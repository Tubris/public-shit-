local isFOVSliding = false
local minFOV = 10
local maxFOV = 500

local function updateFOVCircle()
    local camera = workspace.CurrentCamera
    local viewportSize = camera.ViewportSize
    local screenDiagonal = math.sqrt(viewportSize.X^2 + viewportSize.Y^2)
    local normalizedFOV
    if fovValue <= 173 then
        normalizedFOV = fovValue / 173
    else
        local extraScale = (screenDiagonal / viewportSize.Y) - 1.0
        normalizedFOV = 1.0 + extraScale * ((fovValue - 173) / (500 - 173))
    end    local radius = (viewportSize.Y / 2) * normalizedFOV
    FOVCircle.Position = Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)
    FOVCircle.Radius = radius
end

