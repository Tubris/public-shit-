-- ========== AIMBOT RENDER LOOP ==========
RunService.RenderStepped:Connect(function()
    if not aimbotEnabled then return end
    
    local localCharacter = LocalPlayer.Character
    if not localCharacter or not localCharacter:FindFirstChild("HumanoidRootPart") then return end
    
    local camera = workspace.CurrentCamera
    
    if lockedTarget and lockedTarget.EnemyModel and lockedTarget.EnemyModel.Parent then
        local targetPart = getTargetPartFromEnemy(lockedTarget.EnemyModel)
        if targetPart and targetPart.Parent then
            local humanoid = lockedTarget.EnemyModel:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health > 0 and isInFOV(targetPart.Position) then
                camera.CFrame = CFrame.new(camera.CFrame.Position, targetPart.Position)
                return
            end
        end
        lockedTarget = nil
    end
    
    local enemies = getEnemyPlayersFromHighlight()
    local closestTarget = nil
    local closestDistance = math.huge
    local closestEnemyModel = nil
    
    for _, enemy in ipairs(enemies) do
        local targetPart = getTargetPartFromEnemy(enemy.Model)
        if targetPart and targetPart.Parent == enemy.Model then
            local targetPos = targetPart.Position
            if isInFOV(targetPos) then
                local distance = getDistanceToCursor(targetPos)
                if distance < closestDistance then
                    closestDistance = distance
                    closestTarget = targetPart
                    closestEnemyModel = enemy.Model
                end
            end
        end
    end
    
    if closestTarget and closestEnemyModel then
        lockedTarget = {
            Part = closestTarget,
            EnemyModel = closestEnemyModel
        }
        camera.CFrame = CFrame.new(camera.CFrame.Position, closestTarget.Position)
    end
end)

