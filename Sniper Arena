-- Variable to track if we're waiting for keybind input
local waitingForKeybind = false

-- Function to update keybind button text
local function UpdateKeybindButtonText()
    local keyName = tostring(toggleKeybind):gsub("Enum.KeyCode.", "")
    KeybindButton.Text = "KEYBIND: " .. keyName
    KeybindButton.BackgroundColor3 = Color3.fromRGB(30, 15, 45)
end

-- Keybind button click - listen for next key press
KeybindButton.MouseButton1Click:Connect(function()
    waitingForKeybind = true
    KeybindButton.Text = "PRESS ANY KEY..."
    KeybindButton.BackgroundColor3 = Color3.fromRGB(80, 40, 120)
    task.wait(0.1)
    
    -- Reset after 5 seconds if no key pressed
    task.wait(5)
    if waitingForKeybind then
        waitingForKeybind = false
        UpdateKeybindButtonText()
    end
end)

-- Listen for key presses to set new keybind
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if waitingForKeybind and input.KeyCode ~= Enum.KeyCode.Unknown then
        waitingForKeybind = false
        toggleKeybind = input.KeyCode
        UpdateKeybindButtonText()
    end
end)

-- ========== FUNCTION: TOGGLE MENU VISIBILITY (minimize/restore) ==========
local function ToggleMinimize()
    menuMinimized = not menuMinimized
    if menuMinimized then
        -- Minimize: hide content and shrink frame
        ContentFrame.Visible = false
        MainFrame.Size = UDim2.new(0, 260, 0, 35)
        MinimizeButton.Text = "+"
        MinimizeButton.BackgroundTransparency = 0.3
    else
        -- Restore: show content and restore size
        ContentFrame.Visible = true
        MainFrame.Size = UDim2.new(0, 260, 0, 540)
        MinimizeButton.Text = "−"
        MinimizeButton.BackgroundTransparency = 0.3
    end
end

-- ========== FUNCTION: FULL UNLOAD (disable everything) ==========
local function UnloadScript()
    scriptLoaded = false
    
    -- Disable all hacks
    if aimbotEnabled then
        FOVCircle.Visible = false
    end
    if speedEnabled then
        local character = LocalPlayer.Character
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        if humanoid and originalSpeed then
            humanoid.WalkSpeed = originalSpeed
        end
    end
    if noclipEnabled then
        StopNoclip()
    end
    if espEnabled then
        for player, _ in pairs(espObjects) do
            removeESP(player)
        end
    end
    
    -- Destroy the entire GUI
    ScreenGui:Destroy()
    
    -- Disable all connections (cleanup)
    if Noclipping then
        Noclipping:Disconnect()
        Noclipping = nil
    end
end

-- ========== FUNCTION: TOGGLE WHOLE GUI VISIBLE/INVISIBLE (without unloading) ==========
local function ToggleGuiVisibility()
    if not scriptLoaded then return end
    MainFrame.Visible = not MainFrame.Visible
end

