local function isValidPlayerCharacter(model)
    if not model or not model:IsA("Model") then return false end
    local name = model.Name or ""
    if string.find(name, "_dead") or string.find(string.lower(name), "dead") then return false end
    local humanoid = model:FindFirstChildOfClass("Humanoid")
    if humanoid then
        if humanoid.Health <= 0 then return false end
    else
        return false
    end
    return true
end

local function findAllPlayerCharacters()
    local characters = {}
    for _, child in ipairs(workspace:GetChildren()) do
        if isValidPlayerCharacter(child) then
            local player = Players:GetPlayerFromCharacter(child)
            if player and player ~= LocalPlayer then
                table.insert(characters, child)
            end
        end
    end
    local tempFolder = workspace:FindFirstChild("_Temp")
    if tempFolder then
        for _, child in ipairs(tempFolder:GetChildren()) do
            if isValidPlayerCharacter(child) then
                local player = Players:GetPlayerFromCharacter(child)
                if player and player ~= LocalPlayer then
                    table.insert(characters, child)
                end
            end
            if child:IsA("Folder") or child:IsA("Model") then
                for _, subChild in ipairs(child:GetChildren()) do
                    if isValidPlayerCharacter(subChild) then
                        local player = Players:GetPlayerFromCharacter(subChild)
                        if player and player ~= LocalPlayer then
                            table.insert(characters, subChild)
                        end
                    end
                end
            end
        end
    end
    return characters
end

local function getDistanceToCursor(targetPosition)
    local mouse = LocalPlayer:GetMouse()
    local mousePos = Vector2.new(mouse.X, mouse.Y)
    local screenPos, onScreen = workspace.CurrentCamera:WorldToScreenPoint(targetPosition)
    if not onScreen then return math.huge end
    return (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
end

local function applyVelocity()
    local character = LocalPlayer.Character
    if not character then return end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoid or not rootPart then return end
    if speedEnabled then
        if humanoid.WalkSpeed ~= speedValue then
            humanoid.WalkSpeed = speedValue
        end
        local moveDirection = humanoid.MoveDirection
        if moveDirection.Magnitude > 0 then
            local currentVel = rootPart.Velocity
            local desiredVel = moveDirection * (speedValue * 1.2)
            local newVel = currentVel:Lerp(desiredVel, 0.3)
            newVel = Vector3.new(newVel.X, currentVel.Y, newVel.Z)
            rootPart.Velocity = newVel
        end
    else
        if originalSpeed and humanoid.WalkSpeed ~= originalSpeed then
            humanoid.WalkSpeed = originalSpeed
        end
    end
end

local function StartNoclip()
    if Noclipping then return end
    local function NoclipLoop()
        if noclipEnabled == false then return end
        local character = LocalPlayer.Character
        if character then
            for _, child in pairs(character:GetDescendants()) do
                if child:IsA("BasePart") and child.CanCollide == true then
                    child.CanCollide = false
                end
            end
        end
    end
    Noclipping = RunService.Stepped:Connect(NoclipLoop)
end

local function StopNoclip()
    if Noclipping then
        Noclipping:Disconnect()
        Noclipping = nil
    end
end

local function applyJumpVelocity()
    local character = LocalPlayer.Character
    if not character then return end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoid or not rootPart then return end
    if jumpEnabled then
        local spacePressed = UserInputService:IsKeyDown(Enum.KeyCode.Space)
        local currentState = humanoid:GetState()
        local isOnGround = currentState == Enum.HumanoidStateType.Landed or currentState == Enum.HumanoidStateType.Running or currentState == Enum.HumanoidStateType.GettingUp
        if spacePressed and isOnGround and not isJumping then
            isJumping = true
            local jumpHeight = jumpValue
            if jumpHeight < 50 then jumpHeight = 50 end
            local velocityY = 50 + ((jumpHeight - 50) * 0.8)
            rootPart.Velocity = Vector3.new(rootPart.Velocity.X, velocityY, rootPart.Velocity.Z)
            humanoid.JumpPower = jumpHeight
        elseif not spacePressed and isOnGround then
            isJumping = false
        end
        if spacePressed and currentState == Enum.HumanoidStateType.Jumping then
            local currentVel = rootPart.Velocity
            if currentVel.Y < 20 then
                rootPart.Velocity = Vector3.new(currentVel.X, currentVel.Y + 8, currentVel.Z)
            end
        end
    else
        if humanoid.JumpPower ~= 50 then
            humanoid.JumpPower = 50
        end
        isJumping = false
    end
end

local function isPartVisible(part)
    local camera = workspace.CurrentCamera
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("Head") then return false end
    local headPos = character.Head.Position
    local targetPos = part.Position
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {character, part.Parent}
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    local raycastResult = workspace:Raycast(headPos, (targetPos - headPos).Unit * (targetPos - headPos).Magnitude, raycastParams)
    return raycastResult == nil
end

local function getTeamColor(player)
    if player.Team then
        return player.Team.TeamColor.Color
    else
        return Color3.fromRGB(255, 255, 255)
    end
end

local function getChamColor(player, character)
    if not character then return Color3.fromRGB(255, 0, 0) end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return Color3.fromRGB(255, 0, 0) end
    local head = character:FindFirstChild("Head")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    local checkPart = head or rootPart
    if checkPart and not isPartVisible(checkPart) then
        return Color3.fromRGB(255, 255, 0)
    end
    if humanoid.Health >= humanoid.MaxHealth then
        return Color3.fromRGB(0, 255, 0)
    else
        return Color3.fromRGB(255, 0, 0)
    end
end

local function createESP(player)
    if espObjects[player] then return end
    local espData = {}
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ESP_Name"
    billboard.Size = UDim2.new(0, 200, 0, 25)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = CoreGui
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 1, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = player.Name
    nameLabel.TextColor3 = getTeamColor(player)
    nameLabel.TextStrokeTransparency = 0
    nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    nameLabel.TextSize = 14
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.Parent = billboard
    espData.Billboard = billboard
    espData.NameLabel = nameLabel
    local function createHighlight(character)
        if highlightCache[character] then return end
        local highlight = Instance.new("Highlight")
        highlight.Name = "ESP_Cham"
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0
        highlight.Enabled = true
        highlight.Parent = character
        highlightCache[character] = highlight
        espData.Highlight = highlight
    end
    local character = nil
    for _, char in ipairs(findAllPlayerCharacters()) do
        if Players:GetPlayerFromCharacter(char) == player then
            character = char
            break
        end
    end
    if character then
        createHighlight(character)
    end
    espData.CharacterAdded = player.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        createHighlight(char)
    end)
    espData.CharacterRemoving = player.CharacterRemoving:Connect(function(char)
        if highlightCache[char] then
            highlightCache[char]:Destroy()
            highlightCache[char] = nil
        end
    end)
    espObjects[player] = espData
    local updateConnection
    updateConnection = RunService.RenderStepped:Connect(function()
        if not espObjects[player] then
            updateConnection:Disconnect()
            return
        end
        local character = nil
        local wsChar = workspace:FindFirstChild(player.Name)
        if wsChar and isValidPlayerCharacter(wsChar) then
            character = wsChar
        end
        if not character then
            local tempFolder = workspace:FindFirstChild("_Temp")
            if tempFolder then
                local tempChar = tempFolder:FindFirstChild(player.Name)
                if tempChar and isValidPlayerCharacter(tempChar) then
                    character = tempChar
                end
                if not character then
                    for _, folder in ipairs(tempFolder:GetChildren()) do
                        if folder:IsA("Folder") or folder:IsA("Model") then
                            local subChar = folder:FindFirstChild(player.Name)
                            if subChar and isValidPlayerCharacter(subChar) then
                                character = subChar
                                break
                            end
                        end
                    end
                end
            end
        end
        if character and character:FindFirstChild("Head") then
            local head = character:FindFirstChild("Head")
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            billboard.Adornee = head
            if humanoid and humanoid.Health > 0 then
                local healthPercent = math.floor((humanoid.Health / humanoid.MaxHealth) * 100)
                nameLabel.Text = player.Name .. " | " .. healthPercent .. "%"
                if healthPercent >= 100 then
                    nameLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
                else
                    nameLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
                end
            else
                billboard.Adornee = nil
                return
            end
            if espData.Highlight then
                local chamColor = getChamColor(player, character)
                espData.Highlight.FillColor = chamColor
                espData.Highlight.OutlineColor = chamColor
            end
        else
            billboard.Adornee = nil
        end
    end)
    espData.UpdateConnection = updateConnection
end

local function removeESP(player)
    if espObjects[player] then
        local data = espObjects[player]
        if data.CharacterAdded then data.CharacterAdded:Disconnect() end
        if data.CharacterRemoving then data.CharacterRemoving:Disconnect() end
        if data.UpdateConnection then data.UpdateConnection:Disconnect() end
        if data.Billboard then data.Billboard:Destroy() end
        if data.Highlight then
            data.Highlight:Destroy()
        end
        for char, highlight in pairs(highlightCache) do
            if highlight and highlight.Parent and Players:GetPlayerFromCharacter(char) == player then
                highlight:Destroy()
                highlightCache[char] = nil
            end
        end
        espObjects[player] = nil
    end
end

