-- Dragging functionality (exclude buttons)
local dragging = false
local dragStart, startPos

TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        -- Check if clicking on minimize or unload button
        local mousePos = input.Position
        if MinimizeButton and MinimizeButton.AbsolutePosition then
            if mousePos.X >= MinimizeButton.AbsolutePosition.X and
               mousePos.X <= MinimizeButton.AbsolutePosition.X + MinimizeButton.AbsoluteSize.X and
               mousePos.Y >= MinimizeButton.AbsolutePosition.Y and
               mousePos.Y <= MinimizeButton.AbsolutePosition.Y + MinimizeButton.AbsoluteSize.Y then
                return
            end
        end
        if UnloadButton and UnloadButton.AbsolutePosition then
            if mousePos.X >= UnloadButton.AbsolutePosition.X and
               mousePos.X <= UnloadButton.AbsolutePosition.X + UnloadButton.AbsoluteSize.X and
               mousePos.Y >= UnloadButton.AbsolutePosition.Y and
               mousePos.Y <= UnloadButton.AbsolutePosition.Y + UnloadButton.AbsoluteSize.Y then
                return
            end
        end
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
    end
end)

TitleBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

