RunService.RenderStepped:Connect(function()
    if not aimbotEnabled then return end
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local cam = workspace.CurrentCamera
    
    if lockedTarget and lockedTarget.Model and lockedTarget.Model.Parent then
        local enemies = getEnemyPlayersFromHighlight()
        local valid = false
        for _, e in ipairs(enemies) do
            if e.Model == lockedTarget.Model then
                if wallCheckEnabled then
                    valid = e.IsVisible
                else
                    valid = true
                end
                break
            end
        end
        if valid then
            local tp = getTargetPartFromEnemy(lockedTarget.Model)
            if tp and tp.Parent then
                local hum = lockedTarget.Model:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 and isInFOV(tp.Position) then
                    local target = CFrame.new(cam.CFrame.Position, tp.Position)
                    if smoothness < 100 then
                        cam.CFrame = cam.CFrame:Lerp(target, smoothness / 100)
                    else
                        cam.CFrame = target
                    end
                    return
                end
            end
        end
        lockedTarget = nil
    end
    
    local enemies = getEnemyPlayersFromHighlight()
    local bestDist = math.huge
    local bestTarget = nil
    local bestModel = nil
    
    for _, e in ipairs(enemies) do
        local skip = false
        if wallCheckEnabled then
            if not e.IsVisible then
                skip = true
            end
        end
        if not skip then
            local tp = getTargetPartFromEnemy(e.Model)
            if tp and tp.Parent == e.Model and isInFOV(tp.Position) then
                local dist = getDistanceToCursor(tp.Position)
                if dist < bestDist then
                    bestDist = dist
                    bestTarget = tp
                    bestModel = e.Model
                end
            end
        end
    end
    
    if bestTarget and bestModel then
        lockedTarget = {Part = bestTarget, Model = bestModel}
        local target = CFrame.new(cam.CFrame.Position, bestTarget.Position)
        if smoothness < 100 then
            cam.CFrame = cam.CFrame:Lerp(target, smoothness / 100)
        else
            cam.CFrame = target
        end
    end
end)

