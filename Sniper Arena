local function stopAllHacks()
    if aimbotEnabled then
        FOVCircle.Visible = false
        aimbotEnabled = false
        lockedTarget = nil
    end
    
    if speedEnabled then
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hum and originalSpeed then
            hum.WalkSpeed = originalSpeed
        end
        speedEnabled = false
    end
    
    if jumpEnabled then
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.JumpPower = 50
        end
        jumpEnabled = false
    end
    
    if noclipEnabled then
        if Noclipping then
            Noclipping:Disconnect()
            Noclipping = nil
        end
        local char = LocalPlayer.Character
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = true
                end
            end
        end
        noclipEnabled = false
    end
    
    if espEnabled then
        for p in pairs(espObjects) do
            local data = espObjects[p]
            if data then
                if data.UpdateConnection then data.UpdateConnection:Disconnect() end
                if data.Billboard then data.Billboard:Destroy() end
                if data.Highlight then data.Highlight:Destroy() end
            end
        end
        espObjects = {}
        espEnabled = false
    end
end

local function loadSettings()
    local success, data = pcall(function()
        return game:GetService("HttpService"):JSONDecode(readfile("AimMeSniperMe_Settings.json"))
    end)
    if success and data then
        aimbotEnabled = data.aimbotEnabled or false
        wallCheckEnabled = data.wallCheckEnabled or false
        speedEnabled = data.speedEnabled or false
        jumpEnabled = data.jumpEnabled or false
        espEnabled = data.espEnabled or false
        noclipEnabled = data.noclipEnabled or false
        hitpart = data.hitpart or "Body"
        speedValue = data.speedValue or 16
        jumpValue = data.jumpValue or 50
        fovValue = data.fovValue or 70
        smoothness = data.smoothness or 100
    end
end

local function saveSettings()
    local data = {
        aimbotEnabled = aimbotEnabled,
        wallCheckEnabled = wallCheckEnabled,
        speedEnabled = speedEnabled,
        jumpEnabled = jumpEnabled,
        espEnabled = espEnabled,
        noclipEnabled = noclipEnabled,
        hitpart = hitpart,
        speedValue = speedValue,
        jumpValue = jumpValue,
        fovValue = fovValue,
        smoothness = smoothness
    }
    pcall(function()
        writefile("AimMeSniperMe_Settings.json", game:GetService("HttpService"):JSONEncode(data))
    end)
end

