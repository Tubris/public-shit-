    end
end

local function createESPForPlayer(player, enemyModel)
    if espObjects[player] then return end
    
    local espData = {}
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ESP_Name_" .. player.Name
    billboard.Size = UDim2.new(0, 200, 0, 25)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = CoreGui
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 1, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = player.Name
    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel.TextStrokeTransparency = 0
    nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    nameLabel.TextSize = 14
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.Parent = billboard
    
    espData.Billboard = billboard
    espData.NameLabel = nameLabel
    
    if enemyModel then
        local highlight = Instance.new("Highlight")
        highlight.Name = "ESP_Cham"
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0
        highlight.Enabled = true
        highlight.Parent = enemyModel
        espData.Highlight = highlight
        highlightCache[enemyModel] = highlight
    end
    
    espObjects[player] = espData
    espData.LastModel = enemyModel
    
    local updateConnection
    updateConnection = RunService.RenderStepped:Connect(function()
        if not espObjects[player] then
            updateConnection:Disconnect()
            return
        end
        local enemies = getEnemyPlayersFromHighlight()
        local currentEnemy = nil
        for _, enemy in ipairs(enemies) do
            if enemy.Player == player then
                currentEnemy = enemy
                break
            end
        end
        if currentEnemy and currentEnemy.Model and currentEnemy.RootPart then
            if espData.LastModel ~= currentEnemy.Model then
                if espData.Highlight then
                    espData.Highlight:Destroy()
                end
                local newHighlight = Instance.new("Highlight")
                newHighlight.Name = "ESP_Cham"
                newHighlight.FillTransparency = 0.5
                newHighlight.OutlineTransparency = 0
                newHighlight.Enabled = true
                newHighlight.Parent = currentEnemy.Model
                espData.Highlight = newHighlight
                espData.LastModel = currentEnemy.Model
            end
            updateESPForEnemy(currentEnemy, espData)
        else
            billboard.Adornee = nil
            if espData.Highlight then
                espData.Highlight.Enabled = false
            end
        end
    end)
    espData.UpdateConnection = updateConnection
end

local function removeESP(player)
    if espObjects[player] then
        local data = espObjects[player]
        if data.UpdateConnection then data.UpdateConnection:Disconnect() end
        if data.Billboard then data.Billboard:Destroy() end
        if data.Highlight then data.Highlight:Destroy() end
        espObjects[player] = nil
    end
end

local function refreshAllESP()
    if not espEnabled then return end
    local enemies = getEnemyPlayersFromHighlight()
    local currentEnemyPlayers = {}
    for _, enemy in ipairs(enemies) do
        currentEnemyPlayers[enemy.Player] = true
        if not espObjects[enemy.Player] then
            createESPForPlayer(enemy.Player, enemy.Model)
        end
    end
    for player, _ in pairs(espObjects) do
        if not currentEnemyPlayers[player] then
            removeESP(player)
        end
    end
end

local function toggleESP()
    espEnabled = not espEnabled
    if espEnabled then
        ESPToggle.BackgroundColor3 = Color3.fromRGB(80, 40, 120)
        ESPToggle.Text = "ESP WALLHACK: ON"
        refreshAllESP()
    else
        ESPToggle.BackgroundColor3 = Color3.fromRGB(30, 15, 45)
        ESPToggle.Text = "ESP WALLHACK: OFF"
        for player, _ in pairs(espObjects) do
            removeESP(player)
        end
    end
    task.wait(0.15)
    ESPToggle.BackgroundColor3 = Color3.fromRGB(30, 15, 45)
end

-- ========== AIMBOT FUNCTIONS ==========
local function getDistanceToCursor(targetPosition)
    local mouse = LocalPlayer:GetMouse()
    local mousePos = Vector2.new(mouse.X, mouse.Y)
    local screenPos, onScreen = workspace.CurrentCamera:WorldToScreenPoint(targetPosition)
    if not onScreen then return math.huge end
    return (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
end

local function isInFOV(targetPosition)
    local camera = workspace.CurrentCamera
    local screenPos, onScreen = camera:WorldToScreenPoint(targetPosition)
    if not onScreen then return false end
    local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
    local targetScreen = Vector2.new(screenPos.X, screenPos.Y)
    local distance = (targetScreen - screenCenter).Magnitude
    return distance <= FOVCircle.Radius
end

local function updateFOVCircle()
    local camera = workspace.CurrentCamera
    local viewportSize = camera.ViewportSize
    local normalizedFOV = fovValue / 173
    local radius = (viewportSize.Y / 2) * normalizedFOV
    FOVCircle.Position = Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)
    FOVCircle.Radius = radius
end

