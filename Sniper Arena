-- ========== GET ENEMIES FROM HIGHLIGHT HOLDER ==========
local function getEnemyPlayersFromHighlight()
    local enemies = {}
    local highlightEnemy = workspace:FindFirstChild("Highlight")
    if not highlightEnemy then return enemies end
    local enemyFolder = highlightEnemy:FindFirstChild("Enemy")
    if not enemyFolder then return enemies end
    local highlightHolder = enemyFolder:FindFirstChild("HighlightHolder")
    if not highlightHolder then return enemies end
    
    for _, child in ipairs(highlightHolder:GetChildren()) do
        if child:IsA("Model") then
            local playerName = child.Name
            local player = Players:FindFirstChild(playerName)
            if player and player ~= LocalPlayer then
                local rootPart = child:FindFirstChild("HumanoidRootPart")
                local humanoid = child:FindFirstChildOfClass("Humanoid")
                if rootPart and humanoid and humanoid.Health > 0 then
                    table.insert(enemies, {
                        Model = child,
                        Player = player,
                        RootPart = rootPart,
                        Humanoid = humanoid,
                        Name = playerName
                    })
                end
            end
        end
    end
    return enemies
end

local function getTargetPartFromEnemy(enemyModel)
    if hitpart == "Head" then
        local head = enemyModel:FindFirstChild("Head")
        if head then return head end
        for _, part in ipairs(enemyModel:GetChildren()) do
            if part:IsA("BasePart") and (part.Name:lower() == "head" or part.Name:lower() == "headpart") then
                return part
            end
        end
        return nil
    else
        local rootPart = enemyModel:FindFirstChild("HumanoidRootPart")
        if rootPart then return rootPart end
        local torso = enemyModel:FindFirstChild("UpperTorso") or enemyModel:FindFirstChild("LowerTorso") or enemyModel:FindFirstChild("Torso")
        if torso then return torso end
        for _, part in ipairs(enemyModel:GetChildren()) do
            if part:IsA("BasePart") then
                return part
            end
        end
        return nil
    end
end

-- ========== ESP FUNCTIONS ==========
local function updateESPForEnemy(enemyData, espData)
    if not espData or not espData.Billboard then return end
    local enemyModel = enemyData.Model
    local player = enemyData.Player
    local rootPart = enemyData.RootPart
    
    if enemyModel and rootPart and enemyModel.Parent then
        local head = enemyModel:FindFirstChild("Head") or rootPart
        espData.Billboard.Adornee = head
        
        if enemyData.Humanoid and enemyData.Humanoid.Health > 0 then
            local healthPercent = math.floor((enemyData.Humanoid.Health / enemyData.Humanoid.MaxHealth) * 100)
            espData.NameLabel.Text = player.Name .. " | " .. healthPercent .. "%"
            if healthPercent >= 100 then
                espData.NameLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
            else
                espData.NameLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
            end
        end
        
        if espData.Highlight then
            if enemyData.Humanoid then
                if enemyData.Humanoid.Health >= enemyData.Humanoid.MaxHealth then
                    espData.Highlight.FillColor = Color3.fromRGB(0, 255, 0)
                else
                    espData.Highlight.FillColor = Color3.fromRGB(255, 0, 0)
                end
            end
            espData.Highlight.OutlineColor = Color3.fromRGB(138, 43, 226)
        end
