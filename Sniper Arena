local function setupSliderEvents(button, track, updateFunc)
    local function handleDrag(input)
        local percent = (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
        updateFunc(percent)
    end
    
    button.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            handleDrag(i)
            local moveConn
            local endConn
            moveConn = UserInputService.InputChanged:Connect(function(i2)
                if i2.UserInputType == Enum.UserInputType.MouseMovement then
                    handleDrag(i2)
                end
            end)
            endConn = UserInputService.InputEnded:Connect(function(i2)
                if i2.UserInputType == Enum.UserInputType.MouseButton1 then
                    moveConn:Disconnect()
                    endConn:Disconnect()
                end
            end)
        end
    end)
    
    track.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            handleDrag(i)
            local moveConn
            local endConn
            moveConn = UserInputService.InputChanged:Connect(function(i2)
                if i2.UserInputType == Enum.UserInputType.MouseMovement then
                    handleDrag(i2)
                end
            end)
            endConn = UserInputService.InputEnded:Connect(function(i2)
                if i2.UserInputType == Enum.UserInputType.MouseButton1 then
                    moveConn:Disconnect()
                    endConn:Disconnect()
                end
            end)
        end
    end)
end

