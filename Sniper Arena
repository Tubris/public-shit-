local function isPartVisible(part)
    local character = LocalPlayer.Character
    if not character then return false end
    local head = character:FindFirstChild("Head")
    if not head then return false end
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {character, part.Parent}
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    local result = workspace:Raycast(head.Position, (part.Position - head.Position).Unit * (part.Position - head.Position).Magnitude, raycastParams)
    return result == nil
end

local function getEnemyPlayersFromHighlight()
    local enemies = {}
    local highlightEnemy = workspace:FindFirstChild("Highlight")
    if not highlightEnemy then return enemies end
    local enemyFolder = highlightEnemy:FindFirstChild("Enemy")
    if not enemyFolder then return enemies end
    local highlightHolder = enemyFolder:FindFirstChild("HighlightHolder")
    if not highlightHolder then return enemies end
    
    for _, child in ipairs(highlightHolder:GetChildren()) do
        if child:IsA("Model") then
            local player = Players:FindFirstChild(child.Name)
            if player and player ~= LocalPlayer then
                local rootPart = child:FindFirstChild("HumanoidRootPart")
                local humanoid = child:FindFirstChildOfClass("Humanoid")
                if rootPart and humanoid and humanoid.Health > 0 then
                    table.insert(enemies, {
                        Model = child,
                        Player = player,
                        RootPart = rootPart,
                        Humanoid = humanoid,
                        IsVisible = isPartVisible(rootPart)
                    })
                end
            end
        end
    end
    return enemies
end

local function getTargetPartFromEnemy(model)
    if hitpart == "Head" then
        return model:FindFirstChild("Head")
    else
        local part = model:FindFirstChild("HumanoidRootPart")
        if part then return part end
        return model:FindFirstChild("UpperTorso") or model:FindFirstChild("Torso")
    end
end

local function updateESPForEnemy(data, esp)
    if not esp or not esp.Billboard then return end
    local model = data.Model
    local visible = data.IsVisible
    
    if model and data.RootPart and model.Parent then
        local head = model:FindFirstChild("Head") or data.RootPart
        esp.Billboard.Adornee = head
        
        if data.Humanoid and data.Humanoid.Health > 0 then
            local hp = math.floor((data.Humanoid.Health / data.Humanoid.MaxHealth) * 100)
            if visible then
                esp.NameLabel.TextColor3 = hp >= 100 and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 100, 100)
            else
                esp.NameLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
            end
            esp.NameLabel.Text = data.Player.Name .. " | " .. hp .. "%"
        end
        
        if esp.Highlight then
            esp.Highlight.FillColor = visible and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 255, 0)
            esp.Highlight.FillTransparency = visible and 0.4 or 0.5
            esp.Highlight.OutlineColor = Color3.fromRGB(138, 43, 226)
        end
    else
        esp.Billboard.Adornee = nil
    end
end

local function createESP(player, model, visible)
    if espObjects[player] then return end
    
    local data = {}
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ESP_" .. player.Name
    billboard.Size = UDim2.new(0, 160, 0, 20)
    billboard.StudsOffset = Vector3.new(0, 2.5, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = CoreGui
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = player.Name
    label.TextColor3 = visible and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 200, 0)
    label.TextStrokeTransparency = 0
    label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    label.TextSize = 11
    label.Font = Enum.Font.GothamBold
    label.Parent = billboard
    
    data.Billboard = billboard
    data.NameLabel = label
    
    if model then
        local highlight = Instance.new("Highlight")
        highlight.Name = "ESP"
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0.2
        highlight.Enabled = true
        highlight.FillColor = visible and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 255, 0)
        highlight.OutlineColor = Color3.fromRGB(138, 43, 226)
        highlight.Parent = model
        data.Highlight = highlight
    end
    
    espObjects[player] = data
    
    local conn = RunService.RenderStepped:Connect(function()
        if not espObjects[player] then conn:Disconnect() return end
        local enemies = getEnemyPlayersFromHighlight()
        for _, e in ipairs(enemies) do
            if e.Player == player then
                updateESPForEnemy(e, data)
                return
            end
        end
        billboard.Adornee = nil
        if data.Highlight then data.Highlight.Enabled = false end
    end)
    data.UpdateConnection = conn
end

local function removeESP(player)
    local data = espObjects[player]
    if data then
        if data.UpdateConnection then data.UpdateConnection:Disconnect() end
        if data.Billboard then data.Billboard:Destroy() end
        if data.Highlight then data.Highlight:Destroy() end
        espObjects[player] = nil
    end
end

local function refreshESP()
    if not espEnabled then return end
    local enemies = getEnemyPlayersFromHighlight()
    local current = {}
    for _, e in ipairs(enemies) do
        current[e.Player] = true
        if not espObjects[e.Player] then
            createESP(e.Player, e.Model, e.IsVisible)
        end
    end
    for p in pairs(espObjects) do
        if not current[p] then removeESP(p) end
    end
end

local function getDistanceToCursor(pos)
    local mouse = LocalPlayer:GetMouse()
    local screenPos, onScreen = workspace.CurrentCamera:WorldToScreenPoint(pos)
    if not onScreen then return math.huge end
    return (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(mouse.X, mouse.Y)).Magnitude
end

local function isInFOV(pos)
    local screenPos, onScreen = workspace.CurrentCamera:WorldToScreenPoint(pos)
    if not onScreen then return false end
    local center = Vector2.new(workspace.CurrentCamera.ViewportSize.X / 2, workspace.CurrentCamera.ViewportSize.Y / 2)
    return (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude <= FOVCircle.Radius
end

local function updateFOVCircle()
    local cam = workspace.CurrentCamera
    FOVCircle.Position = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)
    FOVCircle.Radius = (cam.ViewportSize.Y / 2) * (fovValue / 173)
end

local function applyVelocity()
    local character = LocalPlayer.Character
    if not character then return end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoid or not rootPart then return end
    if speedEnabled then
        if humanoid.WalkSpeed ~= speedValue then
            humanoid.WalkSpeed = speedValue
        end
        local moveDirection = humanoid.MoveDirection
        if moveDirection.Magnitude > 0 then
            local currentVel = rootPart.Velocity
            local desiredVel = moveDirection * (speedValue * 1.2)
            local newVel = currentVel:Lerp(desiredVel, 0.3)
            newVel = Vector3.new(newVel.X, currentVel.Y, newVel.Z)
            rootPart.Velocity = newVel
        end
    else
        if originalSpeed and humanoid.WalkSpeed ~= originalSpeed then
            humanoid.WalkSpeed = originalSpeed
        end
    end
end

local function applyJumpVelocity()
    local character = LocalPlayer.Character
    if not character then return end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoid or not rootPart then return end
    if jumpEnabled then
        local spacePressed = UserInputService:IsKeyDown(Enum.KeyCode.Space)
        local currentState = humanoid:GetState()
        local isOnGround = currentState == Enum.HumanoidStateType.Landed or currentState == Enum.HumanoidStateType.Running or currentState == Enum.HumanoidStateType.GettingUp
        if spacePressed and isOnGround and not isJumping then
            isJumping = true
            local jumpHeight = jumpValue
            if jumpHeight < 50 then jumpHeight = 50 end
            local velocityY = 50 + ((jumpHeight - 50) * 0.8)
            rootPart.Velocity = Vector3.new(rootPart.Velocity.X, velocityY, rootPart.Velocity.Z)
            humanoid.JumpPower = jumpHeight
        elseif not spacePressed and isOnGround then
            isJumping = false
        end
        if spacePressed and currentState == Enum.HumanoidStateType.Jumping then
            local currentVel = rootPart.Velocity
            if currentVel.Y < 20 then
                rootPart.Velocity = Vector3.new(currentVel.X, currentVel.Y + 8, currentVel.Z)
            end
        end
    else
        if humanoid.JumpPower ~= 50 then
            humanoid.JumpPower = 50
        end
        isJumping = false
    end
end

