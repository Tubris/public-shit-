local function getTargetPart(character)
    if hitpart == "Head" then
        local head = character:FindFirstChild("Head")
        if head then return head end
        for _, part in ipairs(character:GetChildren()) do
            if part:IsA("BasePart") and (part.Name:lower() == "head" or part.Name:lower() == "headpart") then
                return part
            end
        end
        return nil
    else
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if rootPart then return rootPart end
        local torso = character:FindFirstChild("UpperTorso") or character:FindFirstChild("LowerTorso") or character:FindFirstChild("Torso")
        if torso then return torso end
        return nil
    end
end

local function isInFOV(targetPosition)
    local camera = workspace.CurrentCamera
    local screenPos, onScreen = camera:WorldToScreenPoint(targetPosition)
    if not onScreen then return false end
    local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
    local targetScreen = Vector2.new(screenPos.X, screenPos.Y)
    local distance = (targetScreen - screenCenter).Magnitude
    return distance <= FOVCircle.Radius
end

RunService.RenderStepped:Connect(function()
    if not aimbotEnabled then return end
    local localCharacter = LocalPlayer.Character
    if not localCharacter or not localCharacter:FindFirstChild("HumanoidRootPart") then return end
    local camera = workspace.CurrentCamera
    if lockedTarget then
        local targetChar = lockedTarget.Character
        if targetChar and targetChar.Parent and isValidPlayerCharacter(targetChar) then
            local targetPart = getTargetPart(targetChar)
            if targetPart and targetPart.Parent == targetChar then
                local humanoid = targetChar:FindFirstChildOfClass("Humanoid")
                if humanoid and humanoid.Health > 0 and isInFOV(targetPart.Position) then
                    camera.CFrame = CFrame.new(camera.CFrame.Position, targetPart.Position)
                    return
                end
            end
        end
        lockedTarget = nil
    end
    local allCharacters = findAllPlayerCharacters()
    local closestTarget = nil
    local closestDistance = math.huge
    local closestCharacter = nil
    for _, character in ipairs(allCharacters) do
        if isValidPlayerCharacter(character) then
            local targetPart = getTargetPart(character)
            if targetPart and targetPart.Parent == character then
                local targetPos = targetPart.Position
                if isInFOV(targetPos) then
                    local distance = getDistanceToCursor(targetPos)
                    if distance < closestDistance then
                        closestDistance = distance
                        closestTarget = targetPart
                        closestCharacter = character
                    end
                end
            end
        end
    end
    if closestTarget and closestCharacter then
        lockedTarget = {
            Part = closestTarget,
            Character = closestCharacter
        }
        camera.CFrame = CFrame.new(camera.CFrame.Position, closestTarget.Position)
    end
end)

