sound.Parent = playerGui

-- Variables
local dragging = false
local draggingGUI = false
local dragStart
local frameStart
local currentVolume = 50

-- Update volume UI (100% = 5x louder, so max volume = 5)
local function setVolume(percent)
	currentVolume = math.clamp(percent, 0, 100)
	-- Map 0-100% to 0-5 volume (5x louder at max)
	local mappedVolume = (currentVolume / 100) * 5
	sound.Volume = mappedVolume
	volPercent.Text = tostring(math.floor(currentVolume)) .. "%"
	sliderFill.Size = UDim2.new(currentVolume / 100, 0, 1, 0)
	sliderKnob.Position = UDim2.new(currentVolume / 100, -7, -0.5, -4.5)
end

-- Slider input handler
local function updateFromInput(input)
	local relativeX = math.clamp((input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
	setVolume(relativeX * 100)
end

-- Knob dragging
sliderKnob.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		updateFromInput(input)
	end
end)

-- Background clicking
sliderBg.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		updateFromInput(input)
	end
end)

-- Mouse movement
local uis = game:GetService("UserInputService")
uis.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		updateFromInput(input)
	end
end)

uis.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
	end
end)

-- Load sound
local function loadSound()
	local id = idBox.Text:match("%d+")
	if id then
		sound:Stop()
		sound.SoundId = "rbxassetid://" .. id
		task.wait(0.1)
		sound:Play()
	end
end

loadButton.MouseButton1Click:Connect(loadSound)

-- Play button
playButton.MouseButton1Click:Connect(function()
	sound:Play()
end)

-- Stop button
stopButton.MouseButton1Click:Connect(function()
	sound:Stop()
end)

-- Enter key in textbox
idBox.FocusLost:Connect(function(enterPressed)
	if enterPressed then
		loadSound()
	end
end)

-- GUI Dragging
titleBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		draggingGUI = true
		dragStart = input.Position
		frameStart = mainFrame.Position
	end
end)

uis.InputChanged:Connect(function(input)
	if draggingGUI and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart
		mainFrame.Position = UDim2.new(frameStart.X.Scale, frameStart.X.Offset + delta.X,
										frameStart.Y.Scale, frameStart.Y.Offset + delta.Y)
	end
end)

uis.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		draggingGUI = false
	end
end)

-- Initial load
loadSound()
