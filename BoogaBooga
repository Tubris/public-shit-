		Name = "ChubbisonNotification",
		AnchorPoint = Vector2.new(0, 1),
		Position = UDim2.new(0, -320, 1, -24),
		Size = UDim2.new(0, 300, 0, toastHeight),
		BackgroundColor3 = Color3.fromRGB(12, 8, 28),
