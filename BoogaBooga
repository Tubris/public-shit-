function saveProperties(instance, properties)
	if not instance or fullbright.Instances[instance] then
		return
	end

	local snapshot = {}
	for _, property in ipairs(properties) do
		pcall(function()
			snapshot[property] = instance[property]
		end)
	end
	fullbright.Instances[instance] = snapshot
end

function applyFullbrightToInstance(instance)
	if instance:IsA("Atmosphere") then
		saveProperties(instance, { "Density", "Offset", "Glare", "Haze", "Color", "Decay" })
		instance.Density = 0
		instance.Offset = 0
		instance.Glare = 0
		instance.Haze = 0
	elseif instance:IsA("BloomEffect") or instance:IsA("BlurEffect") or instance:IsA("SunRaysEffect") or instance:IsA("DepthOfFieldEffect") then
		saveProperties(instance, { "Enabled" })
		instance.Enabled = false
	elseif instance:IsA("ColorCorrectionEffect") then
		saveProperties(instance, { "Enabled", "Brightness", "Contrast", "Saturation", "TintColor" })
		instance.Enabled = false
	elseif instance:IsA("Clouds") then
		saveProperties(instance, { "Cover", "Density", "Color" })
		instance.Cover = 0
		instance.Density = 0
	end
end

function applyFullbright()
	if not fullbright.Lighting then
		fullbright.Lighting = {}
		for _, property in ipairs({
			"Ambient",
			"OutdoorAmbient",
			"Brightness",
			"ClockTime",
			"FogStart",
			"FogEnd",
			"FogColor",
			"GlobalShadows",
			"ExposureCompensation",
			"EnvironmentDiffuseScale",
			"EnvironmentSpecularScale",
			"ShadowSoftness",
		}) do
			pcall(function()
				fullbright.Lighting[property] = S.Lighting[property]
			end)
		end
	end

	S.Lighting.Ambient = Color3.fromRGB(255, 255, 255)
	S.Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
	S.Lighting.Brightness = 3
	S.Lighting.ClockTime = 14
	S.Lighting.FogStart = 0
	S.Lighting.FogEnd = 1000000
	S.Lighting.FogColor = Color3.fromRGB(255, 255, 255)
	S.Lighting.GlobalShadows = false
	pcall(function() S.Lighting.ExposureCompensation = 0.25 end)
	pcall(function() S.Lighting.EnvironmentDiffuseScale = 1 end)
	pcall(function() S.Lighting.EnvironmentSpecularScale = 0 end)
	pcall(function() S.Lighting.ShadowSoftness = 0 end)

	for _, descendant in ipairs(S.Lighting:GetDescendants()) do
		applyFullbrightToInstance(descendant)
	end
end

function restoreFullbright()
	if fullbright.Lighting then
		for property, value in pairs(fullbright.Lighting) do
			pcall(function()
				S.Lighting[property] = value
			end)
		end
		fullbright.Lighting = nil
	end

	for instance, snapshot in pairs(fullbright.Instances) do
		if instance and instance.Parent then
			for property, value in pairs(snapshot) do
				pcall(function()
					instance[property] = value
				end)
			end
		end
	end
	table.clear(fullbright.Instances)
end

function setFullbright(enabled)
	state.Fullbright = enabled
	if enabled then
		applyFullbright()
	else
		restoreFullbright()
	end
end

function numberFromValueObject(valueObject)
	if not valueObject then
		return nil
	end

	local ok, value = pcall(function()
		return valueObject.Value
	end)
	if ok then
		if typeof(value) == "number" then
			return value
		elseif typeof(value) == "string" then
			return tonumber(value)
		end
	end

	return nil
end

function readPlaceIdValue(container, names)
	if not container then
		return nil
	end
	for _, name in ipairs(names) do
		local attr = container:GetAttribute(name)
		if typeof(attr) == "number" then
			return attr
		elseif typeof(attr) == "string" then
			local numeric = tonumber(attr)
			if numeric then
				return numeric
			end
		end

		local valueObject = container:FindFirstChild(name, true)
		if valueObject then
			local directValue = numberFromValueObject(valueObject)
			if directValue then
				return directValue
			end

			local placeId = readPlaceIdValue(valueObject, { "PlaceId", "PlaceID", "placeId", "DestinationPlaceId", "Destination" })
			if placeId then
				return placeId
			end
		end
	end
	return nil
end

