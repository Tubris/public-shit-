		health = readNumberValue(workspaceHumanoid:FindFirstChild("Health")) or readNumberValue(workspaceHumanoid)
	end
	health = health or readNumberValue(targetCharacter:FindFirstChildOfClass("Humanoid"))

	local text = targetPlayer.Name
	if health then
		text ..= string.format(" [%d HP]", math.floor(health + 0.5))
	end
	if state.PlayerDistance then
		text ..= string.format(" [%dm]", distanceFromLocal(adornee))
	end
	obj.Text.Text = text
