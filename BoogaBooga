function connect(signal, fn)
	local c = signal:Connect(fn)
	table.insert(connections, c)
	return c
end

function playDeathSound()
	local boolet = S.ReplicatedStorage:FindFirstChild("BOOLET")
	local boom = boolet and boolet:FindFirstChild("boom")
	if not boom or not boom:IsA("Sound") then
		boom = Instance.new("Sound")
		boom.Name = "boom"
		boom.SoundId = "rbxassetid://5178876770"
		boom.Volume = 1
		boom.Parent = boolet or S.ReplicatedStorage
	elseif boom.SoundId == "" then
		boom.SoundId = "rbxassetid://5178876770"
	end
	boom:Play()
end

function watchLocalDeath(currentHumanoid)
	if deathSoundConnection then
		deathSoundConnection:Disconnect()
		deathSoundConnection = nil
	end

	local played = false
	deathSoundConnection = currentHumanoid.HealthChanged:Connect(function(health)
		if health <= 0 and not played then
			played = true
			playDeathSound()
		elseif health > 0 then
			played = false
		end
	end)
	table.insert(connections, deathSoundConnection)
end
