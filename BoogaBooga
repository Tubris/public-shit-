local movementKeys = {
	Forward = false,
	Back = false,
	Left = false,
	Right = false,
	Up = false,
	Down = false,
}

function clearMovementKeys()
	for key in pairs(movementKeys) do
		movementKeys[key] = false
	end
	for key in pairs(freecam.Keys) do
		freecam.Keys[key] = false
	end
end

function startFly()
	local _, hum, root = getCharacterParts()
	if not hum or not root then
		return
	end

	if flyVelocity then
		flyVelocity:Destroy()
	end
	if flyGyro then
		flyGyro:Destroy()
	end

	hum.PlatformStand = true
	root.AssemblyLinearVelocity = Vector3.zero
	root.AssemblyAngularVelocity = Vector3.zero
	flyVelocity = make("BodyVelocity", {
		Name = "ControlPanelFlyVelocity",
		MaxForce = Vector3.new(9e4, 9e4, 9e4),
		Velocity = Vector3.zero,
		P = 4500,
	}, root)
	flyGyro = make("BodyGyro", {
		Name = "ControlPanelFlyGyro",
		MaxTorque = Vector3.new(9e4, 9e4, 9e4),
		CFrame = root.CFrame,
		P = 4500,
	}, root)
end

function stopFly()
	clearMovementKeys()
	if flyVelocity then
		flyVelocity:Destroy()
		flyVelocity = nil
	end
	if flyGyro then
		flyGyro:Destroy()
		flyGyro = nil
	end

	local _, hum = getCharacterParts()
	if hum then
		hum.PlatformStand = false
	end
end

function applyCharacterSettings()
	local _, hum, root = getCharacterParts()
	if not hum then
		return
	end
	if state.Freecam then
		return
	end

	if not state.Fly then
		hum.PlatformStand = false
		hum.AutoRotate = true
		if root then
			root.Anchored = false
		end
	end
	local targetWalkSpeed = state.WalkSpeedEnabled and state.WalkSpeed or defaults.WalkSpeed
	if hum.WalkSpeed ~= targetWalkSpeed then
		hum.WalkSpeed = targetWalkSpeed
	end
	if hum.UseJumpPower then
		local targetJumpPower = state.JumpEnabled and state.JumpPower or defaults.JumpPower
		if hum.JumpPower ~= targetJumpPower then
			hum.JumpPower = targetJumpPower
		end
	else
		local targetJumpHeight = state.JumpEnabled and (state.JumpPower / 7) or defaults.JumpHeight
		if hum.JumpHeight ~= targetJumpHeight then
			hum.JumpHeight = targetJumpHeight
		end
	end
	local targetSlope = state.NoSlip and 89.9 or defaults.MaxSlopeAngle
	if hum.MaxSlopeAngle ~= targetSlope then
		hum.MaxSlopeAngle = targetSlope
	end
	if workspace.Gravity ~= state.Gravity then
		workspace.Gravity = state.Gravity
	end
	local targetZoom = state.InfCamera and 100000 or defaults.CameraMaxZoom
	if player.CameraMaxZoomDistance ~= targetZoom then
		player.CameraMaxZoomDistance = targetZoom
	end
	pcall(function()
		if player.DevCameraOcclusionMode ~= Enum.DevCameraOcclusionMode.Invisicam then
			player.DevCameraOcclusionMode = Enum.DevCameraOcclusionMode.Invisicam
		end
	end)
	if camera then
		if camera.FieldOfView ~= state.PlayerFov then
			camera.FieldOfView = state.PlayerFov
		end
	end
end

function enforceMovementOverrides()
	if state.Freecam then
		return
	end
	local _, hum = getCharacterParts()
	if not hum then
		return
	end

	if state.WalkSpeedEnabled and hum.WalkSpeed ~= state.WalkSpeed then
		hum.WalkSpeed = state.WalkSpeed
	end

	if state.JumpEnabled then
		if hum.UseJumpPower then
			if hum.JumpPower ~= state.JumpPower then
				hum.JumpPower = state.JumpPower
			end
		else
			local targetJumpHeight = state.JumpPower / 7
			if hum.JumpHeight ~= targetJumpHeight then
				hum.JumpHeight = targetJumpHeight
			end
		end
	end
end

function setFreecam(enabled)
	state.Freecam = enabled
	camera = workspace.CurrentCamera
	local _, hum, root = getCharacterParts()

	if enabled then
		if not camera then
			return
		end
		freecam.Original.CameraType = camera.CameraType
		freecam.Original.CameraSubject = camera.CameraSubject
		freecam.Original.MouseBehavior = S.UserInputService.MouseBehavior
		freecam.Original.MouseIconEnabled = S.UserInputService.MouseIconEnabled
		if hum then
			freecam.Original.WalkSpeed = hum.WalkSpeed
			freecam.Original.JumpPower = hum.JumpPower
			freecam.Original.JumpHeight = hum.JumpHeight
			freecam.Original.AutoRotate = hum.AutoRotate
			if not state.AutoRun then
				hum.WalkSpeed = 0
				hum.JumpPower = 0
				hum.JumpHeight = 0
				hum.AutoRotate = false
			end
		end
		if root then
			freecam.Original.RootAnchored = root.Anchored
			if not state.AutoRun then
				root.Anchored = true
				root.AssemblyLinearVelocity = Vector3.zero
			end
		end
		freecam.CFrame = camera.CFrame
		local look = freecam.CFrame.LookVector
		freecam.Yaw = math.atan2(-look.X, -look.Z)
		freecam.Pitch = math.asin(math.clamp(look.Y, -1, 1))
		camera.CameraType = Enum.CameraType.Scriptable
		S.UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
		S.UserInputService.MouseIconEnabled = false
		if not freecamReturnTracer then
			freecamReturnTracer = createTracer(Color3.fromRGB(255, 255, 255))
		end
		notify("Freecam On", "Speed " .. math.floor(state.FreecamSpeed) .. " | Exit " .. keyName(state.FreecamToggleKey) .. " | RGB line = you")
	else
		if camera then
			camera.CameraType = freecam.Original.CameraType or Enum.CameraType.Custom
			camera.CameraSubject = freecam.Original.CameraSubject or hum
		end
		if hum then
			hum.WalkSpeed = freecam.Original.WalkSpeed or defaults.WalkSpeed
			hum.JumpPower = freecam.Original.JumpPower or defaults.JumpPower
			hum.JumpHeight = freecam.Original.JumpHeight or defaults.JumpHeight
			hum.AutoRotate = freecam.Original.AutoRotate ~= false
		end
		if root then
			root.Anchored = freecam.Original.RootAnchored == true
		end
		for key in pairs(freecam.Keys) do
			freecam.Keys[key] = false
		end
		S.UserInputService.MouseBehavior = Enum.MouseBehavior.Default
		S.UserInputService.MouseIconEnabled = true
		task.defer(function()
			S.UserInputService.MouseBehavior = Enum.MouseBehavior.Default
			S.UserInputService.MouseIconEnabled = true
		end)
		if freecamReturnTracer then
			freecamReturnTracer.Visible = false
		end
		table.clear(freecam.Original)
	end
end

function updateFreecam(dt)
	if not state.Freecam then
		return
	end
	camera = workspace.CurrentCamera
	if not camera then
		return
	end
	if not freecam.CFrame then
		freecam.CFrame = camera.CFrame
	end

	local rotation = CFrame.fromOrientation(freecam.Pitch, freecam.Yaw, 0)
	local move = Vector3.zero
	if freecam.Keys.Forward then move += rotation.LookVector end
	if freecam.Keys.Back then move -= rotation.LookVector end
	if freecam.Keys.Right then move += rotation.RightVector end
	if freecam.Keys.Left then move -= rotation.RightVector end
	if freecam.Keys.Up then move += Vector3.yAxis end
	if freecam.Keys.Down then move -= Vector3.yAxis end

	local shiftHeld = freecam.Keys.Boost
		or S.UserInputService:IsKeyDown(Enum.KeyCode.LeftShift)
		or S.UserInputService:IsKeyDown(Enum.KeyCode.RightShift)
	local speed = state.FreecamSpeed * (shiftHeld and 5 or 1)
	if move.Magnitude > 0 then
		freecam.CFrame = freecam.CFrame + move.Unit * speed * dt
	end
	freecam.CFrame = CFrame.new(freecam.CFrame.Position) * rotation
	camera.CFrame = freecam.CFrame

	local _, hum, root = getCharacterParts()
	if hum and not state.AutoRun then
		hum.WalkSpeed = 0
		hum.JumpPower = 0
		hum.JumpHeight = 0
		hum.AutoRotate = false
	elseif hum then
		hum.WalkSpeed = state.WalkSpeedEnabled and state.WalkSpeed or defaults.WalkSpeed
		hum.AutoRotate = true
	end
	if root and not state.AutoRun then
		root.Anchored = true
		root.AssemblyLinearVelocity = Vector3.zero
	elseif root then
		root.Anchored = freecam.Original.RootAnchored == true
	end

	if freecamReturnTracer and root then
		freecamReturnTracer.BackgroundColor3 = rainbowColor(0.35)
		drawTracer(freecamReturnTracer, root.Position, true)
	end
end

function setFly(enabled)
	state.Fly = enabled
	clearMovementKeys()
	if enabled then
		startFly()
	else
		stopFly()
	end
end

function updateFly()
	if not state.Fly then
		return
	end

	local _, hum, root = getCharacterParts()
	if not hum or not root then
		return
	end

	if not flyVelocity or not flyGyro or flyVelocity.Parent ~= root then
		startFly()
	end

	local move = Vector3.zero
	local cf = camera.CFrame
	if movementKeys.Forward or state.AutoRun then move += cf.LookVector end
	if movementKeys.Back then move -= cf.LookVector end
	if movementKeys.Right then move += cf.RightVector end
	if movementKeys.Left then move -= cf.RightVector end
	if movementKeys.Up then move += Vector3.yAxis end
	if movementKeys.Down then move -= Vector3.yAxis end

	if move.Magnitude > 0 then
		move = move.Unit * state.FlySpeed
	else
		root.AssemblyLinearVelocity = Vector3.zero
		root.AssemblyAngularVelocity = Vector3.zero
	end

	flyVelocity.Velocity = move
	flyGyro.CFrame = cf
	hum.PlatformStand = true
end

function restoreNoclip()
	for part, canCollide in pairs(noclipOriginals) do
		if part and part.Parent then
			part.CanCollide = canCollide
		end
	end
	for part, collisionGroup in pairs(noclipCollisionGroups) do
		if part and part.Parent then
			pcall(function()
				part.CollisionGroup = collisionGroup
			end)
		end
	end
	if noclipTerrainGroup then
		pcall(function()
			workspace.Terrain.CollisionGroup = noclipTerrainGroup
		end)
	end
	table.clear(noclipOriginals)
	table.clear(noclipCollisionGroups)
	noclipTerrainGroup = nil
end

function updateNoclip()
	if not state.Noclip then
		return
	end

	local currentCharacter, hum, root = getCharacterParts()
	if not currentCharacter or not root then
		return
	end

	for _, descendant in ipairs(currentCharacter:GetDescendants()) do
		if descendant:IsA("BasePart") then
			if noclipOriginals[descendant] == nil then
				noclipOriginals[descendant] = descendant.CanCollide
			end
			if noclipCollisionGroups[descendant] == nil then
				noclipCollisionGroups[descendant] = descendant.CollisionGroup
			end
			descendant.CanCollide = false
			pcall(function()
				descendant.CollisionGroup = noclipGroupName
			end)
		end
	end

	pcall(function()
		if not noclipTerrainGroup then
			noclipTerrainGroup = workspace.Terrain.CollisionGroup
		end
		workspace.Terrain.CollisionGroup = noclipGroupName
	end)
end

function updateAutoRun()
	if not state.AutoRun or state.Fly then
		return
	end

	local _, hum = getCharacterParts()
	if not hum or not camera then
		return
	end

	local forward = camera.CFrame.LookVector
	local flatForward = Vector3.new(forward.X, 0, forward.Z)
	if flatForward.Magnitude > 0 then
		hum:Move(flatForward.Unit, false)
	end
end

--// ESP
function readableEspColor(color)
	local brightness = color.R * 0.299 + color.G * 0.587 + color.B * 0.114
	if brightness >= 0.22 then
		return color
	end
	return Color3.fromRGB(
		math.floor(math.clamp(color.R * 255 + 150, 165, 255)),
		math.floor(math.clamp(color.G * 255 + 150, 165, 255)),
		math.floor(math.clamp(color.B * 255 + 150, 165, 255))
	)
end

function itemTextColor(name, color)
	if name and string.find(string.lower(name), "god", 1, true) then
		return Color3.fromRGB(255, 220, 70)
	end
	return color and readableEspColor(color) or Color3.fromRGB(245, 245, 245)
end

