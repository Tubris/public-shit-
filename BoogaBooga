--// Window controls
connect(header.InputBegan, function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		drag.Active = true
		drag.Start = input.Position
		drag.FrameStart = main.Position
	end
end)

connect(S.UserInputService.InputChanged, function(input)
	if state.Freecam then
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			freecam.Yaw -= input.Delta.X * 0.0025
			freecam.Pitch = math.clamp(freecam.Pitch - input.Delta.Y * 0.0025, math.rad(-85), math.rad(85))
		elseif input.UserInputType == Enum.UserInputType.MouseWheel then
			local shiftHeld = S.UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) or S.UserInputService:IsKeyDown(Enum.KeyCode.RightShift)
			local step = shiftHeld and 60 or 20
			state.FreecamSpeed = math.clamp(state.FreecamSpeed + input.Position.Z * step, 8, 2500)
		end
	end

	if drag.Active and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - drag.Start
		local targetPosition = UDim2.new(drag.FrameStart.X.Scale, drag.FrameStart.X.Offset + delta.X, drag.FrameStart.Y.Scale, drag.FrameStart.Y.Offset + delta.Y)
		local targetShadowPosition = UDim2.new(drag.FrameStart.X.Scale, drag.FrameStart.X.Offset + delta.X - 10, drag.FrameStart.Y.Scale, drag.FrameStart.Y.Offset + delta.Y - 12)
		local targetAuraPosition = UDim2.new(drag.FrameStart.X.Scale, drag.FrameStart.X.Offset + delta.X - 20, drag.FrameStart.Y.Scale, drag.FrameStart.Y.Offset + delta.Y - 22)
		if drag.Tween then
			drag.Tween:Cancel()
		end
		drag.Tween = S.TweenService:Create(main, TweenInfo.new(0.055, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = targetPosition,
		})
		drag.Tween:Play()
		tween(mainShadow, TweenInfo.new(0.055, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = targetShadowPosition,
		})
		tween(mainAura, TweenInfo.new(0.055, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = targetAuraPosition,
		})
	end
end)

connect(S.UserInputService.InputEnded, function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		drag.Active = false
	end
end)

