		["EU"] = { "eu", "europe", "germany", "frankfurt", "netherlands", "amsterdam", "uk", "london", "france", "paris" },
		["Asia"] = { "asia", "singapore", "tokyo", "japan", "hong kong", "korea", "seoul" },
		["Oceania"] = { "oceania", "australia", "sydney" },
	}

	for _, token in ipairs(wanted[state.ServerRegion] or {}) do
		if string.find(searchText, token, 1, true) then
			return true
		end
	end
	return false
end

function serverMatchesRegion(server, bestPing)
	if state.ServerRegion == "Any" then
		return true
	end
	local ping = serverPing(server)
	local slack = state.ServerRegion == "NA East" and 35
		or state.ServerRegion == "NA West" and 45
		or state.ServerRegion == "EU" and 55
		or 70
	local ceiling = state.ServerRegion == "NA East" and 120
		or state.ServerRegion == "NA West" and 150
		or state.ServerRegion == "EU" and 190
		or state.ServerRegion == "Asia" and 230
		or 260
	if serverMetadataMatchesRegion(server) then
		return ping == math.huge or ping <= ceiling
	end
	if ping == math.huge then
		return false
	end
	return ping <= math.min(ceiling, (bestPing or ping) + slack)
end

function chooseServer(wantsFullest)
	local servers = {}
	local cursor
	local placeId = PLACE.ServerList

	for _ = 1, 5 do
		local ok, data = pcall(getServerList, placeId, cursor)
		if not ok or not data or not data.data then
			warn("Server list failed:", data)
			return nil
		end

		for _, server in ipairs(data.data) do
			local playing = tonumber(server.playing) or 0
			local maxPlayers = tonumber(server.maxPlayers) or 0
			if server.id and server.id ~= game.JobId and playing < maxPlayers then
				table.insert(servers, server)
			end
		end

		cursor = data.nextPageCursor
		if not cursor then
			break
		end
	end

	if #servers == 0 then
		return nil
	end

	local bestPing = math.huge
	for _, server in ipairs(servers) do
		bestPing = math.min(bestPing, serverPing(server))
	end

	local bestServer
	for _, server in ipairs(servers) do
		if serverMatchesRegion(server, bestPing) then
			local playing = tonumber(server.playing) or 0
			local ping = serverPing(server)
			if not bestServer then
				bestServer = server
			else
				local bestPlaying = tonumber(bestServer.playing) or 0
				local bestServerPing = serverPing(bestServer)
				if wantsFullest and (playing > bestPlaying or (playing == bestPlaying and ping < bestServerPing)) then
					bestServer = server
				elseif not wantsFullest and (playing < bestPlaying or (playing == bestPlaying and ping < bestServerPing)) then
					bestServer = server
				end
			end
		end
	end

	return bestServer
end

