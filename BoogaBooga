				else
					for index = #autoHeal.DropOrder, 1, -1 do
						if autoHeal.DropOrder[index] == name then
							table.remove(autoHeal.DropOrder, index)
						end
					end
				end
			end
			row.BackgroundColor3 = value and Color3.fromRGB(245, 245, 245) or Color3.fromRGB(20, 20, 23)
			row.TextColor3 = value and Color3.fromRGB(5, 5, 6) or Color3.fromRGB(235, 235, 240)
			updateWorldEsp()
		end

		connect(row.MouseButton1Click, function()
			setRow(not selections[name])
		end)
	end

	local function refreshOptions()
		for _, name in ipairs(getNames()) do
			addOption(name)
		end
		if searchBox then
			local query = string.lower(searchBox.Text)
			for _, child in ipairs(options:GetChildren()) do
				if child:IsA("TextButton") then
					child.Visible = query == "" or string.find(string.lower(child.Name), query, 1, true) ~= nil
				end
			end
		end
	end

	local function closeDropdown()
		if expanded then
			openDropdowns = math.max(0, openDropdowns - 1)
			dropdownBlocker.Visible = openDropdowns > 0
			syncPageScrolling()
		end
		expanded = false
		overlay.Visible = false
		headerButton.Text = label .. " +"
		if searchBox then
			searchBox.Text = ""
			searchBox:ReleaseFocus()
		end
	end

	table.insert(dropdownClosers, closeDropdown)
	connect(closeButton.MouseButton1Click, closeDropdown)

	connect(headerButton.MouseButton1Click, function()
		local shouldOpen = not expanded
		closeDropdowns()
		expanded = shouldOpen
		overlay.Visible = expanded
		headerButton.Text = label .. (expanded and " -" or " +")
		if expanded then
			openDropdowns += 1
			dropdownBlocker.Visible = true
			syncPageScrolling()
			overlay.Position = UDim2.fromOffset(headerButton.AbsolutePosition.X, headerButton.AbsolutePosition.Y + headerButton.AbsoluteSize.Y + 4)
			overlay.Size = UDim2.new(0, math.max(headerButton.AbsoluteSize.X, 250), 0, withSearch and 250 or 220)
			refreshOptions()
			if searchBox then
				searchBox:CaptureFocus()
			end
		end
	end)

	if searchBox then
		connect(searchBox:GetPropertyChangedSignal("Text"), refreshOptions)
	end

	refreshOptions()
	return refreshOptions
end

