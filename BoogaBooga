function updateAutoDrop(dt)
	if not state.AutoDrop then
		return
	end
	autoHeal.DropTimer += dt
	if autoHeal.DropTimer < math.max(0.001, state.AutoDropDelay / 1000) then
		return
	end
	autoHeal.DropTimer = 0
	local packet = getDropPacket()
	if not packet then
		if os.clock() - autoHeal.LastNoDropNotify > 8 then
			notify("Auto Drop", "No drop packet found.")
			autoHeal.LastNoDropNotify = os.clock()
		end
		return
	end
	local names = {}
	for _, name in ipairs(autoHeal.DropOrder) do
		if selections.AutoDrop[name] and inventorySlotForName(name) then
			table.insert(names, name)
		end
	end
	for name, selected in pairs(selections.AutoDrop) do
		if selected and inventorySlotForName(name) then
			local found = false
			for _, existingName in ipairs(names) do
				found = found or existingName == name
			end
			if not found then
				table.insert(names, name)
			end
		end
	end
	if #names == 0 then
		if os.clock() - autoHeal.LastNoDropNotify > 8 then
			notify("Auto Drop", "No selected inventory item found.")
			autoHeal.LastNoDropNotify = os.clock()
		end
		return
	end
	if autoHeal.DropIndex > #names then
		autoHeal.DropIndex = 1
	end
	local itemName = names[autoHeal.DropIndex]
	local slot = inventorySlotForName(itemName)
	autoHeal.DropIndex = autoHeal.DropIndex % #names + 1
	if slot then
		pcall(function()
			packet.send(slot)
		end)
	end
end

