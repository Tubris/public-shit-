function animatePickupPart(part)
	if not part or not part.Parent or not camera then
		return
	end
	local currentCharacter = player.Character
	if not currentCharacter then
		return
	end
	local clone = part:Clone()
	clone:ClearAllChildren()
	pcall(function() clone:RemoveTag("Draggable") end)
	pcall(function() clone:RemoveTag("Pickup") end)
	clone.CanCollide = false
	clone.Anchored = true
	part:Destroy()
	clone.Parent = camera
	local tweenObj = S.TweenService:Create(clone, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		CFrame = currentCharacter:GetPivot(),
		Size = Vector3.new(0.5, 0.5, 0.5),
		Transparency = 1,
	})
	tweenObj:Play()
	tweenObj.Completed:Once(function()
		if clone and clone.Parent then
			clone:Destroy()
		end
	end)
end

function pickupClosestItem(essenceOnly)
	if not loadPickupModules() then
		return
	end
	local currentCharacter, hum, root = getCharacterParts()
	local itemsFolder = workspace:FindFirstChild("Items")
	if not currentCharacter or not hum or hum.Health <= 0 or not root or not itemsFolder then
		return
	end
	local closestPart, closestDist = nil, math.huge
	for _, part in ipairs(itemsFolder:GetChildren()) do
		if part:IsA("BasePart") and part:GetAttribute("EntityID") and (not essenceOnly or part.Name:find("Essence")) then
			local dist = (root.Position - part.Position).Magnitude
			if dist < closestDist then
				closestDist = dist
				closestPart = part
			end
		end
	end
	if closestPart and closestDist <= 25 and autoHeal.PickupModule.Try(closestPart) then
		local entityID = closestPart:GetAttribute("EntityID")
		if autoHeal.PickupSound then
			autoHeal.PickupSound:Play()
		end
		if entityID then
			autoHeal.PickupRemote.send(entityID)
		end
		animatePickupPart(closestPart)
	end
end

