function updateStats()
	if not state.Stats then
		statsBar.Visible = false
		return
	end
	statsBar.Visible = true

	fpsCounter += 1
	local now = os.clock()
	if now - fpsClock < 0.5 then
		return
	end

	local fps = math.floor(fpsCounter / (now - fpsClock) + 0.5)
	fpsCounter = 0
	fpsClock = now

	table.insert(fpsHistory, fps)
	if #fpsHistory > 8 then table.remove(fpsHistory, 1) end
	local avgFps = 0
	for _, v in ipairs(fpsHistory) do avgFps += v end
	avgFps = math.floor(avgFps / #fpsHistory + 0.5)
	perf.AverageFps = avgFps

	local ping = findPing()
	table.insert(pingHistory, ping)
	if #pingHistory > 8 then table.remove(pingHistory, 1) end
	local avgPing = 0
	for _, v in ipairs(pingHistory) do avgPing += v end
	avgPing = math.floor(avgPing / #pingHistory + 0.5)

	fpsLabel.Text = "FPS " .. avgFps
	playersLabel.Text = string.format("PLR %d/%d", #S.Players:GetPlayers(), S.Players.MaxPlayers)
	pingLabel.Text = "PING " .. avgPing

	fpsLabel.TextColor3 = avgFps >= 55 and Color3.fromRGB(128, 255, 168)
		or avgFps >= 30 and Color3.fromRGB(255, 218, 115)
		or Color3.fromRGB(255, 130, 130)
	pingLabel.TextColor3 = avgPing <= 60 and Color3.fromRGB(128, 255, 168)
		or avgPing <= 120 and Color3.fromRGB(255, 218, 115)
		or Color3.fromRGB(255, 130, 130)
end

function updateHealthBar()
	healthBar.Visible = state.HealthBar
	if not state.HealthBar then
		return
	end
	local health = getLocalWorkspaceHealth() or 0
	local maxHealth = math.max(1, getLocalMaxHealth() or 100)
	local ratio = math.clamp(health / maxHealth, 0, 1)
	local color = ratio >= 0.7 and Color3.fromRGB(95, 235, 120)
		or ratio >= 0.4 and Color3.fromRGB(255, 212, 80)
		or Color3.fromRGB(255, 80, 80)
	healthText.Text = string.format("%d / %d", math.floor(health + 0.5), math.floor(maxHealth + 0.5))
	tween(healthFill, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size = UDim2.fromScale(ratio, 1),
		BackgroundColor3 = color,
	})
end

