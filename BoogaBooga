		obj.ToolText.TextColor3 = itemTextColor(toolName, toolColor)
		obj.ToolText.TextSize = math.max(10, state.PlayerTextSize - 2)
		obj.ToolText.Visible = state.PlayerTools and toolName ~= nil
	end

	drawTracer(obj.Tracer, adornee.Position, state.PlayerEsp and state.PlayerTracers)
end

function hasAnyTag(instance, tags)
	for _, tag in ipairs(tags) do
		if S.CollectionService:HasTag(instance, tag) then
			return true
		end
	end
	return false
end

function isInsideFolderNamed(instance, names)
	local current = instance.Parent
	while current and current ~= workspace do
		for _, folderName in ipairs(names) do
			if string.lower(current.Name) == string.lower(folderName) then
				return true
			end
		end
		current = current.Parent
	end
	return false
end

function hasKeyword(instance, keywords)
	local lowerName = string.lower(instance.Name)
	for _, keyword in ipairs(keywords) do
		if string.find(lowerName, keyword, 1, true) then
			return true
		end
	end
	return false
end

function endsWith(text, suffix)
	return string.sub(text, -#suffix) == suffix
end

function isOreInstance(instance)
	local cleanName = instance.Name:gsub("%s*%b()$", "")
	if oreAliases[cleanName] then
		return true
	end
	local lowerName = string.lower(cleanName)
	return lowerName ~= "node" and (endsWith(lowerName, " node") or endsWith(lowerName, "node"))
end

function getOreColor(instance)
	return oreFallbackColors[selectionName(instance)] or worldRules.Ore.color
end

function shouldIncludeDropped(instance)
	local cleanName = instance.Name:gsub("%s*%b()$", "")
	if selections.Dropped[cleanName] ~= nil then
		return selections.Dropped[cleanName]
	end
	return not filteredDroppedItems[cleanName]
end

function getWanderingTrader()
	local dialogNPCs = workspace:FindFirstChild("DialogNPCs")
	local normal = dialogNPCs and dialogNPCs:FindFirstChild("Normal")
	return normal and normal:FindFirstChild("Wandering Trader")
end

function isInsideWanderingTrader(instance)
	local trader = getWanderingTrader()
	return trader ~= nil and (instance == trader or instance:IsDescendantOf(trader))
end

function getWanderingTraderBody()
	local trader = getWanderingTrader()
	return trader and (
		trader:FindFirstChild("HumanoidRootPart")
		or trader:FindFirstChild("UpperTorso")
		or trader:FindFirstChild("Torso")
		or trader.PrimaryPart
		or trader:FindFirstChildWhichIsA("BasePart", true)
	)
end

function shouldIncludeEntity(instance)
	local lowerName = string.lower(instance.Name)
	if isInsideWanderingTrader(instance) then
		return false
	end
	if instance.Name == "Part" then
		return false
	end
	if string.find(lowerName, "god", 1, true) then
		return false
	end
	if string.find(lowerName, "tree", 1, true)
		or string.find(lowerName, "rock", 1, true)
		or string.find(lowerName, "wood", 1, true) then
		return false
	end
	return true
end

function isTreasureChest(instance)
	local normalized = string.lower(instance.Name):gsub("%s+", "")
	return normalized == "treasurechest"
end

function isMeteorCore(instance)
	return instance:IsA("Model") and instance.Name == "Meteor Core"
end

function isWanderingTrader(instance)
	return instance == getWanderingTraderBody()
end

function isRainbowEvent(instance)
	return isTreasureChest(instance) or isWanderingTrader(instance)
end

function rainbowColor(speed)
	return Color3.fromHSV((os.clock() * (speed or 0.08)) % 1, 0.85, 1)
end

function getMeteorColor(instance)
	local smallRock = instance:FindFirstChild("Small Rock", true)
	if smallRock and smallRock:IsA("BasePart") then
		return smallRock.Color
	end
	local adornee = getAdornee(instance)
	return adornee and adornee.Color or worldRules.Event.color
end

function getEventColor(instance)
	if isMeteorCore(instance) then
		return getMeteorColor(instance)
	elseif isWanderingTrader(instance) then
		return Color3.fromRGB(150, 230, 255)
	end
	return worldRules.Event.color
end

function getEventLabel(instance)
	if isTreasureChest(instance) then
		return "Treasure Chest"
	elseif isMeteorCore(instance) then
		return "Meteor Core"
	elseif isWanderingTrader(instance) then
		return "Wandering Trader"
	end
	return instance.Name
end

function getGodRoot()
	local resources = workspace:FindFirstChild("Resources")
	return resources and resources:FindFirstChild("Ancient God")
end

function isGodBag(instance)
	local current = instance
	while current and current ~= workspace do
		if string.lower(current.Name) == "god bag" then
			return true
		end
		current = current.Parent
	end
	return false
end

function isGodInstance(instance)
	if isGodBag(instance) then
		return false
	end
	local hasGodName = string.find(string.lower(instance.Name), "god", 1, true) ~= nil
	return hasGodName and getAdornee(instance) ~= nil
end

function getGodColor(instance)
	local eyes = instance:FindFirstChild("Eyes", true)
	if eyes and eyes:IsA("BasePart") then
		return eyes.Color
	end
	local parent = instance.Parent
	while parent and parent ~= workspace do
		eyes = parent:FindFirstChild("Eyes", true)
		if eyes and eyes:IsA("BasePart") then
			return eyes.Color
		end
		parent = parent.Parent
	end
	return worldRules.God.color
end

function getGodHealth(instance)
	local model = instance:IsA("Model") and instance or instance:FindFirstAncestorWhichIsA("Model")
	local health = model and model:FindFirstChild("Health")
	if health and health:IsA("IntValue") then
		return health.Value
	end
	health = instance:FindFirstChild("Health", true)
	return health and health:IsA("IntValue") and health.Value or nil
end

function getFolder(name)
	return workspace:FindFirstChild(name)
end

function isInWorkspaceFolder(instance, folderName)
	local folder = getFolder(folderName)
	return folder and (instance == folder or instance:IsDescendantOf(folder))
end

function folderObject(instance, folderName)
	local folder = getFolder(folderName)
	if not folder or instance == folder or not instance:IsDescendantOf(folder) then
		return nil
	end

	local current = instance
	while current.Parent and current.Parent ~= folder do
		current = current.Parent
	end
	return current.Parent == folder and current or nil
end

function isTopFolderObject(instance, folderName)
	return folderObject(instance, folderName) == instance
end

function isPortalInstance(instance)
	return isTopFolderObject(instance, "Portals")
end

function isAntHillInstance(instance)
	return isTopFolderObject(instance, "Mounds")
end

function isTotemInstance(instance)
	return isTopFolderObject(instance, "Totems")
end

function colorFromValue(valueObject, fallback)
	if not valueObject then
		return fallback
	end
	local value = valueObject.Value
	if typeof(value) == "Color3" then
		return value
	end
	if typeof(value) == "BrickColor" then
		return value.Color
	end
	if typeof(value) == "string" then
		local ok, brickColor = pcall(BrickColor.new, value)
		if ok then
			return brickColor.Color
		end
	end
	return fallback
end

function getTotemColor(instance)
	local tribeColor = instance:FindFirstChild("TribeColor", true)
	return colorFromValue(tribeColor, worldRules.Totem.color)
end

function readNumberValue(valueObject)
	if not valueObject then
		return nil
	end
	if valueObject:IsA("Humanoid") then
		return valueObject.Health
	end
	local ok, value = pcall(function()
		return valueObject.Value
	end)
	if ok and typeof(value) == "number" then
		return value
	end
	return nil
end

function getTotemHealth(instance)
	return readNumberValue(instance:FindFirstChild("Health", true))
end

function selectionName(instance)
	local name = instance.Name:gsub("%s*%b()$", "")
	if oreAliases[name] then
		return oreAliases[name]
	end
	if isOreInstance(instance) then
		name = name:gsub("%s+[Nn][Oo][Dd][Ee]$", "")
	end
	return name
end

function canBeWorldCandidate(instance)
	if not instance:IsA("Model") and not instance:IsA("BasePart") then
		return false
	end
	if character and instance:IsDescendantOf(character) then
		return false
	end

	local potential =
		isOreInstance(instance)
		or shouldIncludeEntity(instance) and (
			hasAnyTag(instance, worldRules.Entity.tags)
			or isInsideFolderNamed(instance, worldRules.Entity.folders)
			or hasKeyword(instance, worldRules.Entity.keywords)
		)
		or isTreasureChest(instance)
		or isMeteorCore(instance)
		or isWanderingTrader(instance)
		or isGodInstance(instance)
		or isPortalInstance(instance)
		or isAntHillInstance(instance)
		or isTotemInstance(instance)
		or (
			hasAnyTag(instance, worldRules.Dropped.tags)
			or isInsideFolderNamed(instance, worldRules.Dropped.folders)
		)
	if not potential then
		return false
	end

	return getAdornee(instance) ~= nil
end

function trackWorldCandidate(instance)
	if canBeWorldCandidate(instance) then
		esp.Candidates[instance] = true
	end
end

function untrackWorldCandidate(instance)
	esp.Candidates[instance] = nil
	if esp.World[instance] then
		if esp.World[instance].Billboard then esp.World[instance].Billboard:Destroy() end
		if esp.World[instance].Highlight then esp.World[instance].Highlight:Destroy() end
		if esp.World[instance].Tracer then esp.World[instance].Tracer:Destroy() end
		esp.World[instance] = nil
	end
end

function matchesWorldRule(instance, ruleName)
	local rule = worldRules[ruleName]
	if not rule then
		return false
	end

	if ruleName == "Ore" then
		local name = selectionName(instance)
		return name ~= "" and isOreInstance(instance) and selections.Ore[name] ~= false
	end

	if ruleName == "Entity" and not shouldIncludeEntity(instance) then
		return false
	end

	if ruleName == "Entity" then
		local name = selectionName(instance)
		if selections.Entity[name] ~= true then
			return false
		end
	end

	if ruleName == "Event" then
		return isTreasureChest(instance) or isMeteorCore(instance) or isWanderingTrader(instance)
	end

	if ruleName == "God" then
		return isGodInstance(instance)
	end

	if ruleName == "Portal" then
		return isPortalInstance(instance) and selections.Portal[selectionName(instance)] ~= false
	end

	if ruleName == "AntHill" then
		return isAntHillInstance(instance)
	end

	if ruleName == "Totem" then
		return isTotemInstance(instance)
	end

	if ruleName == "Dropped" and not shouldIncludeDropped(instance) then
		return false
	end

	if ruleName == "Dropped" then
		return hasAnyTag(instance, rule.tags) or isInsideFolderNamed(instance, rule.folders)
	end

	return hasAnyTag(instance, rule.tags)
		or isInsideFolderNamed(instance, rule.folders)
		or hasKeyword(instance, rule.keywords)
end

function getWorldCandidates()
	local candidates = {}

	for instance in pairs(esp.Candidates) do
		if instance.Parent and canBeWorldCandidate(instance) then
			table.insert(candidates, instance)
		else
			esp.Candidates[instance] = nil
		end
	end

	return candidates
end

function ensureWorldEsp(instance, ruleName)
	local adornee = getAdornee(instance)
	if not adornee then
		return
	end

	local rule = worldRules[ruleName]
	local color = ruleName == "Dropped" and adornee.Color
		or ruleName == "Ore" and getOreColor(instance)
		or ruleName == "Portal" and adornee.Color
		or ruleName == "AntHill" and adornee.Color
		or ruleName == "Totem" and getTotemColor(instance)
		or ruleName == "God" and getGodColor(instance)
		or ruleName == "Event" and getEventColor(instance)
		or rule.color
	local obj = esp.World[instance]
	if not obj then
		local billboard, text, subText = createBillboard(instance.Name, color, state.WorldTextSize, ruleName == "God")
		local highlight = createHighlight(color)
		local tracer = createTracer(color)
		billboard.Parent = screenGui
		highlight.Parent = screenGui

		obj = {
			Instance = instance,
			RuleName = ruleName,
			Billboard = billboard,
			Text = text,
			SubText = subText,
			Highlight = highlight,
			Tracer = tracer,
		}
		esp.World[instance] = obj
	end

	obj.Billboard.Adornee = adornee
	obj.Billboard.StudsOffset = ruleName == "Dropped" and Vector3.new(0, 1.25, 0) or Vector3.new(0, 3, 0)
	obj.Billboard.Size = ruleName == "Dropped" and UDim2.new(0, 132, 0, 30)
		or ruleName == "God" and UDim2.new(0, 190, 0, 54)
		or UDim2.new(0, 180, 0, 42)
	obj.Highlight.Adornee = instance:IsA("Model") and instance or adornee
	obj.Billboard.Enabled = state.WorldNames
	obj.Highlight.Enabled = state.WorldChams
	obj.Highlight.FillColor = color
	obj.Highlight.OutlineColor = color
	obj.Tracer.BackgroundColor3 = color
	obj.Text.TextSize = state.WorldTextSize

	local label = ruleName == "Event" and getEventLabel(instance)
		or ruleName == "Ore" and selectionName(instance)
		or instance.Name
	local textColor = ruleName == "Event" and isRainbowEvent(instance) and rainbowColor(0.12)
		or ruleName == "Dropped" and itemTextColor(label, color)
		or readableEspColor(color)
	obj.Text.TextColor3 = textColor
	if ruleName == "Totem" then
		local health = getTotemHealth(instance)
		if health then
			label ..= string.format(" [%d HP]", math.floor(health + 0.5))
		end
	end
	if state.WorldDistance then
		label ..= string.format(" [%dm]", distanceFromLocal(adornee))
	end
	obj.Text.Text = label
	if obj.SubText then
		local health = ruleName == "God" and getGodHealth(instance)
		obj.SubText.Visible = ruleName == "God" and health ~= nil
		obj.SubText.Text = health and string.format("Health: %d", math.floor(health + 0.5)) or ""
		obj.SubText.TextColor3 = textColor
		obj.SubText.TextSize = math.max(10, state.WorldTextSize - 2)
	end

	drawTracer(obj.Tracer, adornee.Position, state.WorldTracers)
end

local perf

function updateWorldEsp()
	local scanStarted = os.clock()
	local enabledRules = {
		{ "God", state.GodEsp },
		{ "Portal", state.PortalEsp },
		{ "AntHill", state.AntHillEsp },
		{ "Totem", state.TotemEsp },
		{ "Event", state.EventEsp },
		{ "Ore", state.OreEsp },
		{ "Entity", state.EntityEsp },
		{ "Dropped", state.DroppedEsp },
	}

	local anyEnabled = false
	for _, ruleInfo in ipairs(enabledRules) do
		anyEnabled = anyEnabled or ruleInfo[2]
	end

	if not anyEnabled then
		clearEsp(esp.World)
		return
	end

	local active = {}
	local ruleCounts = {}
	local ruleLimit = state.WorldMaxObjects
	local droppedLimit = state.DroppedMaxObjects
	if state.PerformanceGuard then
		if perf.AverageFps > 0 and perf.AverageFps < 30 then
			ruleLimit = math.min(ruleLimit, 35)
			droppedLimit = math.min(droppedLimit, 15)
		elseif perf.AverageFps > 0 and perf.AverageFps < 45 then
			ruleLimit = math.min(ruleLimit, 60)
			droppedLimit = math.min(droppedLimit, 25)
		end
	end
	local candidates = getWorldCandidates()
	for _, ruleInfo in ipairs(enabledRules) do
		local ruleName, enabled = ruleInfo[1], ruleInfo[2]
		if enabled then
			local limit = ruleName == "Dropped" and droppedLimit
				or ruleName == "Ore" and math.huge
				or ruleLimit
			for _, instance in ipairs(candidates) do
				if (ruleCounts[ruleName] or 0) >= limit then
					break
				end
				if not active[instance] and matchesWorldRule(instance, ruleName) then
					active[instance] = true
					ensureWorldEsp(instance, ruleName)
					ruleCounts[ruleName] = (ruleCounts[ruleName] or 0) + 1
				end
			end
		end
	end

	for instance, obj in pairs(esp.World) do
		if not active[instance] or not obj.Instance.Parent then
			if obj.Billboard then obj.Billboard:Destroy() end
			if obj.Highlight then obj.Highlight:Destroy() end
			if obj.Tracer then obj.Tracer:Destroy() end
			esp.World[instance] = nil
		end
	end
	if state.PerformanceGuard then
		perf.WorldEspCost = os.clock() - scanStarted
		if perf.WorldEspCost > 0.08 then
			perf.WorldCooldown = math.min(8, state.WorldRefreshTime + perf.WorldEspCost * 18)
		elseif perf.WorldCooldown > state.WorldRefreshTime then
			perf.WorldCooldown = math.max(state.WorldRefreshTime, perf.WorldCooldown - 0.25)
		end
	end
end

