function tween(obj, info, props)
	S.TweenService:Create(obj, info or TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end

function make(className, props, parent)
	local obj = Instance.new(className)
	for k, v in pairs(props or {}) do
		obj[k] = v
	end
	obj.Parent = parent
	return obj
end

function themeHue()
	return state.GuiThemeRgb and ((tick() * 44) % 359) or (state.GuiThemeHue or 267)
end

function themeColor(saturation, value)
	return Color3.fromHSV(themeHue() / 359, saturation or 0.72, value or 1)
end

function applyThemeTarget(target)
	if not target.Obj or not target.Obj.Parent then
		return
	end
	if target.Gradient then
		target.Obj.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, themeColor(0.78, 0.36)),
			ColorSequenceKeypoint.new(0.55, Color3.fromRGB(12, 8, 28)),
			ColorSequenceKeypoint.new(1, themeColor(0.78, 0.56)),
		})
	else
		target.Obj[target.Prop] = themeColor(target.Sat, target.Val)
	end
end

function themeRegister(obj, prop, saturation, value)
	table.insert(themeTargets, { Obj = obj, Prop = prop, Sat = saturation, Val = value })
	applyThemeTarget(themeTargets[#themeTargets])
	return obj
end

function themeGradient(obj)
	table.insert(themeTargets, { Obj = obj, Gradient = true })
	applyThemeTarget(themeTargets[#themeTargets])
	return obj
end

function applyGuiTheme()
	for _, target in ipairs(themeTargets) do
		applyThemeTarget(target)
	end
	for _, redraw in ipairs(themeRedraws) do
		pcall(redraw)
	end
end

