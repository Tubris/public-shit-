function sortedKeys(set)
	local names = {}
	for name in pairs(set) do
		table.insert(names, name)
	end
	table.sort(names)
	return names
end

function collectOreNames()
	local names = {}
	for _, name in ipairs(oreTypeNames) do
		names[name] = true
		if selections.Ore[name] == nil then
			selections.Ore[name] = true
		end
	end
	for instance in pairs(esp.Candidates) do
		if instance.Parent and isOreInstance(instance) then
			local name = selectionName(instance)
			if name ~= "" then
				names[name] = true
				if selections.Ore[name] == nil then
					selections.Ore[name] = true
				end
			end
		end
	end
	for _, descendant in ipairs(workspace:GetDescendants()) do
		if (descendant:IsA("Model") or descendant:IsA("BasePart")) and isOreInstance(descendant) then
			local name = selectionName(descendant)
			if name ~= "" then
				names[name] = true
				if selections.Ore[name] == nil then
					selections.Ore[name] = true
				end
			end
		end
	end
	return sortedKeys(names)
end

function collectEntityNames()
	local names = {}
	local function maybeAdd(instance)
		if shouldIncludeEntity(instance)
			and (
				hasAnyTag(instance, worldRules.Entity.tags)
				or isInsideFolderNamed(instance, worldRules.Entity.folders)
				or hasKeyword(instance, worldRules.Entity.keywords)
			) then
			names[selectionName(instance)] = true
		end
	end
	for instance in pairs(esp.Candidates) do
		if instance.Parent then
			maybeAdd(instance)
		end
	end
	for _, descendant in ipairs(workspace:GetDescendants()) do
		if descendant:IsA("Model") or descendant:IsA("BasePart") then
			maybeAdd(descendant)
		end
	end
	return sortedKeys(names)
end

function collectPortalNames()
	local names = {}
	local portals = workspace:FindFirstChild("Portals")
	if portals then
		for _, child in ipairs(portals:GetChildren()) do
			if (child:IsA("Model") or child:IsA("BasePart")) and getAdornee(child) then
				names[selectionName(child)] = true
			end
		end
	end
	return sortedKeys(names)
end

function collectDroppedNames()
	local names = {}
	local function maybeAdd(instance)
		if (instance:IsA("Model") or instance:IsA("BasePart"))
			and (hasAnyTag(instance, worldRules.Dropped.tags) or isInsideFolderNamed(instance, worldRules.Dropped.folders)) then
			names[selectionName(instance)] = true
		end
	end
	for instance in pairs(esp.Candidates) do
		if instance.Parent then
			maybeAdd(instance)
		end
	end
	for _, descendant in ipairs(workspace:GetDescendants()) do
		maybeAdd(descendant)
	end
	return sortedKeys(names)
end

