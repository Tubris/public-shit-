function createSlider(parent, label, min, max, getValue, setValue)
	local row = make("Frame", {
		Size = UDim2.new(1, 0, 0, 46),
		BackgroundTransparency = 1,
	}, parent)

	local labelText = make("TextLabel", {
		Size = UDim2.new(1, 0, 0, 18),
		BackgroundTransparency = 1,
		Font = Enum.Font.Gotham,
		TextColor3 = Color3.fromRGB(255, 248, 255),
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
	}, row)

	local bar = make("Frame", {
		Position = UDim2.new(0, 0, 0, 29),
		Size = UDim2.new(1, 0, 0, 6),
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		BackgroundTransparency = 0.9,
		BorderSizePixel = 0,
	}, row)
	corner(bar, 3)

	local fill = themeRegister(make("Frame", {
		Size = UDim2.new(0, 0, 1, 0),
		BackgroundColor3 = Color3.fromRGB(135, 70, 230),
		BorderSizePixel = 0,
	}, bar), "BackgroundColor3", 0.86, 0.82)
	corner(fill, 3)

	local knob = make("TextButton", {
		Position = UDim2.new(0, -8, 0, 22),
		Size = UDim2.new(0, 20, 0, 20),
		BackgroundColor3 = Color3.fromRGB(250, 242, 255),
		BorderSizePixel = 0,
		AutoButtonColor = false,
		Text = "",
	}, row)
	corner(knob, 10)

	local sliding = false

	local function setFromX(x)
		local relative = math.clamp((x - bar.AbsolutePosition.X) / math.max(bar.AbsoluteSize.X, 1), 0, 1)
		local value = math.floor(min + (max - min) * relative + 0.5)
		setValue(value)
	end

	local function redraw()
		local value = math.clamp(getValue(), min, max)
		local alpha = (value - min) / (max - min)
		labelText.Text = string.format("%s: %s", label, tostring(value))
		fill.Size = UDim2.new(alpha, 0, 1, 0)
		knob.Position = UDim2.new(alpha, -10, 0, 22)
	end

	connect(knob.MouseButton1Down, function()
		sliding = true
	end)
	connect(bar.InputBegan, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			sliding = true
			setFromX(input.Position.X)
			redraw()
		end
	end)
	connect(S.UserInputService.InputEnded, function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			sliding = false
		end
	end)
	connect(S.UserInputService.InputChanged, function(input)
		if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			setFromX(input.Position.X)
			redraw()
		end
	end)

	redraw()
	return redraw
end

