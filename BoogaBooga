connect(S.RunService.RenderStepped, function(dt)
	camera = workspace.CurrentCamera
	characterSettingsTimer += dt
	if characterSettingsTimer >= 0.25 then
		characterSettingsTimer = 0
		applyCharacterSettings()
	end
	enforceMovementOverrides()
	updateFreecam(dt)
	updateFly()
	updateNoclip()
	updateAutoRun()
	updateAutoHeal(dt)
	updateAutoHunger(dt)
	updateAutoPickup(dt)
	updateAutoDrop(dt)
	updateDance()
	updateStats()
	updateHealthBar()
	updateBloodFruitCounter()
	if state.GuiThemeRgb then
		autoHeal.ThemeRgbTimer += dt
		if autoHeal.ThemeRgbTimer >= 0.04 then
			autoHeal.ThemeRgbTimer = 0
			applyGuiTheme()
		end
	end

	if state.PlayerEsp then
		for _, targetPlayer in ipairs(S.Players:GetPlayers()) do
			ensurePlayerEsp(targetPlayer)
		end
	else
		clearEsp(esp.Players)
	end

	worldScanTimer += dt
	local scanDelay = state.PerformanceGuard and perf.WorldCooldown or state.WorldRefreshTime
	if state.PerformanceGuard and perf.AverageFps > 0 and perf.AverageFps < 30 then
		scanDelay += 1.5
	end
	if worldScanTimer >= scanDelay then
		worldScanTimer = 0
		updateWorldEsp()
	end

	if state.WorldTracers then
		for _, obj in pairs(esp.World) do
			if obj.Instance and obj.Instance.Parent and obj.Tracer then
				local adornee = getAdornee(obj.Instance)
				if adornee then
					drawTracer(obj.Tracer, adornee.Position, true)
				end
			end
		end
	elseif worldTracersLast then
		for _, obj in pairs(esp.World) do
			if obj.Tracer then
				drawTracer(obj.Tracer, Vector3.zero, false)
			end
		end
	end
	worldTracersLast = state.WorldTracers

	for _, obj in pairs(esp.World) do
		if obj.RuleName == "Event" and obj.Instance and obj.Instance.Parent and isRainbowEvent(obj.Instance) then
			local color = rainbowColor(0.12)
			if obj.Text then
				obj.Text.TextColor3 = color
			end
			if obj.Highlight then
				obj.Highlight.FillColor = color
				obj.Highlight.OutlineColor = color
			end
			if obj.Tracer then
				obj.Tracer.BackgroundColor3 = color
			end
		end
	end

	worldLabelTimer += dt
	local labelDelay = state.WorldLabelRefreshTime
	if state.PerformanceGuard and perf.AverageFps > 0 and perf.AverageFps < 45 then
		labelDelay = 0.65
	end
	if worldLabelTimer >= labelDelay then
		worldLabelTimer = 0

		for _, obj in pairs(esp.World) do
			if obj.Instance and obj.Instance.Parent then
				local adornee = getAdornee(obj.Instance)
				if adornee then
					local rule = worldRules[obj.RuleName]
					local color = obj.RuleName == "Dropped" and adornee.Color
						or obj.RuleName == "Ore" and getOreColor(obj.Instance)
						or obj.RuleName == "Portal" and adornee.Color
						or obj.RuleName == "AntHill" and adornee.Color
						or obj.RuleName == "Totem" and getTotemColor(obj.Instance)
						or obj.RuleName == "God" and getGodColor(obj.Instance)
						or obj.RuleName == "Event" and getEventColor(obj.Instance)
						or rule.color
					if obj.RuleName == "Event" and isRainbowEvent(obj.Instance) then
						color = rainbowColor(0.12)
					end
					local label = obj.RuleName == "Event" and getEventLabel(obj.Instance)
						or obj.RuleName == "Ore" and selectionName(obj.Instance)
						or obj.Instance.Name
					if obj.RuleName == "Totem" then
						local health = getTotemHealth(obj.Instance)
						if health then
							label ..= string.format(" [%d HP]", math.floor(health + 0.5))
						end
					end
					if state.WorldDistance then
						label ..= string.format(" [%dm]", distanceFromLocal(adornee))
					end
					obj.Text.Text = label
					obj.Text.TextSize = state.WorldTextSize
					local baseLabel = obj.RuleName == "Event" and getEventLabel(obj.Instance)
						or obj.RuleName == "Ore" and selectionName(obj.Instance)
						or obj.Instance.Name
					local textColor = obj.RuleName == "Dropped" and itemTextColor(baseLabel, color) or readableEspColor(color)
					obj.Text.TextColor3 = textColor
					if obj.SubText then
						local health = obj.RuleName == "God" and getGodHealth(obj.Instance)
						obj.SubText.Visible = obj.RuleName == "God" and health ~= nil
						obj.SubText.Text = health and string.format("Health: %d", math.floor(health + 0.5)) or ""
						obj.SubText.TextSize = math.max(10, state.WorldTextSize - 2)
						obj.SubText.TextColor3 = textColor
					end
					obj.Billboard.Enabled = state.WorldNames
					obj.Highlight.Enabled = state.WorldChams
					obj.Highlight.FillColor = color
					obj.Highlight.OutlineColor = color
					obj.Tracer.BackgroundColor3 = color
					if not state.WorldTracers then
						drawTracer(obj.Tracer, adornee.Position, false)
					end
				end
			end
		end
	end
end)

