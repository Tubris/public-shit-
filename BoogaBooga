function updateAutoHeal(dt)
	if not state.AutoHeal then
		autoHeal.HealNotified = false
		return
	end
	autoHeal.Timer += dt
	if autoHeal.Timer < 0.01 or os.clock() - autoHeal.LastUse < 0.01 then
		return
	end
	autoHeal.Timer = 0
	local health = getLocalWorkspaceHealth()
	if not health or health > state.AutoHealHealth then
		autoHeal.HealNotified = false
		return
	end
	local slot, _, quantity = findBloodfruit()
	local usedItem = "Blood Fruit"
	if not slot or quantity <= 0 then
		if state.HealFallback and loadAutoHealModules() then
			for _, foodName in ipairs(foodTypeNames) do
				local okFood, foodSlot = pcall(function()
					return autoHeal.GameUtil.hasItem(foodName)
				end)
				if okFood and foodSlot then
					slot = foodSlot
					usedItem = foodName
					break
				end
			end
		end
		if not slot then
			if os.clock() - autoHeal.LastNoHealNotify > 8 then
				notify("Auto Heal", state.HealFallback and "No Blood Fruit or fallback food found." or "No Blood Fruit found.")
				autoHeal.LastNoHealNotify = os.clock()
			end
			return
		end
	end
	local ok = pcall(function()
		autoHeal.Packets.UseBagItem.send(slot)
	end)
	if ok then
		autoHeal.LastUse = os.clock()
		if not autoHeal.HealNotified then
			notify("Auto Heal", string.format("Ate %s at %d HP.", usedItem, math.floor(health + 0.5)))
			autoHeal.HealNotified = true
		end
	end
end

function updateAutoHunger(dt)
	if not state.AutoHunger then
		autoHeal.HungerPendingFood = nil
		autoHeal.NoHungerAttempts = 0
		return
	end
	if not loadAutoHealModules() then
		return
	end
	local hunger = autoHeal.GameUtil.Data and autoHeal.GameUtil.Data.stats and autoHeal.GameUtil.Data.stats.food
	if autoHeal.HungerPendingFood then
		if hunger and hunger > (autoHeal.HungerPendingValue or hunger) then
			local inventory = autoHeal.GameUtil.Data and autoHeal.GameUtil.Data.inventory
			local item = inventory and autoHeal.HungerPendingSlot and inventory[autoHeal.HungerPendingSlot]
			local left = item and (tonumber(item.quantity) or 0) or 0
			notify("Auto Hunger", string.format("Ate %s (+%.1f hunger). Left: %d", autoHeal.HungerPendingFood, hunger - autoHeal.HungerPendingValue, left))
			autoHeal.HungerPendingFood = nil
			autoHeal.HungerPendingSlot = nil
		elseif os.clock() - autoHeal.HungerPendingTime > 4 then
			autoHeal.HungerPendingFood = nil
			autoHeal.HungerPendingSlot = nil
		end
	end
	if autoHeal.HungerPendingFood then
		return
	end
	autoHeal.HungerTimer += dt
	if autoHeal.HungerTimer < 2 then
		return
	end
	autoHeal.HungerTimer = 0
	if not hunger or hunger > state.AutoHungerLevel then
		return
	end
	for _, foodName in ipairs(foodTypeNames) do
		if selections.Food[foodName] then
			local ok, slot = pcall(function()
				return autoHeal.GameUtil.hasItem(foodName)
			end)
			if ok and slot then
				pcall(function()
					autoHeal.Packets.UseBagItem.send(slot)
				end)
				autoHeal.NoHungerAttempts = 0
				autoHeal.HungerPendingFood = foodName
				autoHeal.HungerPendingValue = hunger
				autoHeal.HungerPendingSlot = slot
				autoHeal.HungerPendingTime = os.clock()
				return
			end
		end
	end
	autoHeal.NoHungerAttempts += 1
	if autoHeal.NoHungerAttempts % 30 == 0 then
		notify("Auto Hunger", "No enabled food found.")
	end
end

