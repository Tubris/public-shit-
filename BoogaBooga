		if expanded then
			openDropdowns += 1
			dropdownBlocker.Visible = true
			syncPageScrolling()
			overlay.Position = UDim2.fromOffset(headerButton.AbsolutePosition.X, headerButton.AbsolutePosition.Y + headerButton.AbsoluteSize.Y + 4)
			overlay.Size = UDim2.new(0, math.max(headerButton.AbsoluteSize.X, 250), 0, (#choices * 30) + 12)
