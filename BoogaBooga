	}, screenGui)
	corner(toast, 14)
	stroke(toast, Color3.fromRGB(190, 135, 255), 0.2, 1)

	themeGradient(make("UIGradient", {
		Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromRGB(38, 18, 82)),
			ColorSequenceKeypoint.new(0.58, Color3.fromRGB(12, 8, 28)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(72, 24, 118)),
		}),
		Rotation = 24,
	}, toast))

	make("TextLabel", {
		Position = UDim2.new(0, 14, 0, 7),
		Size = UDim2.new(1, -28, 0, 18),
		BackgroundTransparency = 1,
		Font = Enum.Font.GothamBold,
