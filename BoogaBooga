function createTracer(color)
	local frame = make("Frame", {
		Name = "ControlPanelTracer",
		AnchorPoint = Vector2.new(0.5, 0.5),
		BackgroundColor3 = color,
		BorderSizePixel = 0,
		Visible = false,
		ZIndex = 50,
	}, screenGui)
	return frame
end

function drawTracer(frame, worldPosition, enabled)
	if not enabled or not frame or not camera then
		if frame then
			frame.Visible = false
		end
		return
	end

	local point, visible = camera:WorldToViewportPoint(worldPosition)
	if not visible or point.Z <= 0 then
		frame.Visible = false
		return
	end

	local start = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y - 18)
	local finish = Vector2.new(point.X, point.Y)
	local diff = finish - start
	local length = diff.Magnitude
	if length < 4 then
		frame.Visible = false
		return
	end

	frame.Size = UDim2.new(0, length, 0, 2)
	frame.Position = UDim2.fromOffset((start.X + finish.X) / 2, (start.Y + finish.Y) / 2)
	frame.Rotation = math.deg(math.atan2(diff.Y, diff.X))
	frame.Visible = true
end

function clearEsp(bucket)
	for key, obj in pairs(bucket) do
		if obj.Billboard then obj.Billboard:Destroy() end
		if obj.Highlight then obj.Highlight:Destroy() end
		if obj.Tracer then obj.Tracer:Destroy() end
		bucket[key] = nil
	end
end

function getPlayerToolInfo(targetPlayer)
	local workspacePlayers = workspace:FindFirstChild("Players")
	local workspacePlayer = workspacePlayers and workspacePlayers:FindFirstChild(targetPlayer.Name)
	local toolsFolder = workspacePlayer and workspacePlayer:FindFirstChild("Tools")
	if not toolsFolder then
		return nil
	end
	for _, tool in ipairs(toolsFolder:GetChildren()) do
		if tool:IsA("Model") then
			local colorPart = tool:FindFirstChild("Color", true)
			local color = colorPart and colorPart:IsA("BasePart") and colorPart.Color or Color3.fromRGB(245, 245, 245)
			return tool.Name, color
		end
	end
	return nil
end

function ensurePlayerEsp(targetPlayer)
	if targetPlayer == player then
		return
	end

	local targetCharacter = targetPlayer.Character
	local adornee = getAdornee(targetCharacter)
	if not targetCharacter or not adornee then
		return
	end

	local obj = esp.Players[targetPlayer]
	local baseColor = targetPlayer.TeamColor and targetPlayer.TeamColor.Color or Color3.fromRGB(120, 180, 255)
	local teamColor = state.PlayerZayMode and Color3.fromHSV((os.clock() * 0.18) % 1, 0.9, 1) or baseColor
	if not obj then
		local billboard, text, subText = createBillboard(targetPlayer.Name, teamColor, state.PlayerTextSize, true)
		local highlight = createHighlight(teamColor)
		local tracer = createTracer(teamColor)

		billboard.Parent = screenGui
		highlight.Parent = screenGui

		obj = {
			Billboard = billboard,
			Text = text,
			ToolText = subText,
			Highlight = highlight,
			Tracer = tracer,
			Character = targetCharacter,
		}
		esp.Players[targetPlayer] = obj
	end

	obj.Billboard.Adornee = adornee
	obj.Highlight.Adornee = targetCharacter
	obj.Billboard.Enabled = state.PlayerEsp and (state.PlayerNames or state.PlayerTools)
	obj.Highlight.Enabled = state.PlayerEsp and state.PlayerChams
	obj.Text.TextSize = state.PlayerTextSize
	obj.Text.TextColor3 = readableEspColor(teamColor)
	obj.Text.Visible = state.PlayerNames
	obj.Highlight.FillColor = teamColor
	obj.Highlight.OutlineColor = teamColor
	obj.Tracer.BackgroundColor3 = teamColor

