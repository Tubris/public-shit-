function setSeeRecipe(enabled, silent)
	state.SeeRecipe = enabled
	if not loadAutoHealModules() then
		if not silent then notify("See Recipe", "Crafting modules not ready.") end
		state.SeeRecipe = false
		return
	end

	if enabled then
		if not recipeView.TrueLevel then
			recipeView.TrueLevel = autoHeal.GameUtil.Data and autoHeal.GameUtil.Data.level or 0
		end
		local modules = S.ReplicatedStorage:FindFirstChild("Modules")
		local okIDs, itemIDs = pcall(require, modules and modules:FindFirstChild("ItemIDS"))
		local okData, itemData = pcall(require, modules and modules:FindFirstChild("ItemData"))
		local okCrafting, crafting = pcall(require, S.ReplicatedStorage:FindFirstChild("Game") and S.ReplicatedStorage.Game:FindFirstChild("crafting"))
		if not okIDs or not okData then
			if not silent then notify("See Recipe", "Recipe data not ready.") end
			state.SeeRecipe = false
			return
		end
		if not autoHeal.Packets.CraftItem or not autoHeal.Packets.CraftItem.send then
			if not silent then notify("See Recipe", "Craft packet not ready.") end
			state.SeeRecipe = false
			return
		end
		recipeView.ItemIDs = itemIDs
		recipeView.ItemData = itemData
		recipeView.Crafting = okCrafting and crafting or nil
		if not recipeView.OriginalCraftSend then
			recipeView.OriginalCraftSend = autoHeal.Packets.CraftItem.send
		end
		autoHeal.Packets.CraftItem.send = function(itemID)
			local itemName = recipeItemName(itemID)
			local itemInfo = recipeView.ItemData and recipeView.ItemData[itemName]
			local requiredLevel = itemInfo and itemInfo.craftLevel or 0
			if requiredLevel > (recipeView.TrueLevel or 0) then
				notify("Can't craft", string.format("Too low level. %s needs %d, you are %d.", itemName, requiredLevel, recipeView.TrueLevel or 0))
				return
			end
			notify("Crafting", string.format("%s level %d OK.", itemName, requiredLevel))
			recipeView.OriginalCraftSend(itemID)
		end
		autoHeal.GameUtil.Data.level = 100
		refreshCraftMenu(100)
		if not silent then notify("See Recipe", string.format("Showing recipes. True level: %d.", recipeView.TrueLevel or 0)) end
	else
		if recipeView.OriginalCraftSend and autoHeal.Packets and autoHeal.Packets.CraftItem then
			autoHeal.Packets.CraftItem.send = recipeView.OriginalCraftSend
		end
		if autoHeal.GameUtil and autoHeal.GameUtil.Data and recipeView.TrueLevel then
			autoHeal.GameUtil.Data.level = recipeView.TrueLevel
			refreshCraftMenu(recipeView.TrueLevel)
		end
		table.clear(recipeView)
		if not silent then notify("See Recipe", "Reverted to true level.") end
	end
end

