connect(S.UserInputService.InputBegan, function(input, gameProcessed)
	if awaitingKeybindFor and input.KeyCode ~= Enum.KeyCode.Unknown then
		if isTypingInTextBox() then
			return
		end
		state[awaitingKeybindFor] = input.KeyCode
		local changedKey = awaitingKeybindFor
		awaitingKeybindFor = nil
		updateKeybindText(changedKey)
		return
	end

	if isTypingInTextBox() then
		return
	end

	if input.KeyCode == state.ToggleKey then
		state.PanelVisible = not state.PanelVisible
		setCoreChatVisible(not state.PanelVisible)
		main.Visible = state.PanelVisible
		syncMinimizedEffects()
		closeDropdowns()
		return
	end

	if input.KeyCode == state.FreecamToggleKey then
		setFreecam(not state.Freecam)
		if freecamToggleRedraw then
			freecamToggleRedraw()
		end
		return
	end

	if gameProcessed then
		return
	end

	if input.KeyCode == state.AutoRunKey then
		state.AutoRun = not state.AutoRun
		return
	end

	if input.KeyCode == state.AutoPickupKey then
		state.AutoPickup = not state.AutoPickup
		if autoPickupToggleRedraw then
			autoPickupToggleRedraw()
		end
		notify("Auto Pickup", state.AutoPickup and "On" or "Off")
		return
	end

	if input.KeyCode == Enum.KeyCode.Escape then
		closeDropdowns()
		return
	end

	if input.KeyCode == Enum.KeyCode.W then
		if not state.Freecam then state.AutoRun = false end
		if not state.Freecam then movementKeys.Forward = true end
		freecam.Keys.Forward = true
	elseif input.KeyCode == Enum.KeyCode.S then
		if not state.Freecam then state.AutoRun = false end
		if not state.Freecam then movementKeys.Back = true end
		freecam.Keys.Back = true
	elseif input.KeyCode == Enum.KeyCode.A then
		if not state.Freecam then state.AutoRun = false end
		if not state.Freecam then movementKeys.Left = true end
		freecam.Keys.Left = true
	elseif input.KeyCode == Enum.KeyCode.D then
		if not state.Freecam then state.AutoRun = false end
		if not state.Freecam then movementKeys.Right = true end
		freecam.Keys.Right = true
	elseif input.KeyCode == Enum.KeyCode.Space then
		if not state.Freecam then movementKeys.Up = true end
		freecam.Keys.Up = true
	elseif input.KeyCode == Enum.KeyCode.LeftControl or input.KeyCode == Enum.KeyCode.C then
		if not state.Freecam then movementKeys.Down = true end
		freecam.Keys.Down = true
	elseif input.KeyCode == Enum.KeyCode.LeftShift or input.KeyCode == Enum.KeyCode.RightShift then
		freecam.Keys.Boost = true
	end
end)

connect(S.UserInputService.InputEnded, function(input)
	if input.KeyCode == Enum.KeyCode.W then
		movementKeys.Forward = false
		freecam.Keys.Forward = false
	elseif input.KeyCode == Enum.KeyCode.S then
		movementKeys.Back = false
		freecam.Keys.Back = false
	elseif input.KeyCode == Enum.KeyCode.A then
		movementKeys.Left = false
		freecam.Keys.Left = false
	elseif input.KeyCode == Enum.KeyCode.D then
		movementKeys.Right = false
		freecam.Keys.Right = false
	elseif input.KeyCode == Enum.KeyCode.Space then
		movementKeys.Up = false
		freecam.Keys.Up = false
	elseif input.KeyCode == Enum.KeyCode.LeftControl or input.KeyCode == Enum.KeyCode.C then
		movementKeys.Down = false
		freecam.Keys.Down = false
	elseif input.KeyCode == Enum.KeyCode.LeftShift or input.KeyCode == Enum.KeyCode.RightShift then
		freecam.Keys.Boost = false
	end
end)

