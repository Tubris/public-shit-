function corner(parent, radius)
	return make("UICorner", { CornerRadius = UDim.new(0, radius or 8) }, parent)
end

function stroke(parent, color, transparency, thickness)
	local outline = make("UIStroke", {
		Color = color or Color3.fromRGB(65, 72, 86),
		Transparency = transparency or 0.25,
		Thickness = thickness or 1,
	}, parent)
	if color and color.B > color.G and color.R >= color.G then
		themeRegister(outline, "Color", 0.5, 1)
	end
	return outline
end

function getCharacterParts()
	character = player.Character
	if not character then
		return nil, nil, nil
	end

	humanoid = character:FindFirstChildOfClass("Humanoid")
	rootPart = character:FindFirstChild("HumanoidRootPart")
	return character, humanoid, rootPart
end

function captureDefaultsFromHumanoid(currentHumanoid)
	if not currentHumanoid then
		return
	end
	if currentHumanoid.WalkSpeed and currentHumanoid.WalkSpeed > 0 then
		defaults.WalkSpeed = currentHumanoid.WalkSpeed
	end
	if currentHumanoid.UseJumpPower then
		defaults.UseJumpPower = true
		if currentHumanoid.JumpPower and currentHumanoid.JumpPower > 0 then
			defaults.JumpPower = currentHumanoid.JumpPower
		end
	else
		defaults.UseJumpPower = false
		if currentHumanoid.JumpHeight and currentHumanoid.JumpHeight > 0 then
			defaults.JumpHeight = currentHumanoid.JumpHeight
		end
	end
	if currentHumanoid.MaxSlopeAngle and currentHumanoid.MaxSlopeAngle > 0 then
		defaults.MaxSlopeAngle = currentHumanoid.MaxSlopeAngle
	end
end

function getAdornee(instance)
	if not instance or not instance.Parent then
		return nil
	end
	if instance:IsA("BasePart") then
		return instance
	end
	if instance:IsA("Model") then
		return instance:FindFirstChild("HumanoidRootPart")
			or instance.PrimaryPart
			or instance:FindFirstChildWhichIsA("BasePart", true)
	end
	return instance:FindFirstChildWhichIsA("BasePart", true)
end

function distanceFromLocal(part)
	local _, _, root = getCharacterParts()
	if not root or not part then
		return 0
	end
	return math.floor((root.Position - part.Position).Magnitude + 0.5)
end

function findPing()
	local ok, result = pcall(function()
		local performanceStats = S.Stats:FindFirstChild("PerformanceStats")
		if not performanceStats then
			return 0
		end

		local ping = performanceStats:FindFirstChild("Ping")
		if ping and ping.GetValue then
			return math.floor(ping:GetValue())
		end

		local dataPing = performanceStats:FindFirstChild("Data Ping")
		if dataPing and dataPing.GetValue then
			return math.floor(dataPing:GetValue())
		end

		return 0
	end)
	return ok and result or 0
end

