	return foodTypeNames
end

function collectInventoryNames()
	local names = {}
	if loadAutoHealModules() and autoHeal.GameUtil.Data and autoHeal.GameUtil.Data.inventory then
		for _, item in pairs(autoHeal.GameUtil.Data.inventory) do
			if item and item.name and item.quantity and item.quantity > 0 then
				names[item.name] = true
				if selections.AutoDrop[item.name] == nil then
					selections.AutoDrop[item.name] = false
				end
			end
		end
	end
	return sortedKeys(names)
end

