local function teleportToMouse()
    if not enabled then return end
    
    local mouse = localPlayer:GetMouse()
    if not mouse then return end
    
    local targetPos = mouse.Hit.Position
    local character = localPlayer.Character
    if not character then return end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if rootPart then
        rootPart.CFrame = CFrame.new(targetPos)
        if toggleButton then
            local originalColor = toggleButton.BackgroundColor3
            TweenService:create(toggleButton, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(0, 255, 0)}):play()
            task.wait(0.1)
            TweenService:create(toggleButton, TweenInfo.new(0.1), {BackgroundColor3 = originalColor}):play()
        end
    end
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if waitingForKeybind then
        if input.KeyCode ~= Enum.KeyCode.Unknown then
            currentKeybind = input.KeyCode
            waitingForKeybind = false
            if keybindButton then
                keybindButton.Text = "Keybind: " .. getKeyName(currentKeybind)
                keybindButton.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
            end
        end
        return
    end
    
    if currentKeybind and input.KeyCode == currentKeybind then
        enabled = not enabled
        updateButtonColor()
    end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if not enabled then return end
    
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        if mainFrame and mainFrame.Parent then
            local mousePos = input.Position
            local absPos = mainFrame.AbsolutePosition
            local absSize = mainFrame.AbsoluteSize
            local isOverGui = mousePos.X >= absPos.X and mousePos.X <= absPos.X + absSize.X
                and mousePos.Y >= absPos.Y and mousePos.Y <= absPos.Y + absSize.Y
            if isOverGui then return end
        end
        teleportToMouse()
    end
end)

