local function updateButtonColor()
    if not toggleButton then return end
    if enabled then
        toggleButton.Text = "CLICK TP: ON"
        toggleButton.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    else
        toggleButton.Text = "CLICK TP: OFF"
        toggleButton.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
    end
end

local function getKeyName(key)
    if not key then return "None"
    elseif key == Enum.KeyCode.LeftControl then return "LCtrl"
    elseif key == Enum.KeyCode.RightControl then return "RCtrl"
    elseif key == Enum.KeyCode.LeftShift then return "LShift"
    elseif key == Enum.KeyCode.RightShift then return "RShift"
    elseif key == Enum.KeyCode.LeftAlt then return "LAlt"
    elseif key == Enum.KeyCode.RightAlt then return "RAlt"
    else return tostring(key.Name) end
end

