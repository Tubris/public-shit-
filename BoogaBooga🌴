	end
	if state.PlayerDistance then
		text ..= string.format(" [%dm]", distanceFromLocal(adornee))
	end
	obj.Text.Text = text

	drawTracer(obj.Tracer, adornee.Position, state.PlayerEsp and state.PlayerTracers)
end

local function hasAnyTag(instance, tags)
	for _, tag in ipairs(tags) do
		if CollectionService:HasTag(instance, tag) then
			return true
		end
	end
	return false
end

local function isInsideFolderNamed(instance, names)
	local current = instance.Parent
	while current and current ~= workspace do
		for _, folderName in ipairs(names) do
			if string.lower(current.Name) == string.lower(folderName) then
				return true
			end
		end
		current = current.Parent
	end
	return false
end

local function hasKeyword(instance, keywords)
	local lowerName = string.lower(instance.Name)
	for _, keyword in ipairs(keywords) do
		if string.find(lowerName, keyword, 1, true) then
			return true
		end
	end
	return false
end

local function endsWith(text, suffix)
	return string.sub(text, -#suffix) == suffix
end

local function shouldIncludeDropped(instance)
	local cleanName = instance.Name:gsub("%s*%b()$", "")
	if droppedSelections[cleanName] ~= nil then
		return droppedSelections[cleanName]
	end
	return not filteredDroppedItems[cleanName]
end

local function shouldIncludeEntity(instance)
	local lowerName = string.lower(instance.Name)
	if instance.Name == "Part" then
		return false
	end
	if string.find(lowerName, "god", 1, true) then
		return false
	end
	if string.find(lowerName, "tree", 1, true)
		or string.find(lowerName, "rock", 1, true)
		or string.find(lowerName, "wood", 1, true) then
		return false
	end
	return true
end

local function isTreasureChest(instance)
	local normalized = string.lower(instance.Name):gsub("%s+", "")
	return normalized == "treasurechest"
end

local function isMeteorCore(instance)
	return instance:IsA("Model") and instance.Name == "Meteor Core"
end

local function isRainbowEvent(instance)
	return isTreasureChest(instance)
end

local function rainbowColor(speed)
	return Color3.fromHSV((os.clock() * (speed or 0.08)) % 1, 0.85, 1)
end

local function getMeteorColor(instance)
	local smallRock = instance:FindFirstChild("Small Rock", true)
	if smallRock and smallRock:IsA("BasePart") then
		return smallRock.Color
	end
	local adornee = getAdornee(instance)
	return adornee and adornee.Color or worldRules.Event.color
end

local function getEventColor(instance)
	if isMeteorCore(instance) then
		return getMeteorColor(instance)
	end
	return worldRules.Event.color
end

local function getEventLabel(instance)
	if isTreasureChest(instance) then
		return "Treasure Chest"
	end
	return instance.Name
end

local function getGodRoot()
	local resources = workspace:FindFirstChild("Resources")
	return resources and resources:FindFirstChild("Ancient God")
end

local function isGodInstance(instance)
	local hasGodName = string.find(string.lower(instance.Name), "god", 1, true) ~= nil
	return hasGodName and getAdornee(instance) ~= nil
end

local function getGodColor(instance)
	local eyes = instance:FindFirstChild("Eyes", true)
	if eyes and eyes:IsA("BasePart") then
		return eyes.Color
	end
	local parent = instance.Parent
	while parent and parent ~= workspace do
		eyes = parent:FindFirstChild("Eyes", true)
		if eyes and eyes:IsA("BasePart") then
			return eyes.Color
		end
		parent = parent.Parent
	end
	return worldRules.God.color
end

local function getFolder(name)
	return workspace:FindFirstChild(name)
end

local function isInWorkspaceFolder(instance, folderName)
	local folder = getFolder(folderName)
	return folder and (instance == folder or instance:IsDescendantOf(folder))
end

local function folderObject(instance, folderName)
	local folder = getFolder(folderName)
	if not folder or instance == folder or not instance:IsDescendantOf(folder) then
		return nil
	end

	local current = instance
	while current.Parent and current.Parent ~= folder do
		current = current.Parent
	end
	return current.Parent == folder and current or nil
end

local function isTopFolderObject(instance, folderName)
	return folderObject(instance, folderName) == instance
end

local function isPortalInstance(instance)
	return isTopFolderObject(instance, "Portals")
end

local function isAntHillInstance(instance)
	return isTopFolderObject(instance, "Mounds")
end

local function isTotemInstance(instance)
	return isTopFolderObject(instance, "Totems")
end

local function colorFromValue(valueObject, fallback)
	if not valueObject then
		return fallback
	end
	local value = valueObject.Value
	if typeof(value) == "Color3" then
		return value
	end
	if typeof(value) == "BrickColor" then
		return value.Color
	end
	if typeof(value) == "string" then
		local ok, brickColor = pcall(BrickColor.new, value)
		if ok then
			return brickColor.Color
		end
	end
	return fallback
end

local function getTotemColor(instance)
	local tribeColor = instance:FindFirstChild("TribeColor", true)
	return colorFromValue(tribeColor, worldRules.Totem.color)
end

function readNumberValue(valueObject)
	if not valueObject then
		return nil
	end
	if valueObject:IsA("Humanoid") then
		return valueObject.Health
	end
	local ok, value = pcall(function()
		return valueObject.Value
	end)
	if ok and typeof(value) == "number" then
		return value
	end
	return nil
end

local function getTotemHealth(instance)
	return readNumberValue(instance:FindFirstChild("Health", true))
end

function selectionName(instance)
	return instance.Name:gsub("%s*%b()$", "")
end

local function canBeWorldCandidate(instance)
	if not instance:IsA("Model") and not instance:IsA("BasePart") then
		return false
	end
	if character and instance:IsDescendantOf(character) then
		return false
	end

	local potential =
		endsWith(instance.Name, "Node")
		or shouldIncludeEntity(instance) and (
			hasAnyTag(instance, worldRules.Entity.tags)
			or isInsideFolderNamed(instance, worldRules.Entity.folders)
			or hasKeyword(instance, worldRules.Entity.keywords)
		)
		or isTreasureChest(instance)
		or isMeteorCore(instance)
		or isGodInstance(instance)
		or isPortalInstance(instance)
		or isAntHillInstance(instance)
		or isTotemInstance(instance)
		or (
			hasAnyTag(instance, worldRules.Dropped.tags)
			or isInsideFolderNamed(instance, worldRules.Dropped.folders)
		)
	if not potential then
		return false
	end

	return getAdornee(instance) ~= nil
end

local function trackWorldCandidate(instance)
	if canBeWorldCandidate(instance) then
		worldCandidates[instance] = true
	end
end

local function untrackWorldCandidate(instance)
	worldCandidates[instance] = nil
	if worldEsp[instance] then
		if worldEsp[instance].Billboard then worldEsp[instance].Billboard:Destroy() end
		if worldEsp[instance].Highlight then worldEsp[instance].Highlight:Destroy() end
		if worldEsp[instance].Tracer then worldEsp[instance].Tracer:Destroy() end
		worldEsp[instance] = nil
	end
end

local function matchesWorldRule(instance, ruleName)
	local rule = worldRules[ruleName]
	if not rule then
		return false
	end

	if ruleName == "Ore" then
		local name = selectionName(instance)
		return endsWith(instance.Name, "Node") and oreSelections[name] ~= false
	end

	if ruleName == "Entity" and not shouldIncludeEntity(instance) then
		return false
	end

	if ruleName == "Entity" then
		local name = selectionName(instance)
		if entitySelections[name] ~= true then
			return false
		end
	end

	if ruleName == "Event" then
		return isTreasureChest(instance) or isMeteorCore(instance)
	end

	if ruleName == "God" then
		return isGodInstance(instance)
	end

	if ruleName == "Portal" then
		return isPortalInstance(instance) and portalSelections[selectionName(instance)] ~= false
	end

	if ruleName == "AntHill" then
		return isAntHillInstance(instance)
	end

	if ruleName == "Totem" then
		return isTotemInstance(instance)
	end

	if ruleName == "Dropped" and not shouldIncludeDropped(instance) then
		return false
	end

	if ruleName == "Dropped" then
		return hasAnyTag(instance, rule.tags) or isInsideFolderNamed(instance, rule.folders)
	end

	return hasAnyTag(instance, rule.tags)
		or isInsideFolderNamed(instance, rule.folders)
		or hasKeyword(instance, rule.keywords)
end

local function getWorldCandidates()
	local candidates = {}

	for instance in pairs(worldCandidates) do
		if instance.Parent and canBeWorldCandidate(instance) then
			table.insert(candidates, instance)
		else
			worldCandidates[instance] = nil
		end
	end

	return candidates
end

local function ensureWorldEsp(instance, ruleName)
	local adornee = getAdornee(instance)
	if not adornee then
		return
	end

	local rule = worldRules[ruleName]
	local color = ruleName == "Dropped" and adornee.Color
		or ruleName == "Portal" and adornee.Color
		or ruleName == "AntHill" and adornee.Color
		or ruleName == "Totem" and getTotemColor(instance)
		or ruleName == "God" and getGodColor(instance)
		or ruleName == "Event" and getEventColor(instance)
		or rule.color
	local obj = worldEsp[instance]
	if not obj then
		local billboard, text = createBillboard(instance.Name, color, state.WorldTextSize)
		local highlight = createHighlight(color)
		local tracer = createTracer(color)
		billboard.Parent = screenGui
		highlight.Parent = screenGui

		obj = {
			Instance = instance,
			RuleName = ruleName,
			Billboard = billboard,
			Text = text,
			Highlight = highlight,
			Tracer = tracer,
		}
		worldEsp[instance] = obj
	end

	obj.Billboard.Adornee = adornee
	obj.Highlight.Adornee = instance:IsA("Model") and instance or adornee
	obj.Billboard.Enabled = state.WorldNames
	obj.Highlight.Enabled = state.WorldChams
	obj.Highlight.FillColor = color
	obj.Highlight.OutlineColor = color
	obj.Tracer.BackgroundColor3 = color
	obj.Text.TextSize = state.WorldTextSize
	obj.Text.TextColor3 = ruleName == "Event" and isRainbowEvent(instance) and rainbowColor(0.08) or color

	local label = ruleName == "Event" and getEventLabel(instance) or instance.Name
	if ruleName == "Totem" then
		local health = getTotemHealth(instance)
		if health then
			label ..= string.format(" [%d HP]", math.floor(health + 0.5))
		end
	end
	if state.WorldDistance then
		label ..= string.format(" [%dm]", distanceFromLocal(adornee))
	end
	obj.Text.Text = label

	drawTracer(obj.Tracer, adornee.Position, state.WorldTracers)
end

local perf

function updateWorldEsp()
	local scanStarted = os.clock()
	local enabledRules = {
		{ "God", state.GodEsp },
		{ "Portal", state.PortalEsp },
		{ "AntHill", state.AntHillEsp },
		{ "Totem", state.TotemEsp },
		{ "Ore", state.OreEsp },
		{ "Entity", state.EntityEsp },
		{ "Event", state.EventEsp },
		{ "Dropped", state.DroppedEsp },
	}

	local anyEnabled = false
	for _, ruleInfo in ipairs(enabledRules) do
		anyEnabled = anyEnabled or ruleInfo[2]
	end

	if not anyEnabled then
		clearEsp(worldEsp)
		return
	end

	local active = {}
	local activeCount = 0
	local ruleCounts = {}
	local objectLimit = state.WorldMaxObjects
	local droppedLimit = state.DroppedMaxObjects
	if state.PerformanceGuard then
		if perf.AverageFps > 0 and perf.AverageFps < 30 then
			objectLimit = math.min(objectLimit, 35)
			droppedLimit = math.min(droppedLimit, 15)
		elseif perf.AverageFps > 0 and perf.AverageFps < 45 then
			objectLimit = math.min(objectLimit, 60)
			droppedLimit = math.min(droppedLimit, 25)
		end
	end
	for _, instance in ipairs(getWorldCandidates()) do
		if activeCount >= objectLimit then
			break
		end
		for _, ruleInfo in ipairs(enabledRules) do
			local ruleName, enabled = ruleInfo[1], ruleInfo[2]
			if enabled and matchesWorldRule(instance, ruleName) then
				if ruleName == "Dropped" and (ruleCounts.Dropped or 0) >= droppedLimit then
					break
				end
				active[instance] = true
				ensureWorldEsp(instance, ruleName)
				activeCount += 1
				ruleCounts[ruleName] = (ruleCounts[ruleName] or 0) + 1
				break
			end
		end
	end

	for instance, obj in pairs(worldEsp) do
		if not active[instance] or not obj.Instance.Parent then
			if obj.Billboard then obj.Billboard:Destroy() end
			if obj.Highlight then obj.Highlight:Destroy() end
			if obj.Tracer then obj.Tracer:Destroy() end
			worldEsp[instance] = nil
		end
	end
	if state.PerformanceGuard then
		perf.WorldEspCost = os.clock() - scanStarted
		if perf.WorldEspCost > 0.08 then
			perf.WorldCooldown = math.min(8, state.WorldRefreshTime + perf.WorldEspCost * 18)
		elseif perf.WorldCooldown > state.WorldRefreshTime then
			perf.WorldCooldown = math.max(state.WorldRefreshTime, perf.WorldCooldown - 0.25)
		end
	end
end

perf = {
	AverageFps = 60,
	WorldCooldown = 3.5,
	WorldEspCost = 0,
}
local worldScanTimer = 0
local worldLabelTimer = 0
local fpsCounter = 0
local fpsClock = os.clock()
local fpsHistory = {}
local pingHistory = {}

local function updateStats()
	if not state.Stats then
		statsBar.Visible = false
		return
	end
	statsBar.Visible = true

	fpsCounter += 1
	local now = os.clock()
	if now - fpsClock < 0.5 then
		return
	end

	local fps = math.floor(fpsCounter / (now - fpsClock) + 0.5)
	fpsCounter = 0
	fpsClock = now

	table.insert(fpsHistory, fps)
	if #fpsHistory > 8 then table.remove(fpsHistory, 1) end
	local avgFps = 0
	for _, v in ipairs(fpsHistory) do avgFps += v end
	avgFps = math.floor(avgFps / #fpsHistory + 0.5)
	perf.AverageFps = avgFps

	local ping = findPing()
	table.insert(pingHistory, ping)
	if #pingHistory > 8 then table.remove(pingHistory, 1) end
	local avgPing = 0
	for _, v in ipairs(pingHistory) do avgPing += v end
	avgPing = math.floor(avgPing / #pingHistory + 0.5)

	fpsLabel.Text = "FPS " .. avgFps
	playersLabel.Text = string.format("PLR %d/%d", #Players:GetPlayers(), Players.MaxPlayers)
	pingLabel.Text = "PING " .. avgPing

	fpsLabel.TextColor3 = avgFps >= 55 and Color3.fromRGB(128, 255, 168)
		or avgFps >= 30 and Color3.fromRGB(255, 218, 115)
		or Color3.fromRGB(255, 130, 130)
	pingLabel.TextColor3 = avgPing <= 60 and Color3.fromRGB(128, 255, 168)
		or avgPing <= 120 and Color3.fromRGB(255, 218, 115)
		or Color3.fromRGB(255, 130, 130)
end

local function sortedKeys(set)
	local names = {}
	for name in pairs(set) do
		table.insert(names, name)
	end
	table.sort(names)
	return names
end

local function collectOreNames()
	local names = {}
	for instance in pairs(worldCandidates) do
		if instance.Parent and endsWith(instance.Name, "Node") then
			names[selectionName(instance)] = true
		end
	end
	for _, descendant in ipairs(workspace:GetDescendants()) do
		if endsWith(descendant.Name, "Node") then
			names[selectionName(descendant)] = true
		end
	end
	return sortedKeys(names)
end

local function collectEntityNames()
	local names = {}
	local function maybeAdd(instance)
		if shouldIncludeEntity(instance)
			and (
				hasAnyTag(instance, worldRules.Entity.tags)
				or isInsideFolderNamed(instance, worldRules.Entity.folders)
				or hasKeyword(instance, worldRules.Entity.keywords)
			) then
			names[selectionName(instance)] = true
		end
	end
	for instance in pairs(worldCandidates) do
		if instance.Parent then
			maybeAdd(instance)
		end
	end
	for _, descendant in ipairs(workspace:GetDescendants()) do
		if descendant:IsA("Model") or descendant:IsA("BasePart") then
			maybeAdd(descendant)
		end
	end
	return sortedKeys(names)
end

local function collectPortalNames()
	local names = {}
	local portals = workspace:FindFirstChild("Portals")
	if portals then
		for _, child in ipairs(portals:GetChildren()) do
			if (child:IsA("Model") or child:IsA("BasePart")) and getAdornee(child) then
				names[selectionName(child)] = true
			end
		end
	end
	return sortedKeys(names)
end

local function collectDroppedNames()
	local names = {}
	local function maybeAdd(instance)
		if (instance:IsA("Model") or instance:IsA("BasePart"))
			and (hasAnyTag(instance, worldRules.Dropped.tags) or isInsideFolderNamed(instance, worldRules.Dropped.folders)) then
			names[selectionName(instance)] = true
		end
	end
	for instance in pairs(worldCandidates) do
		if instance.Parent then
			maybeAdd(instance)
		end
	end
	for _, descendant in ipairs(workspace:GetDescendants()) do
		maybeAdd(descendant)
	end
	return sortedKeys(names)
end

