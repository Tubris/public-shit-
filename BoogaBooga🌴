local function saveProperties(instance, properties)
	if not instance or fullbrightOriginalInstances[instance] then
		return
	end

	local snapshot = {}
	for _, property in ipairs(properties) do
		pcall(function()
			snapshot[property] = instance[property]
		end)
	end
	fullbrightOriginalInstances[instance] = snapshot
end

local function applyFullbrightToInstance(instance)
	if instance:IsA("Atmosphere") then
		saveProperties(instance, { "Density", "Offset", "Glare", "Haze", "Color", "Decay" })
		instance.Density = 0
		instance.Offset = 0
		instance.Glare = 0
		instance.Haze = 0
	elseif instance:IsA("BloomEffect") or instance:IsA("BlurEffect") or instance:IsA("SunRaysEffect") or instance:IsA("DepthOfFieldEffect") then
		saveProperties(instance, { "Enabled" })
		instance.Enabled = false
	elseif instance:IsA("ColorCorrectionEffect") then
		saveProperties(instance, { "Enabled", "Brightness", "Contrast", "Saturation", "TintColor" })
		instance.Enabled = false
	elseif instance:IsA("Clouds") then
		saveProperties(instance, { "Cover", "Density", "Color" })
		instance.Cover = 0
		instance.Density = 0
	end
end

local function applyFullbright()
	if not fullbrightOriginalLighting then
		fullbrightOriginalLighting = {}
		for _, property in ipairs({
			"Ambient",
			"OutdoorAmbient",
			"Brightness",
			"ClockTime",
			"FogStart",
			"FogEnd",
			"FogColor",
			"GlobalShadows",
			"ExposureCompensation",
			"EnvironmentDiffuseScale",
			"EnvironmentSpecularScale",
			"ShadowSoftness",
		}) do
			pcall(function()
				fullbrightOriginalLighting[property] = Lighting[property]
			end)
		end
	end

	Lighting.Ambient = Color3.fromRGB(255, 255, 255)
	Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
	Lighting.Brightness = 3
	Lighting.ClockTime = 14
	Lighting.FogStart = 0
	Lighting.FogEnd = 1000000
	Lighting.FogColor = Color3.fromRGB(255, 255, 255)
	Lighting.GlobalShadows = false
	pcall(function() Lighting.ExposureCompensation = 0.25 end)
	pcall(function() Lighting.EnvironmentDiffuseScale = 1 end)
	pcall(function() Lighting.EnvironmentSpecularScale = 0 end)
	pcall(function() Lighting.ShadowSoftness = 0 end)

	for _, descendant in ipairs(Lighting:GetDescendants()) do
		applyFullbrightToInstance(descendant)
	end
end

local function restoreFullbright()
	if fullbrightOriginalLighting then
		for property, value in pairs(fullbrightOriginalLighting) do
			pcall(function()
				Lighting[property] = value
			end)
		end
		fullbrightOriginalLighting = nil
	end

	for instance, snapshot in pairs(fullbrightOriginalInstances) do
		if instance and instance.Parent then
			for property, value in pairs(snapshot) do
				pcall(function()
					instance[property] = value
				end)
			end
		end
	end
	table.clear(fullbrightOriginalInstances)
end

local function setFullbright(enabled)
	state.Fullbright = enabled
