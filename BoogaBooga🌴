end

local function createTracer(color)
	local frame = make("Frame", {
		Name = "ControlPanelTracer",
		AnchorPoint = Vector2.new(0.5, 0.5),
		BackgroundColor3 = color,
		BorderSizePixel = 0,
		Visible = false,
		ZIndex = 50,
	}, screenGui)
	return frame
end

local function drawTracer(frame, worldPosition, enabled)
	if not enabled or not frame or not camera then
		if frame then
			frame.Visible = false
		end
		return
	end

	local point, visible = camera:WorldToViewportPoint(worldPosition)
	if not visible or point.Z <= 0 then
		frame.Visible = false
		return
	end

	local start = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y - 18)
	local finish = Vector2.new(point.X, point.Y)
	local diff = finish - start
	local length = diff.Magnitude
	if length < 4 then
		frame.Visible = false
		return
	end

	frame.Size = UDim2.new(0, length, 0, 2)
	frame.Position = UDim2.fromOffset((start.X + finish.X) / 2, (start.Y + finish.Y) / 2)
	frame.Rotation = math.deg(math.atan2(diff.Y, diff.X))
	frame.Visible = true
end

local function clearEsp(bucket)
	for key, obj in pairs(bucket) do
		if obj.Billboard then obj.Billboard:Destroy() end
		if obj.Highlight then obj.Highlight:Destroy() end
		if obj.Tracer then obj.Tracer:Destroy() end
		bucket[key] = nil
	end
end

