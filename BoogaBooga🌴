local function setFreecam(enabled)
	state.Freecam = enabled
	camera = workspace.CurrentCamera
	local _, hum, root = getCharacterParts()

	if enabled then
		if not camera then
			return
		end
		freecamOriginal.CameraType = camera.CameraType
		freecamOriginal.CameraSubject = camera.CameraSubject
		freecamOriginal.MouseBehavior = UserInputService.MouseBehavior
		freecamOriginal.MouseIconEnabled = UserInputService.MouseIconEnabled
		if hum then
			freecamOriginal.WalkSpeed = hum.WalkSpeed
			freecamOriginal.JumpPower = hum.JumpPower
			freecamOriginal.JumpHeight = hum.JumpHeight
			freecamOriginal.AutoRotate = hum.AutoRotate
			hum.WalkSpeed = 0
			hum.JumpPower = 0
			hum.JumpHeight = 0
			hum.AutoRotate = false
		end
		if root then
			freecamOriginal.RootAnchored = root.Anchored
			root.Anchored = true
			root.AssemblyLinearVelocity = Vector3.zero
		end
		freecamCFrame = camera.CFrame
		local look = freecamCFrame.LookVector
		freecamYaw = math.atan2(-look.X, -look.Z)
		freecamPitch = math.asin(math.clamp(look.Y, -1, 1))
		camera.CameraType = Enum.CameraType.Scriptable
		UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
		UserInputService.MouseIconEnabled = false
		notify("Freecam On", "Scroll to change speed. Shift boosts 5x. Press " .. keyName(state.FreecamToggleKey) .. " to exit.")
	else
		if camera then
			camera.CameraType = freecamOriginal.CameraType or Enum.CameraType.Custom
			camera.CameraSubject = freecamOriginal.CameraSubject or hum
		end
		if hum then
			hum.WalkSpeed = freecamOriginal.WalkSpeed or defaults.WalkSpeed
			hum.JumpPower = freecamOriginal.JumpPower or defaults.JumpPower
			hum.JumpHeight = freecamOriginal.JumpHeight or defaults.JumpHeight
			hum.AutoRotate = freecamOriginal.AutoRotate ~= false
		end
		if root then
			root.Anchored = freecamOriginal.RootAnchored == true
		end
		UserInputService.MouseBehavior = freecamOriginal.MouseBehavior or Enum.MouseBehavior.Default
		UserInputService.MouseIconEnabled = freecamOriginal.MouseIconEnabled ~= false
		table.clear(freecamOriginal)
	end
end

local function updateFreecam(dt)
	if not state.Freecam then
		return
	end
	camera = workspace.CurrentCamera
	if not camera then
		return
	end
	if not freecamCFrame then
		freecamCFrame = camera.CFrame
	end

	local rotation = CFrame.fromOrientation(freecamPitch, freecamYaw, 0)
	local move = Vector3.zero
	if freecamKeys.Forward then move += rotation.LookVector end
	if freecamKeys.Back then move -= rotation.LookVector end
	if freecamKeys.Right then move += rotation.RightVector end
	if freecamKeys.Left then move -= rotation.RightVector end
	if freecamKeys.Up then move += Vector3.yAxis end
	if freecamKeys.Down then move -= Vector3.yAxis end

	local speed = state.FreecamSpeed * (freecamKeys.Boost and 5 or 1)
	if move.Magnitude > 0 then
		freecamCFrame = freecamCFrame + move.Unit * speed * dt
	end
	freecamCFrame = CFrame.new(freecamCFrame.Position) * rotation
	camera.CFrame = freecamCFrame

	local _, hum, root = getCharacterParts()
	if hum then
		hum.WalkSpeed = 0
		hum.JumpPower = 0
		hum.JumpHeight = 0
		hum.AutoRotate = false
	end
	if root then
		root.Anchored = true
		root.AssemblyLinearVelocity = Vector3.zero
	end
end

local function setFly(enabled)
	state.Fly = enabled
	if enabled then
		startFly()
	else
		stopFly()
	end
end

local function updateFly()
	if not state.Fly then
		return
	end

	local _, hum, root = getCharacterParts()
	if not hum or not root then
		return
	end

	if not flyVelocity or not flyGyro or flyVelocity.Parent ~= root then
		startFly()
	end

	local move = Vector3.zero
	local cf = camera.CFrame
	if movementKeys.Forward or state.AutoRun then move += cf.LookVector end
	if movementKeys.Back then move -= cf.LookVector end
	if movementKeys.Right then move += cf.RightVector end
	if movementKeys.Left then move -= cf.RightVector end
	if movementKeys.Up then move += Vector3.yAxis end
	if movementKeys.Down then move -= Vector3.yAxis end

	if move.Magnitude > 0 then
		move = move.Unit * state.FlySpeed
	end

	flyVelocity.Velocity = move
	flyGyro.CFrame = cf
	hum.PlatformStand = true
end

local function restoreNoclip()
	for part, canCollide in pairs(noclipOriginals) do
		if part and part.Parent then
			part.CanCollide = canCollide
		end
	end
	for part, collisionGroup in pairs(noclipCollisionGroups) do
		if part and part.Parent then
			pcall(function()
				part.CollisionGroup = collisionGroup
			end)
		end
	end
	if noclipTerrainGroup then
		pcall(function()
			workspace.Terrain.CollisionGroup = noclipTerrainGroup
		end)
	end
	table.clear(noclipOriginals)
	table.clear(noclipCollisionGroups)
	noclipTerrainGroup = nil
end

local function updateNoclip(dt)
	if not state.Noclip then
		return
	end

	local currentCharacter, hum, root = getCharacterParts()
	if not currentCharacter or not root then
		return
	end

	for _, descendant in ipairs(currentCharacter:GetDescendants()) do
		if descendant:IsA("BasePart") then
			if noclipOriginals[descendant] == nil then
				noclipOriginals[descendant] = descendant.CanCollide
			end
			if noclipCollisionGroups[descendant] == nil then
				noclipCollisionGroups[descendant] = descendant.CollisionGroup
			end
			descendant.CanCollide = false
			pcall(function()
				descendant.CollisionGroup = noclipGroupName
			end)
		end
	end

	pcall(function()
		if not noclipTerrainGroup then
			noclipTerrainGroup = workspace.Terrain.CollisionGroup
		end
		workspace.Terrain.CollisionGroup = noclipGroupName
	end)

	if state.Fly then
		return
	end

	local move = Vector3.zero
	local cf = camera and camera.CFrame or root.CFrame
	if movementKeys.Forward or state.AutoRun then move += cf.LookVector end
	if movementKeys.Back then move -= cf.LookVector end
	if movementKeys.Right then move += cf.RightVector end
	if movementKeys.Left then move -= cf.RightVector end
	if movementKeys.Up then move += Vector3.yAxis end
	if movementKeys.Down then move -= Vector3.yAxis end

	if move.Magnitude > 0 then
		local speed = state.WalkSpeedEnabled and state.WalkSpeed or (hum and hum.WalkSpeed or defaults.WalkSpeed)
		root.CFrame = root.CFrame + (move.Unit * math.max(speed, 18) * dt)
		root.AssemblyLinearVelocity = Vector3.zero
	end
end

local function updateAutoRun()
	if not state.AutoRun or state.Freecam or state.Fly or state.Noclip then
		return
	end

	local _, hum = getCharacterParts()
	if not hum or not camera then
		return
	end

	local forward = camera.CFrame.LookVector
	local flatForward = Vector3.new(forward.X, 0, forward.Z)
	if flatForward.Magnitude > 0 then
		hum:Move(flatForward.Unit, false)
	end
end

local autoAttackClock = 0
local virtualUser = game:GetService("VirtualUser")

local function fireToolAttackSignals(tool)
	local fired = false
	local attackNames = {
		attack = true,
		hit = true,
		swing = true,
		slash = true,
		punch = true,
		use = true,
		fire = true,
		activate = true,
		activated = true,
	}

	for _, descendant in ipairs(tool:GetDescendants()) do
		local lowerName = string.lower(descendant.Name)
		local looksLikeAttack = attackNames[lowerName]
			or string.find(lowerName, "attack", 1, true)
			or string.find(lowerName, "hit", 1, true)
			or string.find(lowerName, "swing", 1, true)
			or string.find(lowerName, "slash", 1, true)
		if looksLikeAttack then
			if descendant:IsA("BindableEvent") then
				fired = true
				pcall(function()
					descendant:Fire()
				end)
			elseif descendant:IsA("RemoteEvent") then
				fired = true
				pcall(function()
					descendant:FireServer()
				end)
			end
		end
	end

	return fired
end

local function updateAutoAttack()
	if not state.AutoAttack then
		return
	end

	local now = os.clock()
	if now - autoAttackClock < state.AutoAttackInterval then
		return
	end
	autoAttackClock = now

	local currentCharacter, hum = getCharacterParts()
	if not currentCharacter or not hum then
		return
	end

	local tool = currentCharacter:FindFirstChildOfClass("Tool")
	if not tool then
		local backpack = player:FindFirstChildOfClass("Backpack")
		tool = backpack and backpack:FindFirstChildOfClass("Tool")
		if tool then
			pcall(function()
				hum:EquipTool(tool)
			end)
		end
	end

	if tool then
		pcall(function()
			tool.Enabled = true
		end)
		pcall(function()
			tool:Activate()
		end)
		fireToolAttackSignals(tool)
		pcall(function()
			tool:Deactivate()
		end)
	end

	pcall(function()
		local viewport = camera and camera.ViewportSize or Vector2.new(800, 600)
		local point = Vector2.new(viewport.X / 2, viewport.Y / 2)
		local clickCFrame = camera and camera.CFrame or CFrame.new()
		virtualUser:Button1Down(point, clickCFrame)
		task.wait()
		virtualUser:Button1Up(point, clickCFrame)
	end)
end

