local function activateTab(name)
	closeDropdowns()
	for tabName, page in pairs(pages) do
		page.Visible = tabName == name
	end
	for tabName, button in pairs(tabButtons) do
		local selected = tabName == name
		tween(button, nil, {
			BackgroundColor3 = selected and Color3.fromRGB(124, 86, 210) or Color3.fromRGB(20, 16, 34),
			BackgroundTransparency = selected and 0 or 0.1,
			TextColor3 = selected and Color3.fromRGB(255, 250, 255) or Color3.fromRGB(165, 150, 190),
		})
	end
end

