local function connect(signal, fn)
	local c = signal:Connect(fn)
	table.insert(connections, c)
	return c
end

local function playDeathSound()
	local boolet = ReplicatedStorage:FindFirstChild("BOOLET")
	local boom = boolet and boolet:FindFirstChild("boom")
	if not boom or not boom:IsA("Sound") then
		boom = Instance.new("Sound")
		boom.Name = "boom"
		boom.SoundId = "rbxassetid://5178876770"
		boom.Volume = 1
		boom.Parent = boolet or ReplicatedStorage
	elseif boom.SoundId == "" then
		boom.SoundId = "rbxassetid://5178876770"
	end
	boom:Play()
end

local function watchLocalDeath(currentHumanoid)
	if deathSoundConnection then
		deathSoundConnection:Disconnect()
		deathSoundConnection = nil
	end

	local played = false
	deathSoundConnection = currentHumanoid.HealthChanged:Connect(function(health)
		if health <= 0 and not played then
			played = true
			playDeathSound()
		elseif health > 0 then
			played = false
		end
	end)
	table.insert(connections, deathSoundConnection)
end
watchLocalDeath(humanoid)

local function tween(obj, info, props)
	TweenService:Create(obj, info or TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end

local function make(className, props, parent)
	local obj = Instance.new(className)
	for k, v in pairs(props or {}) do
		obj[k] = v
	end
	obj.Parent = parent
	return obj
end

