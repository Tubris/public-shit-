local function numberFromValueObject(valueObject)
	if not valueObject then
		return nil
	end

	local ok, value = pcall(function()
		return valueObject.Value
	end)
	if ok then
		if typeof(value) == "number" then
			return value
		elseif typeof(value) == "string" then
			return tonumber(value)
		end
	end

	return nil
end

local function readPlaceIdValue(container, names)
	if not container then
		return nil
	end
	for _, name in ipairs(names) do
		local attr = container:GetAttribute(name)
		if typeof(attr) == "number" then
			return attr
		elseif typeof(attr) == "string" then
			local numeric = tonumber(attr)
			if numeric then
				return numeric
			end
		end

		local valueObject = container:FindFirstChild(name, true)
		if valueObject then
			local directValue = numberFromValueObject(valueObject)
			if directValue then
				return directValue
			end

			local placeId = readPlaceIdValue(valueObject, { "PlaceId", "PlaceID", "placeId", "DestinationPlaceId", "Destination" })
			if placeId then
				return placeId
			end
		end
	end
	return nil
end

