local function getServerList(placeId, cursor)
	local url = string.format(
		"https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100%s",
		placeId,
		cursor and ("&cursor=" .. HttpService:UrlEncode(cursor)) or ""
	)

	local body
	local requestFn = syn and syn.request or http_request or request
	if requestFn then
		local response = requestFn({ Url = url, Method = "GET" })
		body = response and response.Body
	else
		body = HttpService:GetAsync(url)
	end

	return HttpService:JSONDecode(body)
end

local function chooseServer(wantsFullest)
	local bestServer
	local cursor
	local placeId = PLACE.ServerList

	for _ = 1, 5 do
		local ok, data = pcall(getServerList, placeId, cursor)
		if not ok or not data or not data.data then
			warn("Server list failed:", data)
			return nil
		end

		for _, server in ipairs(data.data) do
			local playing = tonumber(server.playing) or 0
			local maxPlayers = tonumber(server.maxPlayers) or 0
			if server.id and server.id ~= game.JobId and playing < maxPlayers then
				if not bestServer then
					bestServer = server
				elseif wantsFullest and playing > (tonumber(bestServer.playing) or 0) then
					bestServer = server
				elseif not wantsFullest and playing < (tonumber(bestServer.playing) or math.huge) then
					bestServer = server
				end
			end
		end

		cursor = data.nextPageCursor
		if not cursor then
			break
		end
	end

	return bestServer
end

local function joinServerBySize(wantsFullest)
	local placeId = PLACE.ServerList
