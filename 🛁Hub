local placeId = game.PlaceId

local supported = {
    [11729688377] = "loadstring(game:HttpGet('https://raw.githubusercontent.com/Tubris/public-shit-/refs/heads/main/BoogaBooga'))()",
    [2317712696] = "loadstring(game:HttpGet('https://raw.githubusercontent.com/Tubris/public-shit-/refs/heads/main/WildWestMe'))()",
}

local discordInviteCode = "SatFXKfdHa"
local discordUrl = "https://discord.gg/" .. discordInviteCode
local discordBrowserUrl = "https://discord.com/invite/" .. discordInviteCode

local function copyToClipboard(text)
    if setclipboard then
        setclipboard(text)
        return true
    elseif toclipboard then
        toclipboard(text)
        return true
    else
        local success = pcall(function()
            game:GetService("GuiService"):SetClipboard(text)
        end)
        return success
    end
end

local function openUrl(url)
    if syn and syn.request then
        syn.request({ Url = url, Method = "GET" })
        return
    end
    if request then
        request({ Url = url, Method = "GET" })
        return
    end
    local httpService = game:GetService("HttpService")
    if httpService and httpService.HttpGetAsync then
        pcall(function()
            httpService:HttpGetAsync(url)
        end)
    end
end

if supported[placeId] then
    local scriptCode = supported[placeId]
    local success, err = pcall(function()
        loadstring(scriptCode)()
    end)
    if not success then
        warn("Failed to load script: " .. tostring(err))
    end
else
