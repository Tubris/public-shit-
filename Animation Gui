local currentPackName = "Robot"
local activeCheckmark = nil
local isApplying = false
local savedPack = "Robot"

local function savePack(name)
    savedPack = name
    pcall(function()
        if setclipboard then
            setclipboard("AnimPack:" .. name)
        end
    end)
end

local function loadSavedPack()
    pcall(function()
        if getclipboard then
            local clip = getclipboard()
            if clip and clip:sub(1, 9) == "AnimPack:" then
                local name = clip:sub(10)
                for _, pack in ipairs(packs) do
                    if pack.name == name then
                        savedPack = name
                        break
                    end
                end
            end
        end
    end)
    return savedPack
end

local function applyPack(pack)
    if isApplying then return false end
    isApplying = true
    
    local char = player.Character
    if not char then 
        isApplying = false
        return false 
    end
    
    local animate = char:FindFirstChild("Animate")
    if not animate then 
        isApplying = false
        return false 
    end
    
    local run = animate:FindFirstChild("run")
    if run and run:FindFirstChild("RunAnim") then
        run.RunAnim.AnimationId = pack.ids.run
    end
    
    local walk = animate:FindFirstChild("walk")
    if walk and walk:FindFirstChild("WalkAnim") then
        walk.WalkAnim.AnimationId = pack.ids.walk
    end
    
    local jump = animate:FindFirstChild("jump")
    if jump and jump:FindFirstChild("JumpAnim") then
        jump.JumpAnim.AnimationId = pack.ids.jump
    end
    
    local fall = animate:FindFirstChild("fall")
    if fall and fall:FindFirstChild("FallAnim") then
        fall.FallAnim.AnimationId = pack.ids.fall
    end
    
    local swim = animate:FindFirstChild("swim")
    if swim and swim:FindFirstChild("Swim") then
        swim.Swim.AnimationId = pack.ids.swim
    end
    
    local climb = animate:FindFirstChild("climb")
    if climb and climb:FindFirstChild("ClimbAnim") then
        climb.ClimbAnim.AnimationId = pack.ids.climb
    end
    
    local idle = animate:FindFirstChild("idle")
    if idle then
        local anim1 = idle:FindFirstChild("Animation1")
        local anim2 = idle:FindFirstChild("Animation2")
        if anim1 then anim1.AnimationId = pack.ids.idle end
        if anim2 then anim2.AnimationId = pack.ids.idle end
    end
    
    currentPackName = pack.name
    savePack(pack.name)
    isApplying = false
    return true
end

