-- Create pack buttons
local function createPackButton(pack, index)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 60)
    btn.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
    btn.BackgroundTransparency = 0.3
    btn.BorderSizePixel = 0
    btn.Text = ""
    btn.LayoutOrder = index
    btn.Parent = scroll
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = btn
    
    local name = Instance.new("TextLabel")
    name.Size = UDim2.new(1, -80, 0, 22)
    name.Position = UDim2.new(0, 10, 0, 6)
    name.BackgroundTransparency = 1
    name.Text = pack.name
    name.TextColor3 = Color3.fromRGB(255, 255, 255)
    name.TextSize = 13
    name.Font = Enum.Font.GothamBold
    name.TextXAlignment = Enum.TextXAlignment.Left
    name.Parent = btn
    
    local desc = Instance.new("TextLabel")
    desc.Size = UDim2.new(1, -80, 0, 18)
    desc.Position = UDim2.new(0, 10, 0, 30)
    desc.BackgroundTransparency = 1
    desc.Text = pack.desc
    desc.TextColor3 = Color3.fromRGB(130, 130, 135)
    desc.TextSize = 10
    desc.Font = Enum.Font.Gotham
    desc.TextXAlignment = Enum.TextXAlignment.Left
    desc.Parent = btn
    
    local check = Instance.new("TextLabel")
    check.Size = UDim2.new(0, 20, 0, 20)
    check.Position = UDim2.new(0, 10, 0, 20)
    check.BackgroundTransparency = 1
    check.Text = "✓"
    check.TextColor3 = Color3.fromRGB(0, 180, 100)
    check.TextSize = 14
    check.Font = Enum.Font.GothamBold
    check.Visible = (pack.name == currentPackName)
    check.Parent = btn
    
    local apply = Instance.new("TextButton")
    apply.Size = UDim2.new(0, 60, 0, 28)
    apply.Position = UDim2.new(1, -70, 0, 16)
    apply.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
    apply.Text = "Apply"
    apply.TextColor3 = Color3.fromRGB(255, 255, 255)
    apply.TextSize = 11
    apply.Font = Enum.Font.GothamBold
    apply.BorderSizePixel = 0
    apply.Parent = btn
    
    local applyCorner = Instance.new("UICorner")
    applyCorner.CornerRadius = UDim.new(0, 5)
    applyCorner.Parent = apply
    
    if pack.name == currentPackName then
        activeCheckmark = check
    end
    
    apply.MouseButton1Click:Connect(function()
        if isApplying then
            statusText.Text = "Please wait..."
            return
        end
        
        statusText.Text = "Applying " .. pack.name .. "..."
        apply.BackgroundColor3 = Color3.fromRGB(255, 150, 0)
        apply.Text = "..."
        
        local success = applyPack(pack)
        task.wait(0.2)
        
        if success then
            statusText.Text = "Applied " .. pack.name .. "!"
            currentText.Text = "Current: " .. pack.name
            apply.BackgroundColor3 = Color3.fromRGB(0, 180, 100)
            apply.Text = "✓"
            
            if activeCheckmark then
                activeCheckmark.Visible = false
            end
            check.Visible = true
            activeCheckmark = check
            
            task.wait(0.6)
            apply.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
            apply.Text = "Apply"
        else
            statusText.Text = "Failed! Wait for character"
            apply.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
            apply.Text = "Retry"
            task.wait(1)
            apply.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
            apply.Text = "Apply"
        end
        
        task.wait(0.3)
        statusText.Text = "Ready"
    end)
end

for i, pack in ipairs(packs) do
    createPackButton(pack, i)
end

