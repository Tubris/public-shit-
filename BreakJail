-- ESP FUNCTIONS
local function currentPlayers()
    local playersFolder = firstChildByClass(game, "Players") or Players
    return playersFolder:GetPlayers()
end

local function workspaceModelsByName()
    local world = firstChildByClass(game, "Workspace") or Workspace
    local byName = {}
    for _, child in ipairs(world:GetChildren()) do
        if child.ClassName == "Model" then
            byName[child.Name] = child
        end
    end
    return byName
end

local function characterModelForPlayer(player, modelCache)
    if modelCache and modelCache[player.Name] then
        return modelCache[player.Name]
    end
    if player.Character and player.Character.ClassName == "Model" then
        return player.Character
    end
    return nil
end

local function humanoidFor(model)
    if not model then return nil end
    local direct = model:FindFirstChild("Humanoid")
    if direct and direct.ClassName == "Humanoid" then
        return direct
    end
    return firstChildByClass(model, "Humanoid")
end

local function rootPartFor(model)
    if not model then return nil end
    return model:FindFirstChild("HumanoidRootPart")
        or model:FindFirstChild("UpperTorso")
        or model:FindFirstChild("Torso")
        or model.PrimaryPart
        or firstChildByClass(model, "BasePart")
end

local function playerTeam(player)
    local teamName = player.Team and player.Team.Name or "Unknown"
    if string.find(teamName, "Police") then return "Police" end
    if string.find(teamName, "Criminal") then return "Criminal" end
    if string.find(teamName, "Prisoner") then return "Prisoner" end

    local respawn = player:FindFirstChild("RespawnLocation")
    if respawn then
        local text = tostring(respawn.Value or respawn.Name)
        if string.find(text, "Police") then return "Police" end
        if string.find(text, "Criminal") then return "Criminal" end
        if string.find(text, "Prisoner") then return "Prisoner" end
    end

    return "Unknown"
end

local function teamAllowed(team)
    if team == "Police" then return state.teamPolice end
    if team == "Criminal" then return state.teamCriminal end
    if team == "Prisoner" then return state.teamPrisoner end
    return true
end

local function teamColor(team)
    if team == "Police" then return Color3.fromRGB(71, 156, 255) end
    if team == "Criminal" then return Color3.fromRGB(235, 91, 91) end
    if team == "Prisoner" then return Color3.fromRGB(245, 163, 74) end
    return Color3.fromRGB(220, 224, 230)
end

local function createEsp(player, model)
    local old = espObjects[player]
    if old then
        pcall(function() old.gui:Destroy() end)
    end

    local root = rootPartFor(model)
    if not root then return end

    local gui = Instance.new("BillboardGui")
    gui.Name = "ESP_" .. player.Name
    gui.Size = UDim2.new(0, 260, 0, 28)
    gui.Adornee = root
    gui.AlwaysOnTop = true
    gui.StudsOffset = Vector3.new(0, 3.1, 0)
    gui.Enabled = state.esp
    gui.Parent = screenGui

    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, 0, 1, 0)
    bg.BackgroundColor3 = Color3.fromRGB(6, 4, 10)
    bg.BackgroundTransparency = 1
    bg.BorderSizePixel = 0
    bg.Parent = gui

    local name = Instance.new("TextLabel")
    name.Size = UDim2.new(1, -16, 1, 0)
    name.Position = UDim2.new(0, 8, 0, 0)
    name.BackgroundTransparency = 1
    name.TextColor3 = Color3.fromRGB(255, 255, 255)
    name.TextStrokeTransparency = 0.25
    name.TextSize = 12
    name.Font = Enum.Font.GothamBold
    name.TextXAlignment = Enum.TextXAlignment.Center
    name.Parent = bg

    espObjects[player] = {
        gui = gui,
        name = name,
        model = model,
    }
end

local function destroyEsp(player)
    local data = espObjects[player]
    if data then
        pcall(function() data.gui:Destroy() end)
        espObjects[player] = nil
    end
end

local fpsFrames = 0
local fpsElapsed = 0
local shownFps = 0

table.insert(connections, RunService.RenderStepped:Connect(function(deltaTime)
    fpsFrames = fpsFrames + 1
    fpsElapsed = fpsElapsed + deltaTime
    if fpsElapsed >= 0.5 then
        shownFps = math.floor((fpsFrames / fpsElapsed) + 0.5)
        fpsFrames = 0
        fpsElapsed = 0
        statsLabel.Text = string.format("%d FPS", shownFps)
    end

    Camera = Workspace.CurrentCamera or Camera
    
    local modelCache = workspaceModelsByName()
    local wanted = {}

    for _, player in ipairs(currentPlayers()) do
        if player ~= LocalPlayer then
            local team = playerTeam(player)
            local model = characterModelForPlayer(player, modelCache)
            local humanoid = humanoidFor(model)
            local root = rootPartFor(model)

            if model and humanoid and root and teamAllowed(team) then
                wanted[player] = true
                if not espObjects[player] or espObjects[player].model ~= model then
                    createEsp(player, model)
                end

                local data = espObjects[player]
                if data then
                    data.gui.Enabled = state.esp
                    data.gui.Adornee = root
                    data.name.TextColor3 = teamColor(team)
                    local parts = {player.Name}
                    if state.health then
                        local pct = math.clamp(humanoid.Health / math.max(1, humanoid.MaxHealth), 0, 1)
                        table.insert(parts, string.format("%d%%", math.floor((pct * 100) + 0.5)))
                    end
                    if state.distance and Camera then
                        table.insert(parts, string.format("%dm", math.floor((root.Position - Camera.CFrame.Position).Magnitude + 0.5)))
                    end
                    data.name.Text = table.concat(parts, " | ")
                end
            else
                destroyEsp(player)
            end
        end
    end

    for player in pairs(espObjects) do
        if not wanted[player] or not player.Parent then
            destroyEsp(player)
        end
    end
end))

