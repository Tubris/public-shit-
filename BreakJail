local function setupMovement()
    local character = LocalPlayer.Character
    if not character then return end
    
    local humanoid = character:FindFirstChild("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    
    if not humanoid or not rootPart then return end
    
    humanoid.WalkSpeed = 16
    humanoid.JumpPower = 50
    
    if modsState.speedEnabled then
        if not bodyVelocity or bodyVelocity.Parent ~= rootPart then
            if bodyVelocity then bodyVelocity:Destroy() end
            bodyVelocity = Instance.new("BodyVelocity")
            bodyVelocity.Name = "SpeedBooster"
            bodyVelocity.MaxForce = Vector3.new(100000, 0, 100000)
            bodyVelocity.Parent = rootPart
        end
    else
        if bodyVelocity then
            bodyVelocity:Destroy()
            bodyVelocity = nil
        end
    end
end

local function updateMovement()
    local character = LocalPlayer.Character
    if not character then return end
    
    local humanoid = character:FindFirstChild("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    
    if not humanoid or not rootPart then return end
    
    humanoid.WalkSpeed = 16
    humanoid.JumpPower = 50
    
    local moveVector = Vector3.new()
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveVector = moveVector + Vector3.new(0, 0, -1) end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveVector = moveVector + Vector3.new(0, 0, 1) end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveVector = moveVector + Vector3.new(-1, 0, 0) end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveVector = moveVector + Vector3.new(1, 0, 0) end
    
    if modsState.speedEnabled and moveVector.Magnitude > 0 then
        if not bodyVelocity or bodyVelocity.Parent ~= rootPart then
            setupMovement()
        end
        
        if bodyVelocity then
            moveVector = moveVector.Unit
            local camera = workspace.CurrentCamera
            local forward = camera.CFrame.LookVector
            local right = camera.CFrame.RightVector
            
            forward = Vector3.new(forward.X, 0, forward.Z).Unit
            right = Vector3.new(right.X, 0, right.Z).Unit
            
            local direction = (forward * -moveVector.Z + right * moveVector.X).Unit
            bodyVelocity.Velocity = Vector3.new(direction.X * modsState.desiredSpeed, rootPart.Velocity.Y, direction.Z * modsState.desiredSpeed)
        end
    elseif bodyVelocity then
        bodyVelocity.Velocity = Vector3.new(0, bodyVelocity.Velocity.Y, 0)
    end
    
    if modsState.jumpEnabled then
        local spacePressed = UserInputService:IsKeyDown(Enum.KeyCode.Space)
        local onGround = humanoid.FloorMaterial ~= Enum.Material.Air
        
        if spacePressed and not isJumping and onGround then
            isJumping = true
            local jumpPower = math.min(modsState.desiredJumpPower, 180)
            rootPart.Velocity = Vector3.new(rootPart.Velocity.X, jumpPower, rootPart.Velocity.Z)
            task.wait(0.3)
            isJumping = false
        end
    end
end

-- ============= GUN MODS =============
local originalGunConfigs = {}

local function saveOriginalGunConfig(gun)
    if not gun or not gun.Config then return end
    if originalGunConfigs[gun] then return end
    
    originalGunConfigs[gun] = {
        CamShakeMagnitude = gun.Config.CamShakeMagnitude,
        FireAuto = gun.Config.FireAuto,
        FireAutoMobile = gun.Config.FireAutoMobile,
        _hasSWAT = gun._hasSWAT,
    }
end

local function applyGunMods(gun)
    if not gun or not gun.Config then return end
    
    saveOriginalGunConfig(gun)
    
    local orig = originalGunConfigs[gun]
    if not orig then return end
    
    if modsState.noRecoilEnabled then
        gun.Config.CamShakeMagnitude = 0
    else
        gun.Config.CamShakeMagnitude = orig.CamShakeMagnitude
    end
    
    if modsState.autoFireEnabled then
        gun.Config.FireAuto = true
        gun.Config.FireAutoMobile = true
    else
        gun.Config.FireAuto = orig.FireAuto
        gun.Config.FireAutoMobile = orig.FireAutoMobile
    end
    
    if modsState.swatEnabled then
        gun._hasSWAT = true
    else
        gun._hasSWAT = orig._hasSWAT or false
    end
end

local function refreshAllGuns()
    for gun, _ in pairs(originalGunConfigs) do
        if gun and gun.Config then
            applyGunMods(gun)
        else
            originalGunConfigs[gun] = nil
        end
    end
end

local function onGunToggleChanged()
    refreshAllGuns()
    pcall(scanForGuns)
end

-- Hook gun creation
local gunTypes = {"Gun", "Pistol", "Rifle", "Shotgun", "Sniper", "Revolver"}

for _, gunType in pairs(gunTypes) do
    local path = ReplicatedStorage:FindFirstChild("Game")
    if path then
        path = path:FindFirstChild("Item")
        if path then
            local gunPath = path:FindFirstChild(gunType)
            if gunPath then
                local success, GunClass = pcall(require, gunPath)
                if success and GunClass and GunClass.new then
                    local oldNew = GunClass.new
                    GunClass.new = function(...)
                        local gun = oldNew(...)
                        task.spawn(function()
                            task.wait(0.1)
                            saveOriginalGunConfig(gun)
                            applyGunMods(gun)
                        end)
                        return gun
                    end
                end
            end
        end
    end
end

local function scanForGuns()
    for _, v in pairs(getgc and getgc() or {}) do
        if type(v) == "table" and v.Config then
            local isGun = v.__ClassName == "Gun" or v.__ClassName == "Pistol" or v.__ClassName == "Rifle"
            if isGun then
                saveOriginalGunConfig(v)
                applyGunMods(v)
            end
        end
    end
end

