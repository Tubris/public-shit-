function connectDynamicRefresh(key, source, signalName, callback)
	if dynamicRefreshConnections[key] and dynamicRefreshSources[key] == source then
		return
	end

	if dynamicRefreshConnections[key] then
		dynamicRefreshConnections[key]:Disconnect()
	end

	dynamicRefreshSources[key] = source
	dynamicRefreshConnections[key] = source[signalName]:Connect(callback)
end

function getRunningTrainsFolder()
	local trains = Workspace:FindFirstChild("WORKSPACE_Trains")
	return trains and trains:FindFirstChild("RunningTrains") or nil
end

function ensureDynamicRefreshConnections()
	local _, _, animalsFolder = getEntityFolders()
	if animalsFolder then
		connectDynamicRefresh("AnimalsChildAdded", animalsFolder, "ChildAdded", invalidateWorldESP)
		connectDynamicRefresh("AnimalsChildRemoved", animalsFolder, "ChildRemoved", invalidateWorldESP)
		connectDynamicRefresh("AnimalsDescendantAdded", animalsFolder, "DescendantAdded", invalidateWorldESP)
		connectDynamicRefresh("AnimalsDescendantRemoving", animalsFolder, "DescendantRemoving", invalidateWorldESP)
	end

	local runningTrains = getRunningTrainsFolder()
	if runningTrains then
		connectDynamicRefresh("TrainsChildAdded", runningTrains, "ChildAdded", invalidateItemESP)
		connectDynamicRefresh("TrainsChildRemoved", runningTrains, "ChildRemoved", invalidateItemESP)
		connectDynamicRefresh("TrainsDescendantAdded", runningTrains, "DescendantAdded", invalidateItemESP)
		connectDynamicRefresh("TrainsDescendantRemoving", runningTrains, "DescendantRemoving", invalidateItemESP)
	end

	local trainSafe = getTrainSafe()
	if trainSafe and dynamicRefreshSources.TrainSafeOpen ~= trainSafe then
		if dynamicRefreshConnections.TrainSafeOpen then
			dynamicRefreshConnections.TrainSafeOpen:Disconnect()
		end

		dynamicRefreshSources.TrainSafeOpen = trainSafe
		dynamicRefreshConnections.TrainSafeOpen = trainSafe:GetAttributeChangedSignal("IsSafeOpen"):Connect(invalidateItemESP)
	end
end

function disconnectDynamicRefreshConnections()
	for key, connection in pairs(dynamicRefreshConnections) do
		if connection then
			connection:Disconnect()
		end

		dynamicRefreshConnections[key] = nil
		dynamicRefreshSources[key] = nil
	end
end

