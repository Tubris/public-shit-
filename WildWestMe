function rememberBoostProperty(instance, propertyName, value)
	if not boostFpsState[instance] then
		boostFpsState[instance] = {}
	end

	if boostFpsState[instance][propertyName] == nil then
		boostFpsState[instance][propertyName] = value
	end
end

function normalizeBoostName(value)
	return string.lower(tostring(value or "")):gsub("[^%w]", "")
end

function isFoliageBoostName(name)
	local normalized = normalizeBoostName(name)
	return string.find(normalized, "bush", 1, true) ~= nil
		or string.find(normalized, "shrub", 1, true) ~= nil
end

function isCollisionBoostName(name)
	local normalized = normalizeBoostName(name)
	return string.find(normalized, "hitbox", 1, true) ~= nil
		or string.find(normalized, "collision", 1, true) ~= nil
		or string.find(normalized, "collider", 1, true) ~= nil
		or string.find(normalized, "bounds", 1, true) ~= nil
		or string.find(normalized, "bounding", 1, true) ~= nil
end

function getFoliageBoostRoot(instance)
	if not instance then
		return nil
	end

	local character = localPlayer.Character
	if character and instance:IsDescendantOf(character) then
		return nil
	end

	local current = instance
	local best = nil

	while current and current ~= Workspace and current ~= Lighting do
		if isFoliageBoostName(current.Name) then
			best = current
		end

		current = current.Parent
	end

	return best
end

function repairFoliageBoostArtifacts()
	for _, descendant in ipairs(Workspace:GetDescendants()) do
		if getFoliageBoostRoot(descendant) then
			pcall(function()
				if descendant:IsA("BasePart") then
					descendant.LocalTransparencyModifier = CONFIG.BoostFPS and 1 or 0
				elseif descendant:IsA("Decal") or descendant:IsA("Texture") then
					descendant.Transparency = CONFIG.BoostFPS and 1 or 0
				end
			end)
		end
	end
end

function repairTextureBoostArtifacts()
	for _, descendant in ipairs(Workspace:GetDescendants()) do
		if (descendant:IsA("Decal") or descendant:IsA("Texture"))
			and descendant.Transparency >= 0.99
			and not isCollisionBoostName(descendant.Name)
		then
			pcall(function()
				descendant.Transparency = 0
			end)
		end
	end
end

function optimizeLocalCharacterForBoost()
	local character = localPlayer.Character
	if not character then
		return
	end

	for _, descendant in ipairs(character:GetDescendants()) do
		if descendant:IsA("Shirt") then
			rememberBoostProperty(descendant, "ShirtTemplate", descendant.ShirtTemplate)
			descendant.ShirtTemplate = ""
		elseif descendant:IsA("Pants") then
			rememberBoostProperty(descendant, "PantsTemplate", descendant.PantsTemplate)
			descendant.PantsTemplate = ""
		elseif descendant:IsA("ShirtGraphic") then
			rememberBoostProperty(descendant, "Graphic", descendant.Graphic)
			descendant.Graphic = ""
		end
	end
end

function optimizeBoostInstance(instance)
	if not instance then
		return
	end

	local foliageRoot = getFoliageBoostRoot(instance)
	if foliageRoot then
		if instance:IsA("BasePart") then
			rememberBoostProperty(instance, "LocalTransparencyModifier", instance.LocalTransparencyModifier)
			rememberBoostProperty(instance, "CastShadow", instance.CastShadow)
			instance.LocalTransparencyModifier = 1
			instance.CastShadow = false
		elseif instance:IsA("Decal") or instance:IsA("Texture") then
			rememberBoostProperty(instance, "Transparency", instance.Transparency)
			instance.Transparency = 1
		elseif instance:IsA("SurfaceAppearance") then
			rememberBoostProperty(instance, "Parent", instance.Parent)
			instance.Parent = nil
		elseif instance:IsA("ParticleEmitter")
			or instance:IsA("Trail")
			or instance:IsA("Beam")
			or instance:IsA("Fire")
			or instance:IsA("Smoke")
			or instance:IsA("Sparkles")
		then
			rememberBoostProperty(instance, "Enabled", instance.Enabled)
			instance.Enabled = false
		end
		return
	end

	if instance:IsA("BasePart") then
		return
	elseif instance:IsA("Decal") or instance:IsA("Texture") then
		return
	elseif instance:IsA("SurfaceAppearance") then
		return
	elseif instance:IsA("ParticleEmitter")
		or instance:IsA("Trail")
		or instance:IsA("Beam")
		or instance:IsA("Fire")
		or instance:IsA("Smoke")
		or instance:IsA("Sparkles")
	then
		rememberBoostProperty(instance, "Enabled", instance.Enabled)
		instance.Enabled = false
	elseif instance:IsA("BloomEffect")
		or instance:IsA("BlurEffect")
		or instance:IsA("DepthOfFieldEffect")
		or instance:IsA("SunRaysEffect")
	then
		rememberBoostProperty(instance, "Enabled", instance.Enabled)
		instance.Enabled = false
	end
end

