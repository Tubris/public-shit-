function isTargetBehindWall(model, position, originOverride)
	local camera = Workspace.CurrentCamera
	if not camera or not model or not position then
		return false
	end

	local origin = typeof(originOverride) == "Vector3" and originOverride or camera.CFrame.Position
	local direction = position - origin
	if direction.Magnitude <= 0 then
		return false
	end

	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	rayParams.IgnoreWater = true

	local ignoreList = {}
	if localPlayer.Character then
		table.insert(ignoreList, localPlayer.Character)
	end

	rayParams.FilterDescendantsInstances = ignoreList

	local result = Workspace:Raycast(origin, direction, rayParams)
	if not result or not result.Instance then
		return false
	end

	return not result.Instance:IsDescendantOf(model)
end

function getCachedTargetBehindWall(model, position)
	if not model or not position then
		return false
	end

	local now = os.clock()
	if targetWallCacheModel == model
		and targetWallCachePosition
		and (position - targetWallCachePosition).Magnitude < 2
		and now - targetWallCacheTime < 0.25
	then
		return targetWallCacheBehind
	end

	targetWallCacheModel = model
	targetWallCachePosition = position
	targetWallCacheTime = now
	targetWallCacheBehind = isTargetBehindWall(model, position)
	return targetWallCacheBehind
end

function setVisualTarget(target)
	if unloaded then
		return
	end

	local active = target ~= nil and isSoftAimActive()
	local model = active and target.Model or nil
	local part = active and target.Part or nil
	local group = active and target.Group or nil
	local wantsVisual = active and (CONFIG.TargetChams or CONFIG.TargetName or CONFIG.TargetDistance)
	local nameText = ""

	if not wantsVisual then
		if lastVisualActive ~= false or targetHighlight.Enabled or targetBillboard.Enabled then
			local oldModel = lastVisualModel
			local oldGroup = lastVisualGroup
			lastVisualModel = nil
			lastVisualPart = nil
			lastVisualGroup = nil
			lastVisualActive = false
			targetHighlight.Enabled = false
			targetHighlight.Adornee = nil
			targetBillboard.Enabled = false
			targetBillboard.Adornee = nil
			reassertWorldESPHighlight(oldModel, oldGroup)
		end
		return
	end

	local behindWall = active and getCachedTargetBehindWall(model, target.Position) or false
	local visualColor = behindWall and CONFIG.TargetBehindWallColor or CONFIG.TargetColor

	if active then
		local textParts = {}

		if CONFIG.TargetName then
			textParts[#textParts + 1] = target.Name
		end

		if CONFIG.TargetDistance and target.Position then
			local character = localPlayer.Character
			local characterRoot = character and character:FindFirstChild("HumanoidRootPart")
			local fromPosition = characterRoot and characterRoot.Position or Workspace.CurrentCamera and Workspace.CurrentCamera.CFrame.Position

			if fromPosition then
				textParts[#textParts + 1] = tostring(math.floor((target.Position - fromPosition).Magnitude)) .. " studs"
			end
		end

		nameText = table.concat(textParts, " | ")
	end

	if lastVisualModel == model
		and lastVisualPart == part
		and lastVisualGroup == group
		and lastVisualActive == active
		and lastVisualChams == CONFIG.TargetChams
		and lastVisualName == CONFIG.TargetName
		and lastVisualDistance == CONFIG.TargetDistance
		and lastVisualTextSize == CONFIG.TargetTextSize
		and lastVisualText == nameText
		and lastVisualBehindWall == behindWall
		and lastVisualColor == visualColor then
		targetHighlight.Enabled = active and CONFIG.TargetChams
		targetHighlight.Adornee = model
		targetHighlight.FillColor = visualColor
		targetHighlight.OutlineColor = visualColor:Lerp(Color3.fromRGB(255, 255, 255), 0.42)
		targetBillboard.Enabled = active and nameText ~= ""
		targetBillboard.Adornee = part
		return
	end

	if lastVisualModel and lastVisualModel ~= model then
		reassertWorldESPHighlight(lastVisualModel, lastVisualGroup)
	end

	lastVisualModel = model
	lastVisualPart = part
	lastVisualGroup = group
	lastVisualActive = active
	lastVisualChams = CONFIG.TargetChams
	lastVisualName = CONFIG.TargetName
	lastVisualDistance = CONFIG.TargetDistance
	lastVisualTextSize = CONFIG.TargetTextSize
	lastVisualText = nameText
	lastVisualBehindWall = behindWall
	lastVisualColor = visualColor

	targetHighlight.Enabled = active and CONFIG.TargetChams
	targetHighlight.Adornee = model
	targetHighlight.FillColor = visualColor
	targetHighlight.OutlineColor = visualColor:Lerp(Color3.fromRGB(255, 255, 255), 0.42)

	targetBillboard.Enabled = active and nameText ~= ""
	targetBillboard.Adornee = part
	targetText.TextColor3 = visualColor
	targetText.TextSize = CONFIG.TargetTextSize
	targetText.Text = nameText
end

function getBestTarget(origin)
	if unloaded or not isSoftAimActive() then
		return nil
	end

	local camera = Workspace.CurrentCamera
	if not camera then
		return nil
	end

	refreshTargetCandidates()

	local fovCenter = getFOVCenter()
	local character = localPlayer.Character
	local characterRoot = character and character:FindFirstChild("HumanoidRootPart")
	local charPos = characterRoot and characterRoot.Position or (typeof(origin) == "Vector3" and origin or camera.CFrame.Position)
	local charLook = camera.CFrame.LookVector
	local bestScore = math.huge
	local bestCursorDistance = math.huge
	local bestTargetDistance = math.huge
	local bestTarget = nil

	local function processModel(model)
		local modelGroup = targetCandidateGroups[model]
		if isOwnHorseModel(model) then
			return
		end

		if not shouldTrackModel(model, modelGroup) then
			return
		end

		local root = getRootPart(model)
		if not root then
			return
		end

		local part, aimPosition = getAimPoint(model, modelGroup)
		if not part or not aimPosition then
			return
		end

		local directionToTarget = aimPosition - charPos
		if directionToTarget.Magnitude <= 0 then
			return
		end

		local targetDistance = directionToTarget.Magnitude
		if CONFIG.MaxTargetDistance > 0 and targetDistance > CONFIG.MaxTargetDistance then
			return
		end

		if CONFIG.TargetWallCheck and isTargetBehindWall(model, aimPosition, charPos) then
			return
		end

		if CONFIG.FOV > 0 and charLook:Dot(directionToTarget.Unit) <= 0 then
			return
		end

		local cursorDistance = targetDistance
		local onScreen = false
		local screenDepth = 0

		local function considerCursorPosition(position)
			if not position then
				return
			end

			local screenPos, visible = camera:WorldToScreenPoint(position)
			if visible and screenPos.Z > 0 then
				local distance = (Vector2.new(screenPos.X, screenPos.Y) - fovCenter).Magnitude
				if not onScreen or distance < cursorDistance then
					cursorDistance = distance
					screenDepth = screenPos.Z
					onScreen = true
				end
			end
		end

		considerCursorPosition(part.Position)

		if CONFIG.TargetMode == "Closest To Cursor" then
			considerCursorPosition(root.Position)
		end

		if CONFIG.FOV > 0 then
			if not onScreen or screenDepth <= 0 then
				return
			end

			if cursorDistance > CONFIG.FOV then
				return
			end
		end

		local score
		if CONFIG.TargetMode == "Closest To Player" or CONFIG.FOV <= 0 then
			score = targetDistance
		else
			score = cursorDistance
		end

		local betterScore = score < bestScore
			or (math.abs(score - bestScore) < 0.001 and cursorDistance < bestCursorDistance)
			or (math.abs(score - bestScore) < 0.001 and math.abs(cursorDistance - bestCursorDistance) < 0.001 and targetDistance < bestTargetDistance)

		if betterScore then
			local nameOk, displayName = pcall(getTargetDisplayName, model, modelGroup)
			bestScore = score
			bestCursorDistance = cursorDistance
			bestTargetDistance = targetDistance
			bestTarget = {
				Model = model,
				Part = part,
				Position = aimPosition,
				Name = (nameOk and displayName) or model.Name,
				Group = modelGroup
			}
		end
	end

	for index = #targetCandidates, 1, -1 do
		local model = targetCandidates[index]

		if not model or not model.Parent then
			table.remove(targetCandidates, index)
		else
			processModel(model)
		end
	end

	return bestTarget
end

function passesHitChance()
	if CONFIG.HitChance >= 100 then
		return true
	end

	if CONFIG.HitChance <= 0 then
		return false
	end

	return math.random(1, 100) <= CONFIG.HitChance
end

function shouldApplySoftAimForInfo(info)
	if type(info) ~= "table" then
		return passesHitChance()
	end

	local cachedRoll = hitChanceRolls[info]
	local now = os.clock()
	if cachedRoll and now - cachedRoll.Time < 0.08 then
		return cachedRoll.Roll
	end

	local roll = passesHitChance()
	hitChanceRolls[info] = {
		Roll = roll,
		Time = now
	}
	return roll
end

function getSoftAimDirection(origin, fallbackDirection)
	if unloaded then
		return fallbackDirection, nil, nil, nil
	end

	local target = currentTarget
	local reuseTarget = CONFIG.TargetMode ~= "Closest To Cursor" and target and target.Model and target.Model.Parent
	if reuseTarget and typeof(origin) == "Vector3" and target.Position then
		local distance = (target.Position - origin).Magnitude
		if CONFIG.MaxTargetDistance > 0 and distance > CONFIG.MaxTargetDistance then
			reuseTarget = false
		end
	end

	if not reuseTarget then
		target = getBestTarget(origin)
	end
	currentTarget = target

	if target and typeof(origin) == "Vector3" then
		local direction = target.Position - origin

		if direction.Magnitude > 0 and passesHitChance() then
			return direction.Unit, target.Position, target.Model, target.Part
		end
	end

	return fallbackDirection, nil, nil, nil
end

function applySoftAimNoSpread(info, projectileParams)
	local function zeroSpreadValue(container, key)
		if type(container) ~= "table" or container[key] == nil then
			return
		end

		if type(container[key]) == "number" then
			container[key] = 0
		end
	end

	for _, container in ipairs({ info, projectileParams }) do
		zeroSpreadValue(container, "spread")
		zeroSpreadValue(container, "Spread")
		zeroSpreadValue(container, "bloom")
		zeroSpreadValue(container, "Bloom")
		zeroSpreadValue(container, "inaccuracy")
		zeroSpreadValue(container, "Inaccuracy")
		zeroSpreadValue(container, "recoil")
		zeroSpreadValue(container, "Recoil")

		if type(container) == "table" then
			if type(container.accuracy) == "number" then
				container.accuracy = math.max(container.accuracy, 1)
			end
			if type(container.Accuracy) == "number" then
				container.Accuracy = math.max(container.Accuracy, 1)
			end
		end
	end
end

