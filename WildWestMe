	if groupName == "Player" then
		return CONFIG.WorldPlayerColor
	elseif groupName == "Animal" then
		return CONFIG.WorldAnimalColor
	elseif groupName == "NPC" then
		return CONFIG.WorldNPCColor
	end

	return CONFIG.WorldPlayerColor
end

function getZayColor(offset)
	return Color3.fromHSV((os.clock() * 0.22 + (offset or 0)) % 1, 0.95, 1)
end

function getZayOffset(instance)
	local text = instance and instance.Name or ""
	local total = 0

	for index = 1, #text do
		total += string.byte(text, index)
	end

	return (total % 97) / 97
end

function getZayTintEffect()
	if zayTintEffect and zayTintEffect.Parent then
		return zayTintEffect
