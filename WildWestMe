function httpGetBody(url)
	local body = nil

	pcall(function()
		if type(request) == "function" then
			local response = request({
				Url = url,
				Method = "GET",
				Headers = {
					["User-Agent"] = "Roblox/WinInet"
				}
			})
			body = response and (response.Body or response.body)
		end
	end)
	if type(body) == "string" and #body > 0 then
		return body
	end

	pcall(function()
		if type(http_request) == "function" then
			local response = http_request({
				Url = url,
				Method = "GET"
			})
			body = response and (response.Body or response.body)
		end
	end)
	if type(body) == "string" and #body > 0 then
		return body
	end

	pcall(function()
		if type(syn) == "table" and type(syn.request) == "function" then
			local response = syn.request({
				Url = url,
				Method = "GET"
			})
			body = response and (response.Body or response.body)
		end
	end)
	if type(body) == "string" and #body > 0 then
		return body
	end

	pcall(function()
		if type(http) == "table" and type(http.request) == "function" then
			local response = http.request({
				Url = url,
				Method = "GET"
			})
			body = response and (response.Body or response.body)
		end
	end)
	if type(body) == "string" and #body > 0 then
		return body
	end

	pcall(function()
		if type(fluxus) == "table" and type(fluxus.request) == "function" then
			local response = fluxus.request({
				Url = url,
				Method = "GET"
			})
			body = response and (response.Body or response.body)
		end
	end)
	if type(body) == "string" and #body > 0 then
		return body
	end

	pcall(function()
		body = game:HttpGet(url)
	end)
	if type(body) == "string" and #body > 0 then
		return body
	end

	pcall(function()
		body = HttpService:GetAsync(url)
	end)
	if type(body) == "string" and #body > 0 then
		return body
	end

	return nil
end

function getPlaceServers(placeId, maxPages)
	local servers = {}
	local cursor = nil

	for _ = 1, maxPages do
		local url = "https://games.roblox.com/v1/games/" .. tostring(placeId) .. "/servers/Public?sortOrder=Asc&limit=100&excludeFullGames=true"
		if cursor and cursor ~= "" then
			url = url .. "&cursor=" .. HttpService:UrlEncode(cursor)
		end

		local body = httpGetBody(url)
		if not body then
			break
		end

		local ok, decoded = pcall(function()
			return HttpService:JSONDecode(body)
		end)

		if not ok or type(decoded) ~= "table" then
			break
		end

		if type(decoded.data) == "table" then
			for _, server in ipairs(decoded.data) do
				table.insert(servers, server)
			end
		end

		cursor = decoded.nextPageCursor
		if not cursor or cursor == "" then
			break
		end

		task.wait(0.08)
	end

	return servers
end

function serverLooksAmerican(server)
	if type(server) ~= "table" then
		return false
	end

	local regionText = ""
	for _, key in ipairs({ "region", "location", "country", "name" }) do
		local value = server[key]
		if type(value) == "string" then
			regionText = regionText .. " " .. string.lower(value)
		end
	end

	for _, marker in ipairs({
		"united states",
		"north america",
		"america",
		"usa",
		"u.s.",
		"us-",
		"us_",
		"nae",
		"naw",
		"virginia",
		"california",
		"oregon",
		"texas",
		"illinois",
		"new jersey",
		"florida",
		"georgia",
		"new york",
		"washington",
		"ashburn",
		"atlanta",
		"chicago",
		"dallas",
		"miami",
		"los angeles",
		"seattle"
	}) do
		if string.find(regionText, marker, 1, true) then
			return true
		end
	end

	local ping = tonumber(server.ping)
	return ping ~= nil and ping > 0 and ping <= 160
end

function isJoinableServer(server)
	if type(server) ~= "table" or type(server.id) ~= "string" or server.id == game.JobId then
		return false
	end

	local playing = tonumber(server.playing)
	local maxPlayers = tonumber(server.maxPlayers)
	return not playing or not maxPlayers or playing < maxPlayers
end

function matchesServerRegion(server)
	return not CONFIG.AmericanServers or serverLooksAmerican(server)
end

function pickSmallestServer(servers)
	local bestServer = nil
	local bestPlaying = math.huge
	local bestPing = math.huge

	for _, server in ipairs(servers) do
		if isJoinableServer(server) and matchesServerRegion(server) then
			local playing = tonumber(server.playing) or 0
			local ping = tonumber(server.ping) or math.huge
			if playing < bestPlaying or (playing == bestPlaying and ping < bestPing) then
				bestServer = server
				bestPlaying = playing
				bestPing = ping
			end
		end
	end

	return bestServer
end

function pickRandomPopulatedServer(servers)
	local choices = {}

	for _, server in ipairs(servers) do
		if isJoinableServer(server) and matchesServerRegion(server) then
			local playing = tonumber(server.playing) or 0
			if playing >= CONFIG.MinimumHopPlayers then
				table.insert(choices, server)
			end
		end
	end

	if #choices > 0 then
		return choices[math.random(1, #choices)]
	end

	return nil
end

function teleportToPlaceServer(placeId, server, button)
	if not server or not server.id then
		setServerButtonStatus(button, CONFIG.AmericanServers and "No American server" or "No server found", 1.8)
		return
	end

	local playing = tonumber(server.playing)
	setServerButtonStatus(button, playing and ("Joining " .. tostring(playing) .. " player server") or "Joining server", nil)

	local ok = pcall(function()
		TeleportService:TeleportToPlaceInstance(placeId, server.id, localPlayer)
	end)

	if not ok then
		setServerButtonStatus(button, "Teleport failed", 1.8)
	end
end

function runServerSearch(button, picker)
	if button:GetAttribute("TubzBusy") then
		return
	end

	button:SetAttribute("TubzBusy", true)
	setServerButtonStatus(button, "Searching...", nil)

	task.spawn(function()
		local ok, servers = pcall(function()
			return getPlaceServers(game.PlaceId, 7)
		end)

		button:SetAttribute("TubzBusy", false)

		if unloaded or not button.Parent then
			return
		end

		if not ok or type(servers) ~= "table" or #servers <= 0 then
			setServerButtonStatus(button, "Search failed", 1.8)
			return
		end

		teleportToPlaceServer(game.PlaceId, picker(servers), button)
	end)
end

function rejoinCurrentServer()
	setServerButtonStatus(rejoinServerButton, "Rejoining...", nil)

	local ok = pcall(function()
		if game.JobId and game.JobId ~= "" then
			TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, localPlayer)
		else
			TeleportService:Teleport(game.PlaceId, localPlayer)
		end
	end)

	if not ok then
		setServerButtonStatus(rejoinServerButton, "Rejoin failed", 1.8)
	end
end

