function updateItemESPEntry(instance, labelText, color, fromPosition, visibleItems, forceChams)
	local position, adornee = getOrePositionAndAdornee(instance)
	if not position or not adornee then
		return
	end

	local distance = fromPosition and (position - fromPosition).Magnitude or 0
	if CONFIG.WorldMaxDrawDistance > 0 and distance > CONFIG.WorldMaxDrawDistance then
		return
	end

	visibleItems[instance] = true

	local esp = itemEspObjects[instance] or makeItemESPObject(instance)
	local text = labelText
	if CONFIG.WorldDistance then
		text = text .. " | " .. tostring(math.floor(distance)) .. " studs"
	end

	esp.Highlight.FillColor = color
	esp.Highlight.OutlineColor = color:Lerp(Color3.fromRGB(255, 255, 255), 0.42)
	esp.Highlight.Adornee = adornee
	esp.Highlight.Enabled = CONFIG.WorldChams or forceChams == true
	esp.ForceChams = forceChams == true
	esp.LastSeen = os.clock()

	esp.Billboard.Adornee = adornee
	esp.Billboard.Enabled = true
	esp.Label.TextColor3 = color:Lerp(Color3.fromRGB(255, 255, 255), 0.12)
	esp.Label.TextSize = CONFIG.WorldTextSize
	esp.Label.Text = text
end

