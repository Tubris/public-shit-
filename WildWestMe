		if input.UserInputType ~= Enum.UserInputType.MouseMovement then
			return
		end

		if draggingSV then
			setSVFromPosition(input.Position)
		elseif draggingHue then
			setHueFromPosition(input.Position)
		end
	end)

	updatePicker()
	return updatePicker
end

