	accent.Size = UDim2.new(0, 4, 1, -14)
	accent.Position = UDim2.fromOffset(8, 7)
	accent.BackgroundColor3 = (color or CONFIG.NotificationColor):Lerp(CONFIG.NotificationColor, 0.45)
	accent.BackgroundTransparency = 1
	accent.BorderSizePixel = 0
