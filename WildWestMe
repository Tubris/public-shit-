function getBoatVaultOpenState(vault)
	if not vault then
		return nil
	end

	for _, instance in ipairs({ vault, vault:FindFirstChild("VaultDoor", true), vault:FindFirstChild("Door", true) }) do
		if instance then
			for _, propertyName in ipairs({ "Open", "Opened", "IsOpen", "DoorOpen", "VaultOpen" }) do
				local value = getBoolProperty(instance, propertyName)
				if value ~= nil then
					return value
				end
			end
		end
	end

	for _, descendant in ipairs(vault:GetDescendants()) do
		if descendant:IsA("BoolValue") then
			local normalized = normalizeLookupText(descendant.Name)
			if normalized == "open"
				or normalized == "opened"
				or normalized == "isopen"
				or normalized == "dooropen"
				or normalized == "vaultopen"
			then
				return descendant.Value
			end
		end
	end

	return nil
end

function colorLootVisual(instance, color, glow)
	if not instance or not instance.Parent then
		return
	end

	if instance:IsA("BasePart") then
		instance.Color = color
		if glow and not CONFIG.BoostFPS then
			instance.Material = Enum.Material.Neon
		end
	end

	for _, descendant in ipairs(instance:GetDescendants()) do
		if descendant:IsA("BasePart") then
			descendant.Color = color
			if glow and not CONFIG.BoostFPS then
				descendant.Material = Enum.Material.Neon
			end
		end
	end
end

applyLootPartColors = function()
	local _, _, goldBars, safe1, safe2 = getBankParts()

	for _, unit in ipairs(getBankGoldBarUnits(goldBars)) do
		colorLootVisual(unit, CONFIG.LootGoldColor, true)
	end

	for _, unit in ipairs(getBoatGoldPileUnits()) do
		colorLootVisual(unit, CONFIG.LootGoldColor, true)
	end

	for _, unit in ipairs(getSafeDiamondUnits(safe1)) do
		colorLootVisual(unit, CONFIG.LootDiamondColor, true)
	end

	for _, unit in ipairs(getSafeDiamondUnits(safe2)) do
		colorLootVisual(unit, CONFIG.LootDiamondColor, true)
	end
end

function requestLootColorApply(force)
	lootColorsDirty = true

	if force then
		lastLootColorApply = 0
	end
end

function maybeApplyLootPartColors(force)
	if not applyLootPartColors then
		return
	end

	local now = os.clock()
	if not force and (not lootColorsDirty or now - lastLootColorApply < 1) then
		return
	end

	lastLootColorApply = now
	lootColorsDirty = false
	applyLootPartColors()
end

function getBankSnapshot()
	local bankBase, vaultEntrance, goldBars, safe1, safe2 = getBankParts()
	local goldCount = countBankGoldBars(goldBars)
	local cashValue = goldCount * 200
	local diamondCount = countSafeDiamonds(safe1) + countSafeDiamonds(safe2)
	local vaultOpen = getBoolProperty(vaultEntrance, "Open") == true
	local status = "Closed"

	if cashLabel then
		cashLabel.Text = "Cash: $" .. tostring(cashValue)
	end

	if vaultOpen and goldCount > 0 then
		status = "In Progress"
	elseif goldCount <= 0 then
		status = "Closed"
	else
		status = "Open"
	end

	return {
		Name = "Bank",
		Status = status,
		Color = getStatusColor(status),
		GoldBars = goldCount,
		Diamonds = diamondCount,
		Cash = cashValue,
		Location = vaultEntrance or goldBars or bankBase
	}
end

function getBoatSnapshot()
	local vaults = getRiverboatVaults()
	local units = getBoatGoldPileUnits()
	local count = #units
	local location = nil
	local hasOpenState = false
	local anyOpen = false

	if #units > 0 then
		location = units[1]
	else
		for _, vault in ipairs(vaults) do
			location = location or vault:FindFirstChild("VaultDoor", true) or vault
		end
	end

	for _, vault in ipairs(vaults) do
		local openState = getBoatVaultOpenState(vault)
		if openState ~= nil then
			hasOpenState = true
			anyOpen = anyOpen or openState
		end
	end

	local status
	if #vaults <= 0 and count <= 0 then
		status = "Empty"
	elseif hasOpenState then
		status = anyOpen and "Empty" or "Ready"
	else
		status = count > 0 and "Empty" or "Ready"
	end

	return {
		Name = "Swamp Boat",
		Status = status,
		Color = status == "Ready" and Color3.fromRGB(190, 255, 0) or getStatusColor(status),
		GoldBars = count,
		Location = location
	}
end

function getTrainSnapshot()
	local safe = getTrainSafe()
	local isOpen = safe and safe:GetAttribute("IsSafeOpen") == true
	local status = "Missing"
	if safe then
		status = isOpen and "Robbed" or "Ready"
	end

	return {
		Name = "Train",
		Status = status,
		Color = status == "Ready" and Color3.fromRGB(195, 255, 0) or Color3.fromRGB(255, 65, 65),
		Location = safe
	}
end

