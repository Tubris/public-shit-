function getDirectChildUnder(instance, root)
	local current = instance

	while current and current.Parent and current.Parent ~= root do
		current = current.Parent
	end

	if current and current.Parent == root then
		return current
	end

	return instance
end

function getNearestNamedAncestor(instance, root, wantedName)
	local current = instance

	while current and current ~= root do
		if current.Name == wantedName then
			return current
		end

		current = current.Parent
	end

	return nil
end

function isLootVisualPresent(instance, wantedName)
	if not instance or not instance.Parent then
		return false
	end

	if instance:IsA("BasePart") and instance.Transparency < 0.96 then
		return true
	end

	for _, descendant in ipairs(instance:GetDescendants()) do
		if descendant:IsA("BasePart") and descendant.Transparency < 0.96 then
			if not wantedName
				or descendant.Name == wantedName
				or descendant:FindFirstAncestor(wantedName) ~= nil
			then
				return true
			end
		end
	end

	return false
end

function isGoldPileAvailable(goldPile)
	if not goldPile or not goldPile.Parent then
		return false
	end

	for _, descendant in ipairs(goldPile:GetDescendants()) do
		if descendant:IsA("BasePart") and descendant.Transparency < 0.96 then
			return true
		end
	end

	return goldPile:IsA("BasePart") and goldPile.Transparency < 0.96
end

function isBankGoldBarAvailable(goldBarUnit)
	if not goldBarUnit or not goldBarUnit.Parent then
		return false
	end

	local sawRobScript = false

	for _, descendant in ipairs(goldBarUnit:GetDescendants()) do
		if descendant.Name == "RobBankGold" then
			sawRobScript = true

			local disabled = getBoolProperty(descendant, "Disabled")
			if disabled == false then
				return true
			end
		end
	end

	return not sawRobScript
end

function isDiamondAvailable(diamond)
	if not diamond or not diamond.Parent then
		return false
	end

	local disabledByLootScript = false
	for _, descendant in ipairs(diamond:GetDescendants()) do
		local normalized = normalizeLookupText(descendant.Name)
		if string.find(normalized, "diamond", 1, true)
			and (
				string.find(normalized, "rob", 1, true)
				or string.find(normalized, "loot", 1, true)
				or string.find(normalized, "collect", 1, true)
			)
		then
			local disabled = getBoolProperty(descendant, "Disabled")
			if disabled == false then
				return true
			elseif disabled == true then
				disabledByLootScript = true
			end
		end
	end

	if disabledByLootScript then
		return false
	end

	return isLootVisualPresent(diamond, "CutDiamond")
end

function addLootUnit(units, seen, unit, wantedName)
	if not unit or seen[unit] then
		return
	end

	if wantedName == "GoldBar" and not isBankGoldBarAvailable(unit) then
		return
	end

	if wantedName == "GoldPile" and not isGoldPileAvailable(unit) then
		return
	end

	if wantedName == "CutDiamond" and not isDiamondAvailable(unit) then
		return
	end

	if wantedName ~= "GoldBar"
		and wantedName ~= "CutDiamond"
		and not isLootVisualPresent(unit, wantedName)
	then
		return
	end

	seen[unit] = true
	table.insert(units, unit)
end

function getBankGoldBarUnits(goldBarsFolder)
	local units = {}
	local seen = {}

	if not goldBarsFolder then
		return units
	end

	for _, child in ipairs(goldBarsFolder:GetChildren()) do
		if child:FindFirstChild("RobBankGold", true) then
			addLootUnit(units, seen, child, "GoldBar")
		end
	end

	if #units > 0 then
		return units
	end

	for _, descendant in ipairs(goldBarsFolder:GetDescendants()) do
		if descendant.Name == "RobBankGold" then
			addLootUnit(
				units,
				seen,
				getDirectChildUnder(descendant, goldBarsFolder) or getNearestNamedAncestor(descendant, goldBarsFolder, "GoldBar"),
				"GoldBar"
			)
		end
	end

	if #units <= 0 then
		for _, child in ipairs(goldBarsFolder:GetChildren()) do
			local goldBar = child.Name == "GoldBar" and child or child:FindFirstChild("GoldBar", true)
			addLootUnit(units, seen, goldBar or child, "GoldBar")
		end
	end

	return units
end

function countBankGoldBars(goldBarsFolder)
	return #getBankGoldBarUnits(goldBarsFolder)
end

function getSafeDiamondUnits(safe)
	local units = {}
	local seen = {}

	if not safe then
		return units
	end

	local loot = getPath(safe, { "HumanoidRootPart", "Loot" })
	if not loot then
		return units
	end

	for _, child in ipairs(loot:GetChildren()) do
		local diamond = child.Name == "CutDiamond" and child or child:FindFirstChild("CutDiamond", true)
		addLootUnit(units, seen, diamond, "CutDiamond")
	end

	if #units <= 0 then
		for _, descendant in ipairs(loot:GetDescendants()) do
			if descendant.Name == "CutDiamond" then
				addLootUnit(units, seen, descendant, "CutDiamond")
			end
		end
	end

	return units
end

function countSafeDiamonds(safe)
	return #getSafeDiamondUnits(safe)
end

function getBoatGoldPileUnits()
