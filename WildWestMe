function getRobberyPopupContent(name, status)
	if name == "Train" then
		if status == "Ready" then
			return "Train Open", "Train safe is ready to rob.", Color3.fromRGB(195, 255, 0)
		elseif status == "Robbed" then
			return "Train Robbed", "Train safe got robbed.", Color3.fromRGB(255, 65, 65)
		end
	elseif name == "Bank" then
		if status == "Open" then
			return "Bank Open", "Bank is ready to rob.", Color3.fromRGB(80, 255, 110)
		elseif status == "In Progress" then
			return "Bank In Progress", "Someone started the bank.", Color3.fromRGB(255, 220, 70)
		elseif status == "Closed" then
			return "Bank Robbed", "Bank loot is gone.", Color3.fromRGB(255, 65, 65)
		end
	elseif name == "Swamp Boat" then
		if status == "Ready" then
			return "Swamp Boat Open", "Riverboat vault is ready.", Color3.fromRGB(190, 255, 0)
		elseif status == "Empty" then
			return "Swamp Boat Robbed", "Riverboat loot is gone.", Color3.fromRGB(255, 65, 65)
		end
	end

	return nil, nil, nil
end

function trackRobberyStatus(name, snapshot)
	local status = snapshot and snapshot.Status
	if not status then
		return
	end

	local oldStatus = robberyStatusCache[name]
	robberyStatusCache[name] = status

	if not oldStatus or oldStatus == status then
		return
	end

	local title, body, color = getRobberyPopupContent(name, status)
	if title then
		showRobberyPopup(title, body, color)
	end
end

