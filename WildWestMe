function getPath(root, names)
	local current = root
	for _, name in ipairs(names) do
		if not current then
			return nil
		end

		current = current:FindFirstChild(name)
	end

	return current
end

function getStatusColor(status)
	if status == "Open" or status == "Ready" then
		return Color3.fromRGB(80, 255, 110)
	elseif status == "In Progress" or status == "Partial" then
		return Color3.fromRGB(255, 220, 70)
	end

	return Color3.fromRGB(255, 65, 65)
end

function getBoolProperty(instance, propertyName)
	if not instance then
		return nil
	end

	local attribute = instance:GetAttribute(propertyName)
	if type(attribute) == "boolean" then
		return attribute
	end

	local child = instance:FindFirstChild(propertyName)
	if child and child:IsA("BoolValue") then
		return child.Value
	end

	local ok, value = pcall(function()
		return instance[propertyName]
	end)

	if ok and type(value) == "boolean" then
		return value
	end

	return nil
end

