function isAliveTarget(model)
	local current = nil
	local ok, health = pcall(getAliveCheckHealth, model)
	if ok then
		current = health
	end

	if current ~= nil then
		return current > 0
	end

	return true
end

function hasDeadStateFlag(model)
	if not model then
		return false
	end

	local deadNames = {
		dead = true,
		isdead = true,
		deadbody = true,
		corpse = true,
		ragdoll = true,
		isragdoll = true,
		ragdolled = true,
		downed = true,
		knocked = true,
		knockeddown = true,
		unconscious = true
	}
	local healthNames = {
		health = true,
		hp = true,
		currenthealth = true,
		currenthp = true,
		healthvalue = true
	}

	local function truthy(value)
		if value == true then
			return true
		elseif type(value) == "string" then
			local normalized = normalizeLookupText(value)
			return normalized == "true" or normalized == "yes" or normalized == "dead" or normalized == "downed"
		elseif typeof(value) == "number" then
			return value ~= 0
		end

		return false
	end

	local function checkInstance(instance)
		local normalizedName = normalizeLookupText(instance.Name)
		if normalizedName == "corpse" or normalizedName == "deadbody" then
			return true
		end

		for attributeName, attributeValue in pairs(instance:GetAttributes()) do
			local normalizedAttribute = normalizeLookupText(attributeName)
			if deadNames[normalizedAttribute] and truthy(attributeValue) then
				return true
			end

			if healthNames[normalizedAttribute] then
				local numericHealth = tonumber(attributeValue)
				if numericHealth ~= nil and numericHealth <= 0 then
					return true
				end
			end
		end

		if instance:IsA("BoolValue") and deadNames[normalizedName] and instance.Value then
			return true
		end

		if (instance:IsA("StringValue") or instance:IsA("IntValue") or instance:IsA("NumberValue")) and deadNames[normalizedName] and truthy(instance.Value) then
			return true
		end

		if (instance:IsA("StringValue") or instance:IsA("IntValue") or instance:IsA("NumberValue")) and healthNames[normalizedName] then
			local numericHealth = tonumber(instance.Value)
			if numericHealth ~= nil and numericHealth <= 0 then
				return true
			end
		end

		return false
	end

	if checkInstance(model) then
		return true
	end

	local entityRoot = getEntityRootModel(model)
	if entityRoot and entityRoot ~= model and checkInstance(entityRoot) then
		return true
	end

	local humanoid = model:FindFirstChildWhichIsA("Humanoid", true)
	if humanoid then
		if humanoid.Health <= 0 then
			return true
		end

		local ok, state = pcall(function()
			return humanoid:GetState()
		end)
		if ok and state == Enum.HumanoidStateType.Dead then
			return true
		end
	end

	for _, descendant in ipairs(model:GetDescendants()) do
		if checkInstance(descendant) then
			return true
		end
	end

	return false
end

function isSoftAimAliveTarget(model, groupName)
	if not model then
		return false
	end

	groupName = groupName or targetCandidateGroups[model]
	local entityRoot = getHealthEntityRoot(model, groupName) or getEntityRootModel(model, groupName) or model
	local now = os.clock()
	local cached = softAimAliveCache[entityRoot]
	if cached and now - cached.Time < CONFIG.HealthRefreshInterval then
		return cached.Value
	end

	local value = false
	local ok, health = pcall(getAliveCheckHealth, model, groupName)
	if ok and health ~= nil then
		value = health > 0
	elseif not hasDeadStateFlag(model) then
		value = false
	end

	softAimAliveCache[entityRoot] = {
		Time = now,
		Value = value
	}
	return value
end

function getOffsetVector(value)
	return Vector3.new(0, value / 100, 0)
end

function getAimOffsetVector(groupName)
	return getOffsetVector(CONFIG.SoftAimYOffset + (groupName == "NPC" and CONFIG.NPCSoftAimResolver or 0))
end

function getAimPoint(model, groupName)
	local root = getRootPart(model)
	if not root then
		return nil, nil
	end

	local softAimOffset = getAimOffsetVector(groupName)

	if CONFIG.HitPart == "Head" then
		local part = getDirectPart(model, { "Head" }) or root
		return part, part.Position + softAimOffset
	end

	if CONFIG.HitPart == "Torso" then
		local part = getDirectPart(model, { "UpperTorso", "Torso", "LowerTorso", "HumanoidRootPart" }) or root
		return part, part.Position + softAimOffset
	end

	if CONFIG.HitPart == "Feet" then
		local left = getDirectPart(model, { "LeftFoot", "LeftLowerLeg", "Left Leg" })
		local right = getDirectPart(model, { "RightFoot", "RightLowerLeg", "Right Leg" })

		if left and right then
			return left, ((left.Position + right.Position) / 2) + softAimOffset
		end

		local foot = left or right
		if foot then
			return foot, foot.Position + softAimOffset
		end

		return root, root.Position - Vector3.new(0, 2.5, 0) + softAimOffset
	end

	if CONFIG.HitPart == "Random" then
		local now = os.clock()
		local cached = randomHitCache[model]

		if cached and cached.Part and cached.Part.Parent and now - cached.Time < 0.45 then
			return cached.Part, cached.Part.Position + softAimOffset
		end

		local candidates = {}
		local candidateNames = {
			"Head",
			"UpperTorso",
			"Torso",
			"LowerTorso",
			"HumanoidRootPart",
			"LeftFoot",
			"RightFoot",
			"LeftLowerLeg",
			"RightLowerLeg",
			"Left Leg",
			"Right Leg"
		}

		for _, name in ipairs(candidateNames) do
			local part = getDirectPart(model, { name })

			if part then
				table.insert(candidates, part)
			end
		end

		local chosen = candidates[math.random(1, math.max(1, #candidates))] or root
		randomHitCache[model] = {
			Part = chosen,
			Time = now
		}

		return chosen, chosen.Position + softAimOffset
	end

	return root, root.Position + softAimOffset
end

function addCandidate(model, seen, groupName)
	if seen[model] or not model or not model:IsA("Model") then
		return
	end

	seen[model] = true

	if groupName == "Animal" and isOwnHorseModel(model) then
		return
	end

	if not shouldTrackModel(model, groupName) then
		return
	end

	targetCandidateGroups[model] = groupName
	table.insert(targetCandidates, model)
end

function refreshTargetCandidates(force)
	local now = os.clock()
	if not force and lastCandidateRefresh > 0 and now - lastCandidateRefresh < CONFIG.TargetCandidateRefreshInterval then
		return
	end

	local _, playersFolder, animalsFolder, npcsFolder = getEntityFolders()
	local seen = {}
	targetCandidates = {}
	targetCandidateGroups = setmetatable({}, { __mode = "k" })
	lastCandidateRefresh = now

	if CONFIG.Players then
		if playersFolder then
			addTargetModelsFromFolder(playersFolder, "Player", seen)
		end

		for _, player in ipairs(Players:GetPlayers()) do
			if player ~= localPlayer and player.Character then
				addCandidate(player.Character, seen, "Player")
			end
		end
	end

	if CONFIG.Animals and animalsFolder then
		addTargetModelsFromFolder(animalsFolder, "Animal", seen)
	end

	if CONFIG.NPCs and npcsFolder then
		addTargetModelsFromFolder(npcsFolder, "NPC", seen)
	end
end

function getStableWorldModel(model, groupName)
	if not model or not model:IsA("Model") then
		return model
	end

	local rootModel = getEntityRootModel(model, groupName)
	if rootModel and rootModel:IsA("Model") then
		return rootModel
	end

	return model
end

function reassertWorldESPHighlight(model, groupName)
	local stableModel = getStableWorldModel(model, groupName)
	local esp = stableModel and worldEspObjects[stableModel]
	if not esp or not esp.Highlight or not esp.WorldVisible then
		return
	end

	esp.Highlight.Enabled = false
	esp.Highlight.Adornee = nil

	task.defer(function()
		if unloaded or not stableModel.Parent or not esp.Highlight then
			return
		end

		esp.Highlight.Adornee = stableModel
		esp.Highlight.Enabled = CONFIG.WorldEnabled and (CONFIG.WorldChams or (esp.OwnHorse and CONFIG.ZayHorse))
		lastWorldESPUpdate = 0
		if refreshWorldESP then
			refreshWorldESP(true)
		end
	end)
end

function shouldKeepAnimalESPWarm(model, esp, fromPosition)
	if not model or not model.Parent or not esp or esp.Group ~= "Animal" then
		return false
	end

	if not CONFIG.WorldAnimals and not (CONFIG.ZayHorse and esp.OwnHorse) then
		return false
	end

	local _, _, animalsFolder = getEntityFolders()
	if not animalsFolder or not model:IsDescendantOf(animalsFolder) then
		return false
	end

	local root = getRootPart(model)
	if root and fromPosition and CONFIG.WorldMaxDrawDistance > 0 then
		if (root.Position - fromPosition).Magnitude > CONFIG.WorldMaxDrawDistance then
			return false
		end
	end

	if esp.Highlight then
		esp.Highlight.Adornee = model
		esp.Highlight.Enabled = CONFIG.WorldEnabled and (CONFIG.WorldChams or (esp.OwnHorse and CONFIG.ZayHorse))
	end

	esp.WorldVisible = true
	return true
end

function addWorldCandidate(model, groupName, seen)
	model = getStableWorldModel(model, groupName)
	if not model or not model:IsA("Model") or seen[model] then
		return
	end

	seen[model] = true

	if not shouldTrackWorldModel(model, groupName) then
		return
	end

	table.insert(worldCandidates, {
		Model = model,
		Group = groupName
	})
end

function refreshWorldCandidates(force)
	local now = os.clock()
	if not force and lastWorldCandidateRefresh > 0 and now - lastWorldCandidateRefresh < CONFIG.CandidateRefreshInterval then
		return
	end

	local _, playersFolder, animalsFolder, npcsFolder = getEntityFolders()
	local seen = {}
	worldCandidates = {}
	lastWorldCandidateRefresh = now

	if CONFIG.WorldPlayers then
		if playersFolder then
			addWorldModelsFromFolder(playersFolder, "Player", seen)
		end

		for _, player in ipairs(Players:GetPlayers()) do
			if player ~= localPlayer and player.Character then
				addWorldCandidate(player.Character, "Player", seen)
			end
		end
	end

	if (CONFIG.WorldAnimals or CONFIG.ZayHorse or (CONFIG.WorldShowHealth and (CONFIG.WorldAnimalHealth or CONFIG.WorldHorseHealth))) and animalsFolder then
		addWorldModelsFromFolder(animalsFolder, "Animal", seen)
	end

	if CONFIG.WorldNPCs and npcsFolder then
		addWorldModelsFromFolder(npcsFolder, "NPC", seen)
	end
end

