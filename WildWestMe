function applyWorldEditorValues(force)
	if not CONFIG.WorldEditorLocked and not force then
		return
	end

	local brightness = CONFIG.WorldBrightness / 100
	local exposure = CONFIG.WorldExposure / 100
	local clockTime = CONFIG.WorldClockTime / 100

	if Lighting.Brightness ~= brightness then
		Lighting.Brightness = brightness
	end

	if Lighting.ExposureCompensation ~= exposure then
		Lighting.ExposureCompensation = exposure
	end

	if Lighting.ClockTime ~= clockTime then
		Lighting.ClockTime = clockTime
	end
end

function resetWorldEditorValues()
	local wasReady = worldEditorReady
	worldEditorReady = false
	CONFIG.WorldBrightness = math.clamp(math.floor(lightingDefaults.Brightness * 100 + 0.5), 0, 3000)
	CONFIG.WorldExposure = math.clamp(math.floor(lightingDefaults.ExposureCompensation * 100 + 0.5), -500, 500)
	CONFIG.WorldClockTime = math.clamp(math.floor(lightingDefaults.ClockTime * 100 + 0.5), 0, 2400)
	CONFIG.WorldEditorLocked = false

	Lighting.Brightness = lightingDefaults.Brightness
	Lighting.ExposureCompensation = lightingDefaults.ExposureCompensation
	Lighting.ClockTime = lightingDefaults.ClockTime

	if setWorldBrightnessSlider then
		setWorldBrightnessSlider(CONFIG.WorldBrightness)
	end
	if setWorldExposureSlider then
		setWorldExposureSlider(CONFIG.WorldExposure)
	end
	if setWorldClockTimeSlider then
		setWorldClockTimeSlider(CONFIG.WorldClockTime)
	end
	worldEditorReady = wasReady
end

