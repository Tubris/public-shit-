end

function getHealthBarColor(percent)
	percent = math.clamp(percent or 0, 0, 1)

	if percent >= 0.5 then
		return Color3.fromRGB(255, 220, 70):Lerp(Color3.fromRGB(80, 255, 110), (percent - 0.5) * 2)
	end

	return Color3.fromRGB(255, 65, 65):Lerp(Color3.fromRGB(255, 220, 70), percent * 2)
end

function getModelVisualSize(model)
