function restoreZaySelfColors()
	for part, original in pairs(zaySelfOriginals) do
		if part and part.Parent and original then
			pcall(function()
				part.BrickColor = original.BrickColor
				part.Color = original.Color
			end)
		end

		zaySelfOriginals[part] = nil
	end
end

function updateZaySelfColors()
	if not CONFIG.ZaySelf then
		restoreZaySelfColors()
		return
	end

	local entity = getLocalEntityModel()
	if not entity then
		return
	end

	local color = getZayColor(0)
	local brickColor = BrickColor.new(color)

	for _, partName in ipairs(ZAY_SELF_PART_NAMES) do
		local part = entity:FindFirstChild(partName)
		if part and part:IsA("BasePart") then
			if not zaySelfOriginals[part] then
				zaySelfOriginals[part] = {
					Color = part.Color,
					BrickColor = part.BrickColor
				}
			end

			part.BrickColor = brickColor
			part.Color = color
		end
	end
end

function applyDragonIRL()
	if not CONFIG.DragonIRL then
		for valueObject, oldValue in pairs(dragonOriginals) do
			if valueObject and valueObject.Parent then
				pcall(function()
					valueObject.Value = oldValue
				end)
			end

			dragonOriginals[valueObject] = nil
		end
		return
	end

	local entity = getLocalEntityModel()
	local humanoid = entity and entity:FindFirstChild("Humanoid", true)
	if not humanoid then
		return
	end

	for _, scaleName in ipairs({ "HeadScale", "BodyWidthScale", "BodyDepthScale" }) do
		local valueObject = humanoid:FindFirstChild(scaleName)
		if valueObject and (valueObject:IsA("NumberValue") or valueObject:IsA("IntValue")) then
			if dragonOriginals[valueObject] == nil then
				dragonOriginals[valueObject] = valueObject.Value
			end

			valueObject.Value = 5
		end
	end
end

function applyFreeBall()
	if not CONFIG.FreeBall then
		for clothing, oldValue in pairs(freeBallOriginals) do
			if clothing and clothing.Parent then
				pcall(function()
					if clothing:IsA("Pants") then
						clothing.PantsTemplate = oldValue
					elseif clothing:IsA("Shirt") then
						clothing.ShirtTemplate = oldValue
					end
				end)
			end

			freeBallOriginals[clothing] = nil
		end
		return
	end

	local entity = getLocalEntityModel()
	if not entity then
		return
	end

	local pants = entity:FindFirstChild("Pants", true)
	if pants and pants:IsA("Pants") then
		if freeBallOriginals[pants] == nil then
			freeBallOriginals[pants] = pants.PantsTemplate
		end
		pants.PantsTemplate = ""
	end

	local shirt = entity:FindFirstChild("Shirt", true)
	if shirt and shirt:IsA("Shirt") then
		if freeBallOriginals[shirt] == nil then
			freeBallOriginals[shirt] = shirt.ShirtTemplate
		end
		shirt.ShirtTemplate = ""
	end
end

