function getOrePositionAndAdornee(instance)
	if not instance or not instance.Parent then
		return nil, nil
	end

	if instance:IsA("BasePart") then
		return instance.Position, instance
	end

	if instance:IsA("Model") then
		local root = instance.PrimaryPart or instance:FindFirstChildWhichIsA("BasePart", true)
		local ok, pivot = pcall(function()
			return instance:GetPivot()
		end)

		if ok and pivot then
			return pivot.Position, root or instance
		end

		if root then
			return root.Position, root
		end
	end

	local worldPivot = instance:FindFirstChild("WorldPivot", true)
	if worldPivot then
		if worldPivot:IsA("BasePart") then
			return worldPivot.Position, worldPivot
		elseif worldPivot:IsA("CFrameValue") then
			return worldPivot.Value.Position, nil
		elseif worldPivot:IsA("Vector3Value") then
			return worldPivot.Value, nil
		end
	end

	local childModel = instance:FindFirstChildWhichIsA("Model", true)
	if childModel then
		local position = nil
		local root = childModel.PrimaryPart or childModel:FindFirstChildWhichIsA("BasePart", true)
		local ok, pivot = pcall(function()
			return childModel:GetPivot()
		end)

		if ok and pivot then
			position = pivot.Position
		end

		if position then
			return position, root or childModel
		end
	end

	local childPart = instance:FindFirstChildWhichIsA("BasePart", true)
	if childPart then
		return childPart.Position, childPart
	end

	return nil, nil
end

function addOreCandidate(instance, groupName, seen)
	if not instance or not instance.Parent or seen[instance] then
		return
	end

	local position, adornee = getOrePositionAndAdornee(instance)
	if not position then
		return
	end

	seen[instance] = true
	table.insert(oreCandidates, {
		Instance = instance,
		Group = groupName,
		Position = position,
		Adornee = adornee
	})
end

function refreshOreCandidates(force)
	local now = os.clock()
	if not force and lastOreCandidateRefresh > 0 and now - lastOreCandidateRefresh < CONFIG.CandidateRefreshInterval then
		return
	end

	oreCandidates = {}
	lastOreCandidateRefresh = now

	local oreDeposits = getOreDepositsFolder()
	if not oreDeposits then
		return
	end

	local seen = {}
	for folderName, groupName in pairs(ORE_FOLDER_TO_GROUP) do
		local folder = oreDeposits:FindFirstChild(folderName)
		if folder and CONFIG.OreGroups[groupName] then
			for _, child in ipairs(folder:GetChildren()) do
				addOreCandidate(child, groupName, seen)
			end
		end
	end
end

