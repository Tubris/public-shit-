local function makeCorner(parent, radius)
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, radius)
	corner.Parent = parent
	return corner
end

local function makeStroke(parent, color, thickness, transparency)
	local stroke = Instance.new("UIStroke")
	stroke.Color = color
	stroke.Thickness = thickness
	stroke.Transparency = transparency or 0
	stroke.Parent = parent
	return stroke
end

local function cycle(list, current)
	local index = table.find(list, current) or 1
	index += 1

	if index > #list then
		index = 1
	end

	return list[index]
end

local function isSoftAimActive()
	if unloaded then
		return false
	end

	if not CONFIG.Enabled then
		return false
	end

	if CONFIG.ActivationMode == "Always" then
		return true
	elseif CONFIG.ActivationMode == "Left Click" then
		return leftDown
	elseif CONFIG.ActivationMode == "Right Click" then
		return rightDown
	elseif CONFIG.ActivationMode == "Left Or Right" then
		return leftDown or rightDown
	end

	return false
end

local function getFullBrightEffect()
	if fullBrightEffect and fullBrightEffect.Parent then
		return fullBrightEffect
	end

	fullBrightEffect = Lighting:FindFirstChild("TubzFullBrightEffect")
	if not fullBrightEffect then
		fullBrightEffect = Instance.new("ColorCorrectionEffect")
		fullBrightEffect.Name = "TubzFullBrightEffect"
		fullBrightEffect.Parent = Lighting
	end

	fullBrightEffect.Brightness = 0.1
	fullBrightEffect.Contrast = 0.02
	fullBrightEffect.Saturation = 0.02
	fullBrightEffect.TintColor = Color3.fromRGB(255, 255, 245)

	return fullBrightEffect
end

local function getFullBrightLight()
	if fullBrightLightPart and fullBrightLightPart.Parent and fullBrightPointLight and fullBrightPointLight.Parent then
		return fullBrightLightPart, fullBrightPointLight
	end

	fullBrightLightPart = Workspace:FindFirstChild("TubzFullBrightLight")
	if not fullBrightLightPart then
		fullBrightLightPart = Instance.new("Part")
		fullBrightLightPart.Name = "TubzFullBrightLight"
		fullBrightLightPart.Size = Vector3.new(0.2, 0.2, 0.2)
		fullBrightLightPart.Transparency = 1
		fullBrightLightPart.Anchored = true
		fullBrightLightPart.CanCollide = false
		fullBrightLightPart.CanQuery = false
		fullBrightLightPart.CanTouch = false
		fullBrightLightPart.CastShadow = false
		fullBrightLightPart.Parent = Workspace
	end

	fullBrightPointLight = fullBrightLightPart:FindFirstChild("Fill")
	if not fullBrightPointLight then
		fullBrightPointLight = Instance.new("PointLight")
		fullBrightPointLight.Name = "Fill"
		fullBrightPointLight.Parent = fullBrightLightPart
	end

	fullBrightPointLight.Brightness = 1.6
	fullBrightPointLight.Range = 425
	fullBrightPointLight.Color = Color3.fromRGB(255, 248, 232)
	fullBrightPointLight.Shadows = false

	return fullBrightLightPart, fullBrightPointLight
end

local function applyFullBright()
