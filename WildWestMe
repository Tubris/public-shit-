function valueMatchesLocalPlayer(value)
	if value == nil then
		return false
	end

	if typeof(value) == "Instance" then
		local character = localPlayer.Character
		local localEntity = nil
		pcall(function()
			localEntity = getLocalEntityModel()
		end)

		return value == localPlayer
			or value == character
			or value == localEntity
			or (character ~= nil and value:IsDescendantOf(character))
			or (character ~= nil and character:IsDescendantOf(value))
			or (localEntity ~= nil and value:IsDescendantOf(localEntity))
			or (localEntity ~= nil and localEntity:IsDescendantOf(value))
	elseif typeof(value) == "number" then
		return value == localPlayer.UserId
	elseif type(value) == "string" then
		local normalized = normalizeLookupText(value)
		local playerName = normalizeLookupText(localPlayer.Name)
		local displayName = normalizeLookupText(localPlayer.DisplayName)
		local entityName = ""
		pcall(function()
			local localEntity = getLocalEntityModel()
			entityName = localEntity and normalizeLookupText(localEntity.Name) or ""
		end)

		return normalized ~= "" and (
			normalized == playerName
			or normalized == displayName
			or normalized == entityName
			or string.find(normalized, playerName, 1, true) ~= nil
			or (displayName ~= "" and string.find(normalized, displayName, 1, true) ~= nil)
			or (entityName ~= "" and string.find(normalized, entityName, 1, true) ~= nil)
		)
	end

	return false
end

function looksLikeOwnerKey(name)
	local normalized = normalizeLookupText(name)
	return string.find(normalized, "owner", 1, true) ~= nil
		or string.find(normalized, "owned", 1, true) ~= nil
		or string.find(normalized, "userid", 1, true) ~= nil
		or string.find(normalized, "username", 1, true) ~= nil
		or normalized == "user"
		or string.find(normalized, "player", 1, true) ~= nil
		or string.find(normalized, "character", 1, true) ~= nil
		or string.find(normalized, "claimed", 1, true) ~= nil
		or string.find(normalized, "tamed", 1, true) ~= nil
		or string.find(normalized, "controller", 1, true) ~= nil
		or string.find(normalized, "mount", 1, true) ~= nil
		or string.find(normalized, "rider", 1, true) ~= nil
end

function isOwnedByLocalPlayer(model)
	if not model then
		return false
	end

	if valueMatchesLocalPlayer(model.Name) then
		return true
	end

	local character = localPlayer.Character
	local humanoid = character and character:FindFirstChildWhichIsA("Humanoid", true)
	if humanoid then
		local ok, seatPart = pcall(function()
			return humanoid.SeatPart
		end)

		if ok and seatPart and seatPart:IsDescendantOf(model) then
			return true
		end
	end

	local function checkInstance(instance)
		for attributeName, attributeValue in pairs(instance:GetAttributes()) do
			if looksLikeOwnerKey(attributeName) and valueMatchesLocalPlayer(attributeValue) then
				return true
			end
		end

		if instance:IsA("ObjectValue") and looksLikeOwnerKey(instance.Name) and valueMatchesLocalPlayer(instance.Value) then
			return true
		end

		if (instance:IsA("StringValue") or instance:IsA("IntValue") or instance:IsA("NumberValue")) and looksLikeOwnerKey(instance.Name) then
			return valueMatchesLocalPlayer(instance.Value)
		end

		return false
	end

	if checkInstance(model) then
		return true
	end

	for _, child in ipairs(model:GetChildren()) do
		if checkInstance(child) then
			return true
		end
	end

	return false
end

function isOwnHorseModel(model)
	if not isAnimalModel(model) then
		return false
	end

	local now = os.clock()
	local rootModel = getEntityRootModel(model, "Animal") or model
	local cached = ownHorseCache[rootModel]
	if cached and now - cached.Time < 5 then
		return cached.Value
	end

	local value = isOwnedByLocalPlayer(rootModel) or isOwnedByLocalPlayer(model)

	ownHorseCache[rootModel] = {
		Time = now,
		Value = value
	}
	return value
end

function isHorseModel(model)
	if not model then
		return false
	end

	local now = os.clock()
	local cached = horseModelCache[model]
	if type(cached) == "table" and (cached.Value or now - cached.Time < 3) then
		return cached.Value
	elseif type(cached) == "boolean" then
		return cached
	end

	local rootModel = getEntityRootModel(model, "Animal") or model
	local function looksLikeHorse(instance)
		return instance ~= nil and string.find(normalizeLookupText(instance.Name), "horse", 1, true) ~= nil
	end

	local isHorse = looksLikeHorse(rootModel) or looksLikeHorse(model)
	local _, _, animalsFolder = getEntityFolders()
	local current = model

	while not isHorse and current and current ~= animalsFolder and current ~= Workspace do
		isHorse = looksLikeHorse(current)
		current = current.Parent
	end

	if not isHorse then
		for _, descendant in ipairs(rootModel:GetDescendants()) do
			if looksLikeHorse(descendant) then
				isHorse = true
				break
			end
		end
	end

	if not isHorse then
		isHorse = rootModel:FindFirstChild("HorseStats", true) ~= nil or model:FindFirstChild("HorseStats", true) ~= nil
	end

	local cacheEntry = {
		Time = now,
		Value = isHorse
	}
	horseModelCache[model] = cacheEntry
	if rootModel then
		horseModelCache[rootModel] = cacheEntry
	end

	return isHorse
end

function isLocalPlayerModel(model)
	if not model or not model:IsA("Model") then
		return true
	end

	local character = localPlayer.Character
	if character and (model == character or model:IsDescendantOf(character)) then
		return true
	end

	if Players:GetPlayerFromCharacter(model) == localPlayer then
		return true
	end

	local entityRoot = getEntityRootModel(model, "Player")
	return entityRoot ~= nil and (entityRoot.Name == localPlayer.Name or entityRoot.Name == localPlayer.DisplayName)
end

function shouldTrackModel(model, groupName)
	if not model or not model:IsA("Model") or not getRootPart(model) then
		return false
	end

	if groupName == "Player" then
		return not isLocalPlayerModel(model)
	end

	return not isOwnModel(model)
end

function shouldTrackWorldModel(model, groupName)
	if not model or not model:IsA("Model") or isOwnModel(model) or not getRootPart(model) then
		return false
	end

	if groupName == "Player" then
		if Players:GetPlayerFromCharacter(model) then
			return true
		end

		if not getDirectPart(model, { "HumanoidRootPart" }) and not model:FindFirstChildOfClass("Humanoid") then
			return false
		end
	end

	if groupName == "NPC" then
		local normalizedName = normalizeLookupText(model.Name)
		if string.find(normalizedName, "loadout", 1, true)
			or string.find(normalizedName, "holster", 1, true)
			or string.find(normalizedName, "weapon", 1, true)
			or string.find(normalizedName, "carbine", 1, true)
			or string.find(normalizedName, "rifle", 1, true)
			or string.find(normalizedName, "cattleman", 1, true)
			or string.find(normalizedName, "revolver", 1, true)
		then
			return false
		end

		if not getDirectPart(model, { "HumanoidRootPart", "Head", "UpperTorso", "Torso", "LowerTorso" })
			and not model:FindFirstChildOfClass("Humanoid")
		then
			return false
		end
	end

	return true
end

function hasTrackableAncestorInFolder(model, folder)
	local ancestor = model and model.Parent

	while ancestor and ancestor ~= folder do
		if ancestor:IsA("Model") and getRootPart(ancestor) then
			return true
		end

		ancestor = ancestor.Parent
	end

	return false
end

function hasWorldTrackableAncestorInFolder(model, folder, groupName)
	local ancestor = model and model.Parent

	while ancestor and ancestor ~= folder do
		if ancestor:IsA("Model") and shouldTrackWorldModel(ancestor, groupName) then
			return true
		end

		ancestor = ancestor.Parent
	end

	return false
end

function addTargetModelsFromFolder(folder, groupName, seen)
	if not folder then
		return
	end

	for _, descendant in ipairs(folder:GetDescendants()) do
		if descendant:IsA("Model") and not hasTrackableAncestorInFolder(descendant, folder) then
			addCandidate(descendant, seen, groupName)
		end
	end
end

function addWorldModelsFromFolder(folder, groupName, seen)
	if not folder then
		return
	end

	for _, descendant in ipairs(folder:GetDescendants()) do
		if descendant:IsA("Model")
			and shouldTrackWorldModel(descendant, groupName)
			and not hasWorldTrackableAncestorInFolder(descendant, folder, groupName)
		then
			addWorldCandidate(descendant, groupName, seen)
		end
	end
end

function isOwnModel(model)
	local character = localPlayer.Character

	if not model or not model:IsA("Model") then
		return true
	end

	if character and (model == character or model:IsDescendantOf(character) or character:IsDescendantOf(model)) then
		return true
	end

	if Players:GetPlayerFromCharacter(model) == localPlayer then
		return true
	end

	if isAnimalModel(model) then
		return false
	end

	if model.Name == localPlayer.Name or model.Name == localPlayer.DisplayName then
		return true
	end

	local userId = model:GetAttribute("UserId") or model:GetAttribute("UserID") or model:GetAttribute("PlayerUserId")
	if tonumber(userId) == localPlayer.UserId then
		return true
	end

	local owner = model:GetAttribute("Owner") or model:GetAttribute("Player") or model:GetAttribute("PlayerName")
	if owner == localPlayer.Name or owner == localPlayer.DisplayName then
		return true
	end

	for _, child in ipairs(model:GetChildren()) do
		if child:IsA("ObjectValue") and child.Value == localPlayer then
			return true
		end

		if child:IsA("IntValue") or child:IsA("NumberValue") then
			if (child.Name == "UserId" or child.Name == "UserID" or child.Name == "PlayerUserId") and child.Value == localPlayer.UserId then
				return true
			end
		end

		if child:IsA("StringValue") then
			if child.Value == localPlayer.Name or child.Value == localPlayer.DisplayName then
				return true
			end
		end
	end

	return false
end

function getAnimalDisplayName(model)
	local rootModel = getEntityRootModel(model, "Animal") or model
	if isHorseModel(rootModel or model) then
		return "Horse"
	end

	local nameText = rootModel and rootModel.Name or model and model.Name or "Animal"
	local normalizedName = normalizeLookupText(nameText)
	if normalizedName == "" or normalizedName == "model" then
		nameText = model and model.Name or "Animal"
	end

	return nameText
end

function getTargetDisplayName(model, groupName)
	if groupName == "Animal" then
		return getAnimalDisplayName(model)
	end

	local player = getPlayerForModel(model)
	if player then
		if player.DisplayName and player.DisplayName ~= "" then
			return player.DisplayName
		end

		return player.Name
	end

	return model.Name
end

function getLoadoutItemName(instanceName)
	local text = tostring(instanceName or "")
	local prefix = "loadoutitem/"

	if string.sub(string.lower(text), 1, #prefix) == prefix then
		return string.sub(text, #prefix + 1)
	end

	return nil
end

function isIgnoredPlayerWeaponModelName(instanceName)
	local normalized = normalizeLookupText(instanceName)
	if normalized == ""
		or normalized == "model"
		or normalized == "humanoid"
		or normalized == "humanoidrootpart"
		or normalized == "head"
		or normalized == "uppertorso"
		or normalized == "lowertorso"
		or normalized == "torso"
	then
		return true
	end

	return string.find(normalized, "holster", 1, true) ~= nil
		or string.find(normalized, "sheathe", 1, true) ~= nil
		or string.find(normalized, "scabbard", 1, true) ~= nil
end

function getPlayerWeaponName(model)
	local entityRoot = getEntityRootModel(model, "Player") or model
	if not entityRoot then
		return nil
	end

	local cache = playerLoadoutItemCache[entityRoot]
	if not cache then
		cache = {}
		playerLoadoutItemCache[entityRoot] = cache
	end

	for _, child in ipairs(entityRoot:GetChildren()) do
		if child:IsA("Model") then
			local loadoutName = getLoadoutItemName(child.Name)
			if loadoutName and loadoutName ~= "" then
				cache[normalizeLookupText(loadoutName)] = loadoutName
			end
		end
	end

	local fallbackName = nil
	local fallbackCount = 0

	for _, child in ipairs(entityRoot:GetChildren()) do
		if child:IsA("Model") and not getLoadoutItemName(child.Name) then
			local normalized = normalizeLookupText(child.Name)
			if cache[normalized] then
				return child.Name
			end

			if not isIgnoredPlayerWeaponModelName(child.Name)
				and child:FindFirstChildWhichIsA("BasePart", true)
			then
				fallbackName = child.Name
				fallbackCount += 1
			end
		end
	end

	if fallbackCount == 1 then
		return fallbackName
	end

	return nil
end

function normalizeLookupText(value)
	if value == nil then
		return ""
	end

	return string.lower(tostring(value)):gsub("[^%w]", "")
end

function getPlayerForModel(model)
	if not model then
		return nil
	end

	local directPlayer = Players:GetPlayerFromCharacter(model)
	if directPlayer then
		return directPlayer
	end

	local modelName = normalizeLookupText(model.Name)
	local userIdHints = {}
	local nameHints = {
		modelName
	}

	for _, attributeName in ipairs({ "UserId", "UserID", "PlayerUserId", "OwnerUserId", "OwnerID" }) do
		local value = model:GetAttribute(attributeName)
		if value ~= nil then
			userIdHints[tostring(value)] = true
		end
	end

	for _, attributeName in ipairs({ "Player", "Owner", "PlayerName", "Username", "UserName", "DisplayName", "CharacterName" }) do
		local value = model:GetAttribute(attributeName)
		if value ~= nil then
			nameHints[#nameHints + 1] = normalizeLookupText(value)
		end
	end

	for _, child in ipairs(model:GetChildren()) do
		if child:IsA("ObjectValue") and child.Value and child.Value:IsA("Player") then
			return child.Value
		end

		if (child:IsA("IntValue") or child:IsA("NumberValue")) and string.find(string.lower(child.Name), "userid", 1, true) then
			userIdHints[tostring(child.Value)] = true
		end

		if child:IsA("StringValue") then
			nameHints[#nameHints + 1] = normalizeLookupText(child.Value)
		end
	end

	for _, player in ipairs(Players:GetPlayers()) do
		if userIdHints[tostring(player.UserId)] then
			return player
		end

		local playerName = normalizeLookupText(player.Name)
		local displayName = normalizeLookupText(player.DisplayName)
		for _, hint in ipairs(nameHints) do
			if hint ~= "" and (
				hint == playerName
				or hint == displayName
				or string.find(hint, playerName, 1, true)
				or (displayName ~= "" and string.find(hint, displayName, 1, true))
			) then
				return player
			end
		end
	end

	return nil
end

function getNumberStat(model, names)
	local wanted = {}
	for _, name in ipairs(names) do
		wanted[string.lower(name)] = true
	end

	local function numberFrom(value)
		if typeof(value) == "number" then
			return value
		elseif type(value) == "string" then
			return tonumber(value)
		end

		return nil
	end

	local function readValueObject(instance)
		if not instance then
			return nil
		end

		local ok, value = pcall(function()
			return instance.Value
		end)

		if ok then
			local numberValue = numberFrom(value)
			if numberValue ~= nil then
				return numberValue
			end
		end

		return nil
	end

	local function getAttributeMatch(instance)
		for attributeName, attributeValue in pairs(instance:GetAttributes()) do
			if wanted[string.lower(attributeName)] then
				local numberValue = numberFrom(attributeValue)
				if numberValue ~= nil then
					return numberValue
				end
			end
		end

		return nil
	end

	for _, name in ipairs(names) do
		local attribute = numberFrom(model:GetAttribute(name))
		if attribute ~= nil then
			return attribute
		end

		local valueObject = model:FindFirstChild(name, true)
		local value = readValueObject(valueObject)
		if value ~= nil then
			return value
		end
	end

	local modelAttribute = getAttributeMatch(model)
	if modelAttribute ~= nil then
		return modelAttribute
	end

	for _, descendant in ipairs(model:GetDescendants()) do
		if wanted[string.lower(descendant.Name)] then
			local value = readValueObject(descendant)
			if value ~= nil then
				return value
			end
		end

		local attribute = getAttributeMatch(descendant)
		if attribute ~= nil then
			return attribute
		end
	end

	return nil
end

function readHealthFromInstance(instance)
	if not instance then
		return nil, nil, nil
	end

	if instance:IsA("Humanoid") and instance.MaxHealth > 0 then
		local humanoidCurrent = tonumber(instance:GetAttribute("Health"))
			or tonumber(instance:GetAttribute("HP"))
			or tonumber(instance:GetAttribute("CurrentHealth"))
			or instance.Health
		local humanoidMaximum = tonumber(instance:GetAttribute("MaxHealth"))
			or tonumber(instance:GetAttribute("MaxHP"))
			or tonumber(instance:GetAttribute("MaximumHealth"))
			or instance.MaxHealth

		if humanoidCurrent and humanoidMaximum and humanoidMaximum > 0 then
			humanoidCurrent = math.clamp(humanoidCurrent, 0, humanoidMaximum)
			return humanoidCurrent, humanoidMaximum, humanoidCurrent / humanoidMaximum
		end
	end

	local current = getNumberStat(instance, { "Health", "HP", "CurrentHealth", "CurrentHP", "HealthValue" })
	local maximum = getNumberStat(instance, { "MaxHealth", "MaxHP", "MaximumHealth", "MaximumHP", "HealthMax", "HPMax", "Max", "Maximum" })

	if current and maximum and maximum > 0 then
		current = math.clamp(current, 0, maximum)
		return current, maximum, current / maximum
	end

	if instance:IsA("Humanoid") and instance.MaxHealth > 0 then
		current = current or instance.Health
		maximum = maximum or instance.MaxHealth
		current = math.clamp(current, 0, maximum)
		return current, maximum, current / maximum
	end

	if current then
		maximum = maximum or (current > 100 and current or 100)
		current = math.clamp(current, 0, maximum)
		return current, maximum, current / maximum
	end

	return nil, nil, nil
end

function findNamedDescendant(instance, wantedName)
	if not instance then
		return nil
	end

	local wanted = string.lower(wantedName)
	if string.lower(instance.Name) == wanted then
		return instance
	end

	for _, descendant in ipairs(instance:GetDescendants()) do
		if string.lower(descendant.Name) == wanted then
			return descendant
		end
	end

	return nil
end

function getDirectNumberStat(instance, names)
	if not instance then
		return nil
	end

	local function toNumber(value)
		if typeof(value) == "number" then
			return value
		end

		return tonumber(value)
	end

	for _, name in ipairs(names) do
		local attribute = toNumber(instance:GetAttribute(name))
		if attribute ~= nil then
			return attribute
		end

		local child = instance:FindFirstChild(name)
		if child then
			local ok, value = pcall(function()
				return child.Value
			end)

			if ok then
				local numberValue = toNumber(value)
				if numberValue ~= nil then
					return numberValue
				end
			end
		end
	end

	return nil
end

function getAliveCheckHealth(model, groupName)
	if not model then
		return nil
	end

	local healthRoot = getHealthEntityRoot(model, groupName)
	if healthRoot then
		local current = readEntityHumanoidHealth(healthRoot)
		if current ~= nil then
			return current
		end
	end

	local humanoid = model:FindFirstChildWhichIsA("Humanoid", true)
	if humanoid then
		local current = readHealthFromInstance(humanoid)
		return current
	end

	local humanoidContainer = findNamedDescendant(model, "Humanoid")
	if humanoidContainer then
		local current = readHealthFromInstance(humanoidContainer)
		if current ~= nil then
			return current
		end
	end

	local entityRoot = getEntityRootModel(model, groupName)
	if entityRoot and entityRoot ~= model then
		local current = readHealthFromInstance(entityRoot)
		if current ~= nil then
			return current
		end
	end

	local current = getDirectNumberStat(model, { "Health", "HP", "CurrentHealth", "CurrentHP", "HealthValue" })
	if current ~= nil then
		return current
	end

	return nil
end

function getCachedHealthInfo(model, groupName)
	local now = os.clock()
	local cached = healthCache[model]

	if cached and now - cached.Time < CONFIG.HealthRefreshInterval then
		return cached.Current, cached.Maximum, cached.Percent
	end

	local current, maximum, percent = getHealthInfo(model, groupName)
	if current and maximum then
		local cachedMaximum = healthMaxCache[model]
		if not cachedMaximum or maximum > cachedMaximum then
			healthMaxCache[model] = maximum
		elseif cachedMaximum > maximum then
			maximum = cachedMaximum
			percent = maximum > 0 and math.clamp(current / maximum, 0, 1) or percent
		end
	end

	healthCache[model] = {
		Time = now,
		Current = current,
		Maximum = maximum,
		Percent = percent
	}

	return current, maximum, percent
end

function getHealthInfo(model, groupName)
	if not model then
		return nil, nil, nil
	end

	local player = groupName == "Player" and getPlayerForModel(model) or nil
	local entityRoot = getHealthEntityRoot(model, groupName)

	if entityRoot then
		local current, maximum, percent = readEntityHumanoidHealth(entityRoot)
		if current then
			return current, maximum, percent
		end
	end

	local humanoid = model:FindFirstChildWhichIsA("Humanoid", true) or findNamedDescendant(model, "Humanoid")
	local current, maximum, percent = readHealthFromInstance(humanoid)
	if current then
		return current, maximum, percent
	end

	if entityRoot and entityRoot ~= model then
		current, maximum, percent = readHealthFromInstance(entityRoot)
		if current then
			return current, maximum, percent
		end
	end

	if player and player.Character then
		local playerHumanoid = player.Character:FindFirstChildWhichIsA("Humanoid", true) or findNamedDescendant(player.Character, "Humanoid")
		current, maximum, percent = readHealthFromInstance(playerHumanoid)
		if current then
			return current, maximum, percent
		end
	end

	current, maximum, percent = readHealthFromInstance(model)
	if current then
		return current, maximum, percent
	end

	if player then
		current, maximum, percent = readHealthFromInstance(player)
		if current then
			return current, maximum, percent
		end
	end

	return nil, nil, nil
end

function isWorldHealthEnabled(groupName, horseModel)
	if not CONFIG.WorldShowHealth then
		return false
	end

	if groupName == "Player" then
		return CONFIG.WorldPlayerHealth
	elseif groupName == "Animal" then
		if horseModel then
			return CONFIG.WorldHorseHealth
