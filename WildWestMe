function getTrainSafe()
	local trains = Workspace:FindFirstChild("WORKSPACE_Trains")
	local running = trains and trains:FindFirstChild("RunningTrains")
	if not running then
		return nil
	end

	local children = running:GetChildren()
	local preferred = children[4]
	local preferredModel = preferred and preferred:FindFirstChild("Model")
	if preferredModel then
		local interior = preferredModel:FindFirstChild("Interior")
		local safe = interior and interior:FindFirstChild("HighTierSafe")
		if safe then
			return safe
		end
	end

	for _, train in ipairs(children) do
		local model = train:FindFirstChild("Model")
		local interior = model and model:FindFirstChild("Interior")
		local safe = interior and interior:FindFirstChild("HighTierSafe")
		if safe then
