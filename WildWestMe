	label.TextStrokeTransparency = 0.55
	label.Parent = billboard

	esp.Highlight = highlight
	esp.Billboard = billboard
	esp.Label = label
	oreEspObjects[instance] = esp
	return esp
end

clearOreESP = function()
	for instance, esp in pairs(oreEspObjects) do
		if esp.Highlight then
			esp.Highlight:Destroy()
		end

		if esp.Billboard then
			esp.Billboard:Destroy()
		end

		oreEspObjects[instance] = nil
	end
end

refreshOreESP = function(force)
	if unloaded then
		return
	end

	local now = os.clock()
	if not force and now - lastOreESPUpdate < CONFIG.OreESPInterval then
		return
	end

	lastOreESPUpdate = now

	if not CONFIG.WorldEnabled or not CONFIG.OreEnabled then
		for _, esp in pairs(oreEspObjects) do
			esp.Highlight.Enabled = false
			esp.Billboard.Enabled = false
		end

		return
	end

	refreshOreCandidates(force)

	local camera = Workspace.CurrentCamera
	local character = localPlayer.Character
	local characterRoot = character and character:FindFirstChild("HumanoidRootPart")
	local fromPosition = characterRoot and characterRoot.Position or camera and camera.CFrame.Position
	local visibleOre = {}

	for index = #oreCandidates, 1, -1 do
		local entry = oreCandidates[index]
		local instance = entry.Instance

		if not instance or not instance.Parent then
			table.remove(oreCandidates, index)
			continue
		end

		local position, adornee = getOrePositionAndAdornee(instance)
		if not position or not CONFIG.OreGroups[entry.Group] then
			continue
		end

		local distance = fromPosition and (position - fromPosition).Magnitude or 0
		local inRange = CONFIG.OreMaxDrawDistance <= 0 or distance <= CONFIG.OreMaxDrawDistance
		if not inRange then
			continue
		end

		visibleOre[instance] = true

		local esp = oreEspObjects[instance] or makeOreESPObject(instance)
		local color = CONFIG.OreColors[entry.Group] or Color3.fromRGB(255, 255, 255)
		local showText = CONFIG.OreName or CONFIG.OreDistance
		local textParts = {}

		if CONFIG.OreName then
			textParts[#textParts + 1] = entry.Group
		end

		if CONFIG.OreDistance then
			textParts[#textParts + 1] = tostring(math.floor(distance)) .. " studs"
		end

		esp.Highlight.FillColor = color
		esp.Highlight.OutlineColor = color:Lerp(Color3.fromRGB(255, 255, 255), 0.42)
		esp.Highlight.Adornee = adornee
		esp.Highlight.Enabled = CONFIG.OreChams and adornee ~= nil

		esp.Billboard.Adornee = adornee
		esp.Billboard.Enabled = showText and adornee ~= nil and (adornee:IsA("BasePart") or adornee:IsA("Attachment"))
		esp.Label.TextColor3 = color
		esp.Label.TextSize = CONFIG.WorldTextSize
		esp.Label.Text = table.concat(textParts, " | ")
	end

	for instance, esp in pairs(oreEspObjects) do
		if not visibleOre[instance] then
			esp.Highlight.Enabled = false
			esp.Billboard.Enabled = false
		end
	end
end

