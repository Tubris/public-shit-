function applySoftAimToProjectileInfo(info, projectileParams)
	if unloaded or not info or typeof(info.origin) ~= "Vector3" then
		return
	end

	if not shouldApplySoftAimForInfo(info) then
		return
	end

	local oldHitChance = CONFIG.HitChance
	CONFIG.HitChance = 100
	local newDirection, targetPosition = getSoftAimDirection(info.origin, info.direction)
	CONFIG.HitChance = oldHitChance

	if targetPosition and typeof(newDirection) == "Vector3" then
		info.direction = newDirection
		applySoftAimNoSpread(info, projectileParams)
	end
end

function installProjectileHandlerHook()
	local ok, projectileHandler = pcall(function()
		local sharedModules = ReplicatedStorage:WaitForChild("SharedModules", 5)
		if not sharedModules then
			return nil
		end

		local world = sharedModules:WaitForChild("World", 5)
		if not world then
			return nil
		end

		local moduleScript = world:WaitForChild("ProjectileHandler", 5)
		if not moduleScript then
			return nil
		end

		return require(moduleScript)
	end)

	if not ok or type(projectileHandler) ~= "table" then
		return
	end

	hookedProjectileHandler = projectileHandler
	projectileHandler.__SoftAimApplyInfo = applySoftAimToProjectileInfo

	if projectileHandler.__SoftAimHooked then
		return
	end

	if type(projectileHandler.GetProjectileSpread) == "function" then
		projectileHandler.__SoftAimOldGetSpread = projectileHandler.GetProjectileSpread
		local oldGetSpread = projectileHandler.GetProjectileSpread

		projectileHandler.GetProjectileSpread = function(self, projectileType, projectileParams, info, numProjectiles)
			if projectileHandler.__SoftAimApplyInfo then
				projectileHandler.__SoftAimApplyInfo(info, projectileParams)
			end

			return oldGetSpread(self, projectileType, projectileParams, info, numProjectiles)
		end
	end

	if type(projectileHandler.InitProjectiles) == "function" then
		projectileHandler.__SoftAimOldInit = projectileHandler.InitProjectiles
		local oldInit = projectileHandler.InitProjectiles

		projectileHandler.InitProjectiles = function(self, projectileType, projectileParams, info, callback)
			if projectileHandler.__SoftAimApplyInfo then
				projectileHandler.__SoftAimApplyInfo(info, projectileParams)
			end

			return oldInit(self, projectileType, projectileParams, info, callback)
		end
	end

	projectileHandler.__SoftAimHooked = true
end

reloadScript = function()
	local clone
	local parent = script.Parent

	if not parent then
		return false
	end

	pcall(function()
		script.Archivable = true
	end)

	pcall(function()
		clone = script:Clone()
	end)

	if not clone then
		return false
	end

	pcall(function()
		clone.Disabled = false
	end)
	pcall(function()
		clone.Enabled = true
	end)

	if unloadScript then
		unloadScript()
	end

	clone.Parent = parent

	pcall(function()
		script:Destroy()
	end)

	return true
end

