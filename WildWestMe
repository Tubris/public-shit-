	zayTintEffect = Lighting:FindFirstChild("TubzZayModeTint")
	if not zayTintEffect then
		zayTintEffect = Instance.new("ColorCorrectionEffect")
		zayTintEffect.Name = "TubzZayModeTint"
		zayTintEffect.Parent = Lighting
	end

	zayTintEffect.Brightness = 0.02
	zayTintEffect.Contrast = 0.05
	zayTintEffect.Saturation = 0.35
	return zayTintEffect
