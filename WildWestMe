local function makeSlider(parent, labelText, minValue, maxValue, defaultValue, order, callback, displayFormatter)
	local holder = Instance.new("Frame")
	holder.Size = UDim2.new(1, 0, 0, 62)
	holder.BackgroundColor3 = Color3.fromRGB(17, 19, 25)
	holder.BorderSizePixel = 0
	holder.LayoutOrder = order
	holder.ZIndex = 12
	holder.Parent = parent
	table.insert(themeSurfaces, holder)
	makeCorner(holder, 9)
	makeStroke(holder, Color3.fromRGB(56, 60, 74), 1, 0.38)

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, -18, 0, 22)
	label.Position = UDim2.fromOffset(9, 7)
	label.BackgroundTransparency = 1
	label.TextColor3 = Color3.fromRGB(226, 230, 240)
	label.Font = Enum.Font.GothamMedium
	label.TextSize = 13
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.ZIndex = 13
	label.Parent = holder

	local bar = Instance.new("Frame")
	bar.Size = UDim2.new(1, -18, 0, 6)
	bar.Position = UDim2.fromOffset(9, 42)
	bar.BackgroundColor3 = Color3.fromRGB(42, 45, 56)
	bar.BorderSizePixel = 0
	bar.ZIndex = 13
	bar.Parent = holder
	makeCorner(bar, 6)

	local fill = Instance.new("Frame")
	fill.Size = UDim2.fromScale(0, 1)
	fill.BackgroundColor3 = CONFIG.FOVColor
	fill.BorderSizePixel = 0
	fill.ZIndex = 14
	fill.Parent = bar
	makeCorner(fill, 6)

	local knob = Instance.new("Frame")
	knob.Size = UDim2.fromOffset(18, 18)
	knob.AnchorPoint = Vector2.new(0.5, 0.5)
	knob.Position = UDim2.fromScale(0, 0.5)
	knob.BackgroundColor3 = Color3.fromRGB(236, 240, 250)
	knob.BorderSizePixel = 0
	knob.ZIndex = 15
	knob.Parent = bar
	makeCorner(knob, 18)

	local draggingSlider = false

	local function setValue(value)
		value = math.clamp(math.floor(value), minValue, maxValue)
		local percent = (value - minValue) / (maxValue - minValue)

		label.Text = labelText .. ": " .. (displayFormatter and displayFormatter(value) or tostring(value))
		fill.Size = UDim2.fromScale(percent, 1)
		knob.Position = UDim2.fromScale(percent, 0.5)
		callback(value)
	end

	local function setValueFromX(x)
		local percent = math.clamp((x - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
		setValue(minValue + (maxValue - minValue) * percent)
	end

	holder.InputBegan:Connect(function(input)
		if unloaded then
			return
		end

		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			draggingSlider = true
			setValueFromX(input.Position.X)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if unloaded then
			return
		end

		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			draggingSlider = false
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if unloaded then
			return
		end

		if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
			setValueFromX(input.Position.X)
		end
	end)

	addAccentSetter(function(color)
		fill.BackgroundColor3 = color
	end)

	setValue(defaultValue)
	return setValue
end

