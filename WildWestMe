function restoreBoostInstance(instance, state)
	if not instance or not state then
		return
	end

	pcall(function()
		if state.Parent ~= nil then
			instance.Parent = state.Parent
		end

		for propertyName, value in pairs(state) do
			if propertyName ~= "Parent" then
				instance[propertyName] = value
			end
		end
	end)
end

function applyBoostFPS()
	if CONFIG.BoostFPS then
		if not boostFpsLightingState then
			boostFpsLightingState = {
				GlobalShadows = Lighting.GlobalShadows,
				EnvironmentDiffuseScale = Lighting.EnvironmentDiffuseScale,
				EnvironmentSpecularScale = Lighting.EnvironmentSpecularScale,
				ShadowSoftness = Lighting.ShadowSoftness
			}
		end

		Lighting.GlobalShadows = false
		Lighting.EnvironmentDiffuseScale = 0
		Lighting.EnvironmentSpecularScale = 0
		Lighting.ShadowSoftness = 0
		pcall(function()
			local terrain = Workspace:FindFirstChildOfClass("Terrain")
			if terrain and boostFpsLightingState.TerrainDecoration == nil then
				boostFpsLightingState.Terrain = terrain
				boostFpsLightingState.TerrainDecoration = terrain.Decoration
				terrain.Decoration = false
			end
		end)

		for _, descendant in ipairs(Workspace:GetDescendants()) do
			optimizeBoostInstance(descendant)
		end

		for _, descendant in ipairs(Lighting:GetDescendants()) do
			optimizeBoostInstance(descendant)
		end

		optimizeVegetationForBoost()
		optimizeLocalCharacterForBoost()
		repairFoliageBoostArtifacts()
		repairTextureBoostArtifacts()

		if not boostFpsConnection then
			boostFpsConnection = Workspace.DescendantAdded:Connect(function(descendant)
				task.defer(function()
					if not unloaded and CONFIG.BoostFPS then
						optimizeBoostInstance(descendant)
						optimizeLocalCharacterForBoost()
					end
				end)
			end)
		end
	else
		if boostFpsConnection then
			boostFpsConnection:Disconnect()
			boostFpsConnection = nil
		end

		for instance, state in pairs(boostFpsState) do
			restoreBoostInstance(instance, state)
		end

		boostFpsState = {}

		if boostFpsLightingState then
			Lighting.GlobalShadows = boostFpsLightingState.GlobalShadows
			Lighting.EnvironmentDiffuseScale = boostFpsLightingState.EnvironmentDiffuseScale
			Lighting.EnvironmentSpecularScale = boostFpsLightingState.EnvironmentSpecularScale
			Lighting.ShadowSoftness = boostFpsLightingState.ShadowSoftness
			pcall(function()
				if boostFpsLightingState.Terrain and boostFpsLightingState.TerrainDecoration ~= nil then
					boostFpsLightingState.Terrain.Decoration = boostFpsLightingState.TerrainDecoration
				end
			end)
			boostFpsLightingState = nil
		end

		repairFoliageBoostArtifacts()
		repairTextureBoostArtifacts()
	end
end

local function shouldClearFog()
	return CONFIG.ClearFog
end

local function shouldClearRain()
	return CONFIG.ClearRain
end

local function shouldClearClouds()
	return CONFIG.ClearClouds
end

local function applyClearFog()
	if shouldClearFog() then
		Lighting.FogStart = 0
		Lighting.FogEnd = 100000

		for _, descendant in ipairs(Lighting:GetDescendants()) do
			if descendant:IsA("Atmosphere") then
				if not atmosphereState[descendant] then
					atmosphereState[descendant] = {
						Density = descendant.Density,
						Haze = descendant.Haze,
						Glare = descendant.Glare
					}
				end

				descendant.Density = 0
				descendant.Haze = 0
				descendant.Glare = 0
			end
		end
	else
		if not CONFIG.FullBright then
			Lighting.FogStart = lightingDefaults.FogStart
			Lighting.FogEnd = lightingDefaults.FogEnd
		end

		for atmosphere, defaults in pairs(atmosphereState) do
			if atmosphere and atmosphere.Parent then
				atmosphere.Density = defaults.Density
				atmosphere.Haze = defaults.Haze
				atmosphere.Glare = defaults.Glare
			end
		end

		atmosphereState = {}
	end
end

local function applyClearClouds()
	local terrain = Workspace:FindFirstChildOfClass("Terrain")
	if not terrain then
		return
	end

	for _, child in ipairs(terrain:GetChildren()) do
		if child:IsA("Clouds") then
			if shouldClearClouds() then
				if not cloudState[child] then
					cloudState[child] = {
						Cover = child.Cover,
						Density = child.Density
					}
				end

				child.Cover = 0
				child.Density = 0
			elseif cloudState[child] then
				child.Cover = cloudState[child].Cover
				child.Density = cloudState[child].Density
				cloudState[child] = nil
			end
		end
	end
end

local function isRainObject(instance)
	local name = string.lower(instance.Name)
	return string.find(name, "rain") ~= nil
		or string.find(name, "storm") ~= nil
		or string.find(name, "drizzle") ~= nil
		or string.find(name, "weather") ~= nil
end

local function applyClearRain()
	local containers = { Workspace, Lighting }

	for _, container in ipairs(containers) do
		for _, descendant in ipairs(container:GetDescendants()) do
			local isVisual = descendant:IsA("ParticleEmitter") or descendant:IsA("Beam") or descendant:IsA("Trail")
			local isSound = descendant:IsA("Sound")

			if (isVisual or isSound) and isRainObject(descendant) then
				if shouldClearRain() then
					if not rainState[descendant] then
						rainState[descendant] = {
							Enabled = isVisual and descendant.Enabled or nil,
							Volume = isSound and descendant.Volume or nil
						}
					end

					if isVisual then
						descendant.Enabled = false
					elseif isSound then
						descendant.Volume = 0
					end
				elseif rainState[descendant] then
					if isVisual and rainState[descendant].Enabled ~= nil then
						descendant.Enabled = rainState[descendant].Enabled
					elseif isSound and rainState[descendant].Volume ~= nil then
						descendant.Volume = rainState[descendant].Volume
					end

					rainState[descendant] = nil
				end
			end
		end
	end
end

