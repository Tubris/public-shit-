refreshWorldESP = function(force)
	if unloaded then
		return
	end

	local now = os.clock()
	if not force and now - lastWorldESPUpdate < CONFIG.WorldESPInterval then
		return
	end

	lastWorldESPUpdate = now

	if not CONFIG.WorldEnabled then
		for _, esp in pairs(worldEspObjects) do
			esp.Highlight.Enabled = false
			esp.Billboard.Enabled = false
			esp.HealthBillboard.Enabled = false
			esp.WeaponBillboard.Enabled = false
			esp.Tracer.Visible = false
			esp.WorldVisible = false
		end

		return
	end

	refreshWorldCandidates(force)

	local camera = Workspace.CurrentCamera
	local character = localPlayer.Character
	local characterRoot = character and character:FindFirstChild("HumanoidRootPart")
	local fromPosition = characterRoot and characterRoot.Position or camera and camera.CFrame.Position
	local visibleModels = {}

	for index = #worldCandidates, 1, -1 do
		local entry = worldCandidates[index]
		local model = getStableWorldModel(entry.Model, entry.Group)
		entry.Model = model

		if not model or not model.Parent then
			table.remove(worldCandidates, index)
			continue
		end

		local root = getRootPart(model)
		if not root or not shouldTrackWorldModel(model, entry.Group) then
			continue
		end

		local distance = fromPosition and (root.Position - fromPosition).Magnitude or 0
		local inRange = CONFIG.WorldMaxDrawDistance <= 0 or distance <= CONFIG.WorldMaxDrawDistance
		if not inRange then
			continue
		end

		local ownHorse = entry.Group == "Animal" and isOwnHorseModel(model)
		local horseModel = entry.Group == "Animal" and isHorseModel(model)
		local showHealth = isWorldHealthEnabled(entry.Group, horseModel)
		local normalAnimalVisible = entry.Group ~= "Animal" or CONFIG.WorldAnimals
		if entry.Group == "Animal"
			and not normalAnimalVisible
			and not (ownHorse and CONFIG.ZayHorse)
			and not showHealth
		then
			continue
		end

		visibleModels[model] = true

		local esp = worldEspObjects[model] or makeWorldESPObject(model)
		local espColor = getWorldESPColor(entry.Group)
		local zayActive = CONFIG.ZayMode or (ownHorse and CONFIG.ZayHorse)
		if ownHorse then
			espColor = Color3.fromRGB(255, 240, 0)
		end
		if zayActive then
			espColor = ownHorse and CONFIG.ZayHorse and getZayColor(0) or getZayColor(getZayOffset(model))
		end

		local showText = ownHorse or CONFIG.WorldName or CONFIG.WorldDistance
		local textParts = {}

		if ownHorse then
			textParts[#textParts + 1] = "YOUR HORSEY"
		elseif CONFIG.WorldName then
			local nameOk, displayName = pcall(getTargetDisplayName, model, entry.Group)
			local nameText = (nameOk and displayName) or model.Name
			textParts[#textParts + 1] = nameText
		end

		if CONFIG.WorldDistance then
			textParts[#textParts + 1] = tostring(math.floor(distance)) .. " studs"
		end

		local healthCurrent = nil
		local healthMaximum = nil
		local healthPercent = nil
		local healthBarInRange = CONFIG.WorldHealthBarMaxDistance <= 0 or distance <= CONFIG.WorldHealthBarMaxDistance
		local needsHealthValue = showHealth and (CONFIG.WorldHealthMode == "Percent" or healthBarInRange)
		if needsHealthValue then
			healthCurrent, healthMaximum, healthPercent = getCachedHealthInfo(model, entry.Group)
			if CONFIG.WorldHealthMode == "Percent" and healthPercent then
				textParts[#textParts + 1] = tostring(math.floor(math.clamp(healthPercent, 0, 1) * 100 + 0.5)) .. "% HP"
				showText = true
			end
		end

		local weaponName = nil
		if entry.Group == "Player" and CONFIG.WorldPlayerWeapon then
			weaponName = getPlayerWeaponName(model)
		end

		esp.Highlight.FillColor = espColor
		esp.Highlight.OutlineColor = espColor:Lerp(Color3.fromRGB(255, 255, 255), 0.42)
		esp.Highlight.FillTransparency = ownHorse and CONFIG.ZayHorse and 0 or 0.78
		esp.Highlight.OutlineTransparency = ownHorse and CONFIG.ZayHorse and 0 or 0.18
		esp.Highlight.DepthMode = ownHorse and CONFIG.ZayHorse and Enum.HighlightDepthMode.AlwaysOnTop or Enum.HighlightDepthMode.AlwaysOnTop
		esp.Highlight.Adornee = model
		esp.Highlight.Enabled = (CONFIG.WorldChams and normalAnimalVisible) or (ownHorse and CONFIG.ZayHorse)

		esp.Billboard.Adornee = root
		esp.Billboard.Enabled = showText
		esp.Billboard.Size = UDim2.fromOffset(math.clamp(CONFIG.WorldTextSize * 19, 185, 360), math.clamp(CONFIG.WorldTextSize * 2, 20, 44))
		esp.Label.TextColor3 = zayActive and espColor or (ownHorse and Color3.fromRGB(255, 240, 0) or espColor:Lerp(Color3.fromRGB(255, 255, 255), 0.16))
		esp.Label.TextSize = CONFIG.WorldTextSize
		esp.Label.Text = table.concat(textParts, " / ")

		esp.Group = entry.Group
		esp.OwnHorse = ownHorse
		esp.ZayActive = zayActive
		esp.ZayOffset = getZayOffset(model)
		esp.TracerColor = espColor
		esp.TracerRoot = root
		esp.Tracer.Visible = false
		esp.WorldVisible = true
		esp.LastSeen = now

		local visualSize = nil
		if weaponName and weaponName ~= "" then
			visualSize = getModelVisualSize(model)
			esp.WeaponBillboard.Adornee = root
			esp.WeaponBillboard.StudsOffset = Vector3.new(0, -math.clamp((visualSize.Y / 2) + 0.8, 2.5, 6), 0)
			esp.WeaponBillboard.Size = UDim2.fromOffset(math.clamp(CONFIG.WorldTextSize * 14, 150, 270), math.clamp(CONFIG.WorldTextSize * 1.8, 18, 34))
			esp.WeaponBillboard.Enabled = true
			esp.WeaponLabel.TextColor3 = Color3.fromRGB(255, 230, 0)
			esp.WeaponLabel.TextSize = CONFIG.WorldTextSize
			esp.WeaponLabel.Text = weaponName
		else
			esp.WeaponBillboard.Enabled = false
		end

		if showHealth and CONFIG.WorldHealthMode == "Bar" and healthPercent and healthBarInRange then
			visualSize = visualSize or getModelVisualSize(model)
			local barHeight = math.clamp(visualSize.Y * 0.95, 2.2, 5.2)
			local barWidth = math.clamp(barHeight * 0.055, 0.12, 0.2)
			local sideOffset = math.clamp((visualSize.X / 2) + 0.45, 0.95, 3.2)
			esp.HealthBillboard.Adornee = root
			esp.HealthBillboard.StudsOffset = Vector3.new(sideOffset, 0, 0)
			esp.HealthBillboard.Size = UDim2.fromScale(barWidth, barHeight)
			esp.HealthBillboard.Enabled = true
			esp.HealthFill.Size = UDim2.fromScale(1, math.clamp(healthPercent, 0, 1))
			esp.HealthFill.BackgroundColor3 = getHealthBarColor(healthPercent)
		else
			esp.HealthBillboard.Enabled = false
		end
	end

	for model, esp in pairs(worldEspObjects) do
		local keepWarm = shouldKeepAnimalESPWarm(model, esp, fromPosition)
		if not visibleModels[model] and not keepWarm then
			esp.Highlight.Enabled = false
			esp.Billboard.Enabled = false
			esp.HealthBillboard.Enabled = false
			esp.WeaponBillboard.Enabled = false
			esp.Tracer.Visible = false
			esp.WorldVisible = false
		end
	end
end

function updateZayWorldColors()
	updateZayTint()
	updateZaySelfColors()

	if not CONFIG.ZayMode and not CONFIG.ZayHorse then
		return
	end

	for model, esp in pairs(worldEspObjects) do
		if esp.WorldVisible and esp.Highlight then
			local zayActive = CONFIG.ZayMode or (CONFIG.ZayHorse and esp.OwnHorse)
			if zayActive then
				local color = (CONFIG.ZayHorse and esp.OwnHorse) and getZayColor(0) or getZayColor(esp.ZayOffset or getZayOffset(model))
				esp.Highlight.FillColor = color
				esp.Highlight.OutlineColor = color:Lerp(Color3.fromRGB(255, 255, 255), 0.42)
				if CONFIG.ZayHorse and esp.OwnHorse then
					esp.Highlight.FillTransparency = 0
					esp.Highlight.OutlineTransparency = 0
				end
				if esp.Label then
					esp.Label.TextColor3 = color
				end
				if esp.Tracer then
					esp.Tracer.BackgroundColor3 = color
				end
				esp.TracerColor = color
			end
		end
	end
end

function updateWorldTracers()
	if not CONFIG.WorldEnabled or not CONFIG.WorldTracers then
		if worldTracersWereVisible then
			for _, esp in pairs(worldEspObjects) do
				if esp.Tracer then
					esp.Tracer.Visible = false
				end
			end
			worldTracersWereVisible = false
		end

		return
	end

	worldTracersWereVisible = true

	local camera = Workspace.CurrentCamera
	if not camera then
		return
	end

	local tracerStart = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y - 4)
	for model, esp in pairs(worldEspObjects) do
		if not model or not model.Parent or not esp.Tracer or not esp.TracerRoot or not esp.TracerRoot.Parent then
			if esp.Tracer then
				esp.Tracer.Visible = false
			end
			continue
		end

		if not esp.WorldVisible then
			esp.Tracer.Visible = false
			continue
		end

		local screenPoint, onScreen = camera:WorldToViewportPoint(esp.TracerRoot.Position)
		if not onScreen or screenPoint.Z <= 0 then
			esp.Tracer.Visible = false
			continue
		end

		local tracerEnd = Vector2.new(screenPoint.X, screenPoint.Y)
		local tracerDelta = tracerEnd - tracerStart
		local tracerLength = tracerDelta.Magnitude
		if tracerLength <= 2 then
			esp.Tracer.Visible = false
			continue
		end

		esp.Tracer.Visible = true
		esp.Tracer.BackgroundColor3 = esp.TracerColor or Color3.fromRGB(255, 255, 255)
		esp.Tracer.Position = UDim2.fromOffset((tracerStart.X + tracerEnd.X) / 2, (tracerStart.Y + tracerEnd.Y) / 2)
		esp.Tracer.Size = UDim2.fromOffset(tracerLength, 2)
		esp.Tracer.Rotation = math.deg(math.atan2(tracerDelta.Y, tracerDelta.X))
	end
end

function getOreDepositsFolder()
