function getEntityRootModel(model, groupName)
	if not model then
		return nil
	end

	local entities, playersFolder, animalsFolder, npcsFolder = getEntityFolders()
	local folder = groupName == "Player" and playersFolder or groupName == "Animal" and animalsFolder or groupName == "NPC" and npcsFolder or nil

	if not folder and entities then
		if playersFolder and model:IsDescendantOf(playersFolder) then
			folder = playersFolder
		elseif animalsFolder and model:IsDescendantOf(animalsFolder) then
			folder = animalsFolder
		elseif npcsFolder and model:IsDescendantOf(npcsFolder) then
			folder = npcsFolder
		end
	end

	if not folder then
		return model
	end

	local current = model
	while current and current.Parent and current.Parent ~= folder do
		current = current.Parent
	end

	if current and current.Parent == folder then
		return current
	end

	return model
end

function findChildInsensitive(parent, wantedName)
	if not parent then
		return nil
	end

	local wanted = normalizeLookupText(wantedName)
	for _, child in ipairs(parent:GetChildren()) do
		if normalizeLookupText(child.Name) == wanted then
			return child
		end
	end

	return nil
end

function findEntityRootByName(folder, name)
	if not folder or not name then
		return nil
	end

	local normalized = normalizeLookupText(name)
	for _, child in ipairs(folder:GetChildren()) do
		if normalizeLookupText(child.Name) == normalized then
			return child
		end
	end

	return nil
end

function getHealthEntityRoot(model, groupName)
	local _, playersFolder, animalsFolder = getEntityFolders()

	if groupName == "Player" and playersFolder then
		local player = getPlayerForModel(model)
		return (player and (findEntityRootByName(playersFolder, player.Name) or findEntityRootByName(playersFolder, player.DisplayName)))
			or findEntityRootByName(playersFolder, model and model.Name)
			or getEntityRootModel(model, groupName)
	elseif groupName == "Animal" and animalsFolder then
		return getEntityRootModel(model, groupName)
	end

	return getEntityRootModel(model, groupName)
end

