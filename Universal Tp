-- DRAG SYSTEM
local dragging = false
local dragStart
local frameStart

mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        frameStart = mainFrame.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(0, frameStart.X.Offset + delta.X, 0.5, frameStart.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

local function teleport()
    local character = localPlayer.Character
    if not character then 
        showErrorNotification("Character not found!")
        return 
    end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then 
        showErrorNotification("HumanoidRootPart not found!")
        return 
    end
    
    local x = tonumber(xInput.Text)
    local y = tonumber(yInput.Text)
    local z = tonumber(zInput.Text)
    local pos = rootPart.Position
    
    local success = false
    local coordMsg = ""
    
    if x and y and z then
        rootPart.CFrame = CFrame.new(x, y, z)
        coordMsg = string.format("(%.1f, %.1f, %.1f)", x, y, z)
        success = true
    elseif x and y then
        rootPart.CFrame = CFrame.new(x, y, pos.Z)
        coordMsg = string.format("(%.1f, %.1f, %.1f)", x, y, pos.Z)
        success = true
    elseif x and z then
        rootPart.CFrame = CFrame.new(x, pos.Y, z)
        coordMsg = string.format("(%.1f, %.1f, %.1f)", x, pos.Y, z)
        success = true
    elseif y and z then
        rootPart.CFrame = CFrame.new(pos.X, y, z)
        coordMsg = string.format("(%.1f, %.1f, %.1f)", pos.X, y, z)
        success = true
    elseif x then
        rootPart.CFrame = CFrame.new(x, pos.Y, pos.Z)
        coordMsg = string.format("(%.1f, %.1f, %.1f)", x, pos.Y, pos.Z)
        success = true
    elseif y then
        rootPart.CFrame = CFrame.new(pos.X, y, pos.Z)
        coordMsg = string.format("(%.1f, %.1f, %.1f)", pos.X, y, pos.Z)
        success = true
    elseif z then
        rootPart.CFrame = CFrame.new(pos.X, pos.Y, z)
        coordMsg = string.format("(%.1f, %.1f, %.1f)", pos.X, pos.Y, z)
        success = true
    else
        showErrorNotification("Enter at least one coordinate!")
        return
    end
    
    if success then
        showTeleportNotification(coordMsg)
    end
    
    TweenService:create(tpButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 255, 100)}):play()
    task.wait(0.2)
    TweenService:create(tpButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 150, 200)}):play()
end

tpButton.MouseButton1Click:Connect(teleport)

